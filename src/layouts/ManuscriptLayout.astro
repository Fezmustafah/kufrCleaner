---
import type { CollectionEntry } from 'astro:content';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';
import { siteConfig } from '@/config';
import { generatePostsListSEO } from '@/utils/seo';
import { processPost, formatDate, isValidDate } from '@/utils/markdown';
import { normalizeStatus, getStatusDisplayText, hasStatusStyling, getStatusClasses } from '@/utils/status';
import BaseLayout from '@/layouts/BaseLayout.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import Icon from '@/components/Icon.astro';

export interface Props {
  manuscript: CollectionEntry<'manuscripts'>;
}

const { manuscript } = Astro.props;

const {
  title,
  subtitle,
  abstract,
  authors,
  date,
  modified,
  type,
  status: rawStatus,
  tags,
  doi,
  url,
  pdf,
  publishedIn,
  volume,
  issue,
  pages: pagesField,
  references,
  hideTOC,
  showTOC,
  noIndex,
} = manuscript.data;

const status = normalizeStatus(rawStatus ?? 'draft');

const authorList = Array.isArray(authors) ? authors : authors ? [authors] : [];

const typeLabels: Record<string, string> = {
  essay: 'Essay',
  paper: 'Paper',
  'research-note': 'Research Note',
  review: 'Review',
  preprint: 'Preprint',
  other: 'Manuscript',
};
const typeLabel = typeLabels[type ?? 'essay'] ?? 'Manuscript';

const venueStr = [
  publishedIn,
  volume ? `vol. ${volume}` : null,
  issue ? `no. ${issue}` : null,
  pagesField ? `pp. ${pagesField}` : null,
].filter(Boolean).join(', ');

// Load global refs, merge with frontmatter refs (frontmatter wins on conflict)
let _globalRefs: CiteRef[] = [];
try {
  const gPath = join(process.cwd(), 'src/data/global-refs.json');
  if (existsSync(gPath)) _globalRefs = JSON.parse(readFileSync(gPath, 'utf-8'));
} catch { /* global-refs not yet generated */ }

const globalRefMap = new Map<string, CiteRef>(_globalRefs.map(r => [r.id, r]));

// Merge: frontmatter refs enriched with global metadata (frontmatter wins on conflict)
const fmIds = new Set((references ?? []).map((r: any) => r.id));
const mergedRefs: CiteRef[] = (references ?? []).map((ref: any) => {
  const global = globalRefMap.get(ref.id);
  return global ? { ...global, ...ref } : ref as CiteRef;
});

// Scan raw body for [@key] and append global refs not in frontmatter,
// in first-occurrence order — mirrors remark-citations pass-1 logic
{
  const bodyRegex = /\[@([a-zA-Z0-9_:.-]+)\]/g;
  const seen = new Set<string>(fmIds);
  let bm: RegExpExecArray | null;
  while ((bm = bodyRegex.exec(manuscript.body ?? '')) !== null) {
    const key = bm[1];
    if (!seen.has(key) && globalRefMap.has(key)) {
      seen.add(key);
      mergedRefs.push(globalRefMap.get(key)! as CiteRef);
    }
  }
}

const { Content, headings } = await processPost(manuscript as any);

const shouldShowTOC = siteConfig.tableOfContents.enabled && showTOC === true && !hideTOC && headings.length > 0;

const seoData = generatePostsListSEO(import.meta.env.SITE || '', undefined);
seoData.title = `${title} | ${siteConfig.title}`;
seoData.description = abstract || `${typeLabel} by ${authorList.join(', ')}`;
seoData.noIndex = noIndex ?? false;

// Format authors for citation display
const formatAuthor = (author: string) => author;

// Format a single reference for display
interface CiteRef {
  id: string;
  type?: string;
  title?: string;
  author?: string | string[];
  year?: number;
  journal?: string;
  booktitle?: string;
  publisher?: string;
  volume?: string;
  issue?: string;
  pages?: string;
  doi?: string;
  url?: string;
}

const formatReference = (ref: CiteRef, _num: number): string => {
  const authorStr = Array.isArray(ref.author)
    ? ref.author.join(', ')
    : (ref.author ?? '');
  const yearStr = ref.year ? ` (${ref.year}).` : '.';
  const titleStr = ref.title ? ` ${ref.title}.` : '';

  let venueInfo = '';
  if (ref.type === 'article' || ref.type === 'conference') {
    const venue = ref.journal ?? ref.booktitle ?? '';
    const vol = ref.volume ? `, ${ref.volume}` : '';
    const iss = ref.issue ? `(${ref.issue})` : '';
    const pg = ref.pages ? `, ${ref.pages}` : '';
    if (venue) venueInfo = ` <em>${venue}</em>${vol}${iss}${pg}.`;
  } else if (ref.type === 'book') {
    const pub = ref.publisher ?? '';
    if (pub) venueInfo = ` ${pub}.`;
  } else if (ref.type === 'chapter') {
    const bt = ref.booktitle ? ` In <em>${ref.booktitle}</em>.` : '';
    const pub = ref.publisher ? ` ${ref.publisher}.` : '';
    venueInfo = bt + pub;
  }

  const doiStr = ref.doi ? ` <a href="https://doi.org/${ref.doi}" target="_blank" rel="noopener" class="cite-doi">https://doi.org/${ref.doi}</a>` : '';
  const urlStr = !ref.doi && ref.url ? ` <a href="${ref.url}" target="_blank" rel="noopener" class="cite-doi">${ref.url}</a>` : '';

  return `${authorStr}${yearStr}${titleStr}${venueInfo}${doiStr}${urlStr}`;
};
---

<BaseLayout seoData={seoData}>
  <div class="pt-4 pb-16 md:py-8 relative">
    <div class="mx-auto px-4 sm:px-6 lg:px-8" style={`max-width: ${siteConfig.layout.contentWidth}`}>

      <!-- Back link -->
      <div class="mb-6">
        <a href="/manuscripts/" class="inline-flex items-center gap-1.5 text-sm text-primary-500 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-200 transition-colors">
          <Icon name="arrow-left" class="w-3.5 h-3.5" />
          Manuscripts
        </a>
      </div>

      <!-- Manuscript header -->
      <header class="mb-8 pb-6 border-b border-primary-200 dark:border-primary-700">
        <!-- Type + status badges -->
        <div class="flex items-center gap-2 mb-3 flex-wrap">
          <span class="font-mono text-xs text-highlight-600 dark:text-highlight-400 font-semibold tracking-widest uppercase bg-highlight-50 dark:bg-highlight-950 px-2 py-0.5 rounded">
            {typeLabel}
          </span>
          {hasStatusStyling(status) && (
            <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${getStatusClasses(status)}`}>
              {getStatusDisplayText(status)}
            </span>
          )}
        </div>

        <!-- Title -->
        <h1 class="text-2xl md:text-3xl font-bold text-primary-900 dark:text-primary-50 leading-tight mb-2">
          {title}
        </h1>

        <!-- Subtitle -->
        {subtitle && (
          <p class="text-lg italic text-primary-500 dark:text-primary-400 mb-4">{subtitle}</p>
        )}

        <!-- Authors -->
        {authorList.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {authorList.map(author => (
              <span class="text-sm text-primary-700 dark:text-primary-300 font-medium">
                {formatAuthor(author)}
              </span>
            ))}
          </div>
        )}

        <!-- Date + venue -->
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-primary-500 dark:text-primary-400 mb-4">
          {isValidDate(date) && <span>{formatDate(date)}</span>}
          {venueStr && <span class="italic">{venueStr}</span>}
          {modified && isValidDate(modified) && (
            <span class="text-xs">Updated {formatDate(modified)}</span>
          )}
        </div>

        <!-- External links: DOI / URL / PDF -->
        <div class="flex flex-wrap gap-4">
          {doi && (
            <a
              href={`https://doi.org/${doi}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm text-highlight-600 dark:text-highlight-400 hover:underline"
            >
              <Icon name="external-link" class="w-4 h-4" />
              DOI: {doi}
            </a>
          )}
          {url && (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm text-highlight-600 dark:text-highlight-400 hover:underline"
            >
              <Icon name="external-link" class="w-4 h-4" />
              Read online
            </a>
          )}
          {pdf && (
            <a
              href={`/manuscripts/${pdf}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm text-primary-500 dark:text-primary-400 hover:underline"
            >
              <Icon name="file-text" class="w-4 h-4" />
              PDF
            </a>
          )}
        </div>

        <!-- Tags -->
        {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-4">
            {tags.map(tag => (
              <a
                href={`/posts/tag/${tag}/`}
                class="text-xs px-2.5 py-0.5 rounded-full bg-primary-100 dark:bg-primary-800 text-primary-600 dark:text-primary-300 hover:bg-primary-200 dark:hover:bg-primary-700 transition-colors"
              >
                #{tag}
              </a>
            ))}
          </div>
        )}
      </header>

      <!-- Table of contents (if enabled) -->
      {shouldShowTOC && (
        <aside class="mb-8 p-4 bg-primary-50 dark:bg-primary-800 rounded-lg border border-primary-200 dark:border-primary-700">
          <TableOfContents headings={headings} />
        </aside>
      )}

      <!-- Abstract callout -->
      {abstract && (
        <div class="mb-8 p-4 border-l-4 border-highlight-500 dark:border-highlight-600 bg-primary-50 dark:bg-primary-800 rounded-r-lg">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary-400 dark:text-primary-500 mb-2">Abstract</p>
          <p class="text-sm text-primary-700 dark:text-primary-300 leading-relaxed">{abstract}</p>
        </div>
      )}

      <!-- Main content -->
      <article class="prose prose-sm dark:prose-dark max-w-none manuscript-body">
        <Content />
      </article>

      <!-- References section -->
      {mergedRefs.length > 0 && (
        <section class="mt-12 pt-8 border-t border-primary-200 dark:border-primary-700" id="references">
          <h2 class="text-base font-bold text-primary-900 dark:text-primary-50 mb-6 flex items-center gap-2">
            <Icon name="book-open" class="w-4 h-4 text-primary-400" />
            References
          </h2>
          <ol class="space-y-4 text-sm">
            {mergedRefs.map((ref, i) => (
              <li id={`ref-${ref.id}`} class="flex gap-3 text-primary-700 dark:text-primary-300 scroll-mt-24">
                <span class="flex-shrink-0 font-mono text-xs text-primary-400 dark:text-primary-500 w-6 text-right pt-0.5">
                  [{i + 1}]
                </span>
                <span
                  class="leading-relaxed"
                  set:html={formatReference(ref as any, i + 1)}
                />
              </li>
            ))}
          </ol>
        </section>
      )}

    </div>
  </div>
</BaseLayout>

<style>
  /* Citation link styling */
  :global(.cite-ref) {
    @apply text-highlight-600 dark:text-highlight-400 no-underline hover:underline font-mono text-xs;
    vertical-align: super;
    font-size: 0.7em;
  }

  :global(.cite-doi) {
    @apply text-highlight-600 dark:text-highlight-400 hover:underline break-all;
  }

  /* Manuscript body prose adjustments */
  :global(.manuscript-body) {
    @apply text-primary-800 dark:text-primary-200;
  }

  :global(.manuscript-body p) {
    @apply leading-relaxed mb-4;
  }

  :global(.manuscript-body h2) {
    @apply text-xl font-bold mt-10 mb-4;
  }

  :global(.manuscript-body h3) {
    @apply text-lg font-semibold mt-8 mb-3;
  }

  /* Highlight reference when jumped to via cite link */
  :global(li[id^="ref-"]:target) {
    @apply bg-highlight-50 dark:bg-highlight-950 rounded px-2 -mx-2;
  }
</style>
