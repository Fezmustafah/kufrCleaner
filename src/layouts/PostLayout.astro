---
import type { Post, Heading } from '@/types';
import { siteConfig } from '@/config';
import { generatePostSEO } from '@/utils/seo';
// import { getOptimizedFormat } from '@/utils/images'; // unused while PostBanner is disabled
import { processWikilinksInHTML } from '@/utils/internallinks';
import { getCollection } from 'astro:content';
import { shouldShowPost, processPost, calculateReadingTime, generateTOC, getAdjacentPosts, formatDate, formatDateMobile, getReadingTimeMobile } from '@/utils/markdown';
import BaseLayout from '@/layouts/BaseLayout.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import LinkedMentions from '@/components/LinkedMentions.astro';
import LocalGraph from '@/components/LocalGraph.astro';
import GiscusComments from '@/components/GiscusComments.astro';
import Lightbox from '@/components/Lightbox.astro';
import Icon from '@/components/Icon.astro';
// import PostBanner from '@/components/PostBanner.astro';
import ImageWrapper from '@/components/ImageWrapper.astro';
import { devConfig } from '@/config/dev';
import { readFileSync } from 'fs';
import { join } from 'path';

export interface Props {
  post: Post;
}

const { post } = Astro.props;

// Check if we're in development mode
const isDev = import.meta.env.DEV;

// Generate SEO data
const seoData = generatePostSEO(post, import.meta.env.SITE || '');



// Generate structured data for the post
const structuredData = {
  "@context": "https://schema.schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "author": {
    "@type": "Person",
    "name": siteConfig.author
  },
  "publisher": {
    "@type": "Organization",
    "name": siteConfig.title,
    "logo": {
      "@type": "ImageObject",
      "url": siteConfig.site + "/favicon.ico"
    }
  },
  "datePublished": post.data.date.toISOString(),
  "dateModified": post.data.date.toISOString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  }
};

// Get all posts for wikilink resolution
const allPosts = await getCollection('posts');
const visiblePosts = allPosts.filter(p => shouldShowPost(p, isDev));

// Process the post content and get processed data including word count
const { Content, headings, wordCount, remarkPluginFrontmatter } = await processPost(post);
const readingTime = calculateReadingTime(post.body || '');

// Generate table of contents if enabled
const hideTOC = post.data.hideTOC === true;
const shouldShowTOC = !hideTOC && siteConfig.tableOfContents.enabled && headings.length > 0;
const toc = shouldShowTOC ? await generateTOC(headings) : [];

// Get adjacent posts for navigation
const { prev: prevPost, next: nextPost } = getAdjacentPosts(visiblePosts, post.id);

// ── Post banner image resolution (commented out — PostBanner disabled) ───────
// let resolvedImageSrc: string | undefined;
// let resolvedImageBasePath: string | undefined;
// if (post.data.image) { ... }

// Check if current post has connections for LocalGraph
let hasLocalGraphConnections = false;
if (siteConfig.postOptions.graphView.enabled && siteConfig.postOptions.graphView.showInSidebar) {
  try {
    // Read the graph data file directly from the file system (works at build time)
    const graphDataPath = join(process.cwd(), 'public', 'graph', 'graph-data.json');
    const graphDataContent = readFileSync(graphDataPath, 'utf-8');
    const graphData = JSON.parse(graphDataContent);

    // Check if current post has any connections (both incoming and outgoing)
    const matchingConnections = graphData.connections.filter((conn: any) =>
      conn.source === post.id || conn.target === post.id
    );
    
    hasLocalGraphConnections = matchingConnections.length > 0;
  } catch (error) {
    // If we can't read the graph data at build time, don't show the graph
    hasLocalGraphConnections = false;
  }
}
---

<BaseLayout seoData={seoData}>
  <Fragment slot="head">
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Banner image is preloaded via fetchpriority="high" on the ImageWrapper -->

    <!-- Post-specific meta tags -->
    {post.data.targetKeyword && (
      <meta name="keywords" content={post.data.targetKeyword}>
    )}
  </Fragment>

  <!-- PostBanner disabled for layout testing
  <PostBanner
    imageSrc={resolvedImageSrc}
    imageBasePath={resolvedImageBasePath}
  />
  -->

  <!-- Ghost element: gives Header scroll script a #post-banner offsetHeight to threshold against,
       preserving the navbar hide-on-scroll behaviour without the visual banner. -->
  <div id="post-banner" aria-hidden="true" style="position:absolute;height:clamp(260px,44vh,520px);width:1px;pointer-events:none;visibility:hidden;"></div>

  <div class="py-8">
    <div
      class:list={["post-layout-grid", (shouldShowTOC || hasLocalGraphConnections) && "has-left-col"]}
      style={`--contentWidth: ${siteConfig.layout.contentWidth}`}
    >

      <!-- Main content -->
      <article class="post-layout-article">

        <!-- Post content wrapper -->
        <div class="post-content-wrapper px-6 md:px-9 pt-6 pb-4">
          <header class="mb-8">

            <!-- Category eyebrow -->
            {siteConfig.postOptions.categories && (post.data as any).category && (
              <a
                href={`${import.meta.env.BASE_URL}posts/category/${encodeURIComponent((post.data as any).category)}`}
                class="inline-block text-xs font-semibold tracking-[0.12em] uppercase text-highlight-600 dark:text-highlight-400 mb-3 hover:opacity-75 transition-opacity"
              >
                {(post.data as any).category}
              </a>
            )}

            <!-- Title -->
            <h1 class="text-3xl md:text-4xl font-bold text-primary-900 dark:text-primary-50 leading-tight mb-3">
              {post.data.title}
            </h1>

            <!-- Single meta line: date · read time · word count · tags -->
            <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-primary-400 dark:text-primary-500">

              <time datetime={post.data.date.toISOString()}>
                {formatDate(post.data.date)}
              </time>

              {siteConfig.postOptions.readingTime && readingTime && (
                <>
                  <span aria-hidden="true" class="select-none">·</span>
                  <span>{readingTime.text && readingTime.text !== 'read0' ? readingTime.text : '1 min read'}</span>
                </>
              )}

              {siteConfig.postOptions.wordCount && wordCount !== undefined && (
                <>
                  <span aria-hidden="true" class="select-none">·</span>
                  <span>{wordCount} words</span>
                </>
              )}

              {siteConfig.postOptions.tags && post.data.tags && post.data.tags.length > 0 && (
                <>
                  <span aria-hidden="true" class="select-none">·</span>
                  <div class="flex flex-wrap items-center gap-x-1.5">
                    {post.data.tags.map((tag, i) => (
                      <>
                        {i > 0 && <span class="text-primary-300 dark:text-primary-700 select-none">/</span>}
                        <a
                          href={`${import.meta.env.BASE_URL}posts/tag/${encodeURIComponent(tag)}`}
                          class="hover:text-secondary-500 dark:hover:text-secondary-300 transition-colors"
                        >
                          {tag}
                        </a>
                      </>
                    ))}
                  </div>
                </>
              )}

            </div>
          </header>

        <!-- Article content -->
        <div class="prose dark:prose-dark max-w-none" id="post-content">
          <Content />
        </div>

        {siteConfig.postOptions.linkedMentions.enabled && (
          <LinkedMentions currentSlug={post.id} />
        )}

        <!-- Post navigation -->
        {siteConfig.postOptions.postNavigation && (prevPost || nextPost) && (
          <nav class={`mt-8 pt-8 ${siteConfig.postOptions.linkedMentions.enabled ? '' : 'border-t border-primary-200 dark:border-primary-700'}`}>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {prevPost && (
                <div class="text-left">
                  <a
                    href={`${import.meta.env.BASE_URL}posts/${prevPost.id}`}
                    class="group block p-4 rounded-lg border border-primary-200 dark:border-primary-700 hover:border-highlight-300 dark:hover:border-highlight-600 transition-all duration-200 hover:shadow-md"
                  >
                    <h3 class="font-semibold text-primary-900 dark:text-primary-50 group-hover:text-highlight-600 dark:group-hover:text-highlight-400 transition-colors">
                      {prevPost.data.title}
                    </h3>
                    <div class="flex justify-start mt-2">
                      <Icon name="arrow-left" class="w-5 h-5 text-primary-500 dark:text-primary-400 group-hover:text-highlight-500 dark:group-hover:text-highlight-400 transition-colors" />
                    </div>
                  </a>
                </div>
              )}

              {nextPost && (
                <div class={`text-right ${!prevPost ? 'md:col-start-2' : ''}`}>
                  <a
                    href={`${import.meta.env.BASE_URL}posts/${nextPost.id}`}
                    class="group block p-4 rounded-lg border border-primary-200 dark:border-primary-700 hover:border-highlight-300 dark:hover:border-highlight-600 transition-all duration-200 hover:shadow-md"
                  >
                    <h3 class="font-semibold text-primary-900 dark:text-primary-50 group-hover:text-highlight-600 dark:group-hover:text-highlight-400 transition-colors">
                      {nextPost.data.title}
                    </h3>
                    <div class="flex justify-end mt-2">
                      <Icon name="arrow-right" class="w-5 h-5 text-primary-500 dark:text-primary-400 group-hover:text-highlight-500 dark:group-hover:text-highlight-400 transition-colors" />
                    </div>
                  </a>
                </div>
              )}
            </div>
          </nav>
        )}

        <!-- Giscus Comments -->
        {siteConfig.postOptions.comments.enabled && (
          <div class="mt-16">
            <GiscusComments
              postTitle={post.data.title}
              postSlug={post.id}
              postUrl={Astro.url.href}
            />
          </div>
        )}
        </div>
      </article>

      <!-- Left sidebar: Contents header (toggle) + TOC + Local graph -->
      {(shouldShowTOC || hasLocalGraphConnections) && (
        <aside class="post-layout-left-col" id="post-left-sidebar">
          <!-- Clickable "Contents" header — collapses/expands sidebar content -->
          <button
            class="sidebar-toc-header"
            id="sidebar-toc-header"
            aria-expanded="true"
            aria-controls="sidebar-toc-content"
            title="Toggle table of contents"
          >
            <!-- Ornamental divider — full width with centered diamond -->
            <span class="sidebar-toc-divider" aria-hidden="true">
              <span class="sidebar-toc-line"></span>
              <span class="sidebar-toc-ornament">◈</span>
              <span class="sidebar-toc-line"></span>
            </span>
            <!-- Tiny chevron below ornament indicates collapse state -->
            <svg class="sidebar-toc-chevron" xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="18 15 12 9 6 15"/>
            </svg>
          </button>

          <!-- Collapsible content: TOC + graph -->
          <div class="sidebar-toc-content" id="sidebar-toc-content">
            {shouldShowTOC && <TableOfContents headings={toc} />}
            {hasLocalGraphConnections && (
              <div class="left-sidebar-graph">
                <LocalGraph currentSlug={post.id} />
              </div>
            )}
          </div>
        </aside>
      )}
    </div>
  </div>
  </div>

  <Fragment slot="scripts">
    <!-- Marginalia: hover highlighting + popover (<1100px) + scroll+hash (≥1100px) -->
    <script>
      // (sidebar collapsed state is persisted via kufrCleaner:sidebarCollapsed in localStorage)

      function wireImgLightbox(img: HTMLImageElement, beforeOpen?: (e: MouseEvent) => void) {
        if ((img as any)._lightboxWired) return;
        (img as any)._lightboxWired = true;
        img.style.cursor = 'pointer';
        img.addEventListener('click', (e) => {
          beforeOpen?.(e);
          if (typeof window.openLightbox === 'function') {
            window.openLightbox(img.src, img.alt || '');
          }
        });
      }

      // ── JS-based note positioning (replaces CSS float/clear) ─────────────
      // Positions each .footnote absolutely to the right of the article,
      // aligned with its label and pushed down only when needed to avoid overlap.
      function layoutMarginaliaFloats() {
        const article = document.querySelector<HTMLElement>('.post-layout-article');
        if (!article) return;

        // Make article a containing block for absolute notes
        if (getComputedStyle(article).position === 'static') {
          article.style.position = 'relative';
        }

        const notes = Array.from(document.querySelectorAll<HTMLElement>('.footnote'));
        if (!notes.length) return;

        const isWide = window.innerWidth >= 1100;

        if (!isWide) {
          notes.forEach(n => { n.style.top = ''; n.style.left = ''; });
          article.style.minHeight = '';
          return;
        }

        const NOTE_WIDTH = 200;
        const NOTE_GAP  = 8;   // px between stacked notes
        const SIDE_GAP  = 12;  // px from article right edge to note left edge

        // Clear any stale minHeight so offsetHeight reflects natural content height below
        article.style.minHeight = '';

        const articleRect = article.getBoundingClientRect();
        let lastBottom = 0;

        notes.forEach(note => {
          const container = note.closest<HTMLElement>('.footnote-container');
          const label     = container?.querySelector<HTMLElement>('.footnote-number');
          if (!container || !label) return;

          const opParent = note.offsetParent as HTMLElement | null;
          const opRect   = opParent ? opParent.getBoundingClientRect() : articleRect;

          // Horizontal: note left edge sits SIDE_GAP right of the article card
          note.style.left = `${articleRect.right - opRect.left + SIDE_GAP}px`;

          // Vertical: align with label, push down past previous note if needed
          const labelRect    = label.getBoundingClientRect();
          const desiredTop   = labelRect.top - opRect.top;
          const topVal       = Math.max(desiredTop, lastBottom);
          note.style.top     = `${topVal}px`;

          lastBottom = topVal + note.offsetHeight + NOTE_GAP;
        });

        // Expand article to contain all notes so they don't overflow below the card.
        // minHeight was cleared above, so offsetHeight is the natural content height.
        const notesBottom = lastBottom - NOTE_GAP;
        if (notesBottom > article.offsetHeight) {
          // Include bottom padding + border so the last note doesn't clip at the card edge.
          const cs = getComputedStyle(article);
          const extraBottom = parseFloat(cs.paddingBottom) + parseFloat(cs.borderBottomWidth);
          article.style.minHeight = `${notesBottom + extraBottom}px`;
        }
      }

      function initMarginalia() {
        const containers = document.querySelectorAll<HTMLElement>('.footnote-container');
        if (!containers.length) return;

        // Whether the floated sidebar notes are visible
        const floatsVisible = () => window.innerWidth >= 1100;

        // Position notes immediately on init
        layoutMarginaliaFloats();

        // ── Abort stale listeners from previous page navigation ────────────
        // Each initMarginalia() call would stack more mouseenter/mouseleave on
        // the persistent pop element, causing multiple independent hideTimers
        // that cancelHide() from the current run cannot cancel. AbortController
        // wipes all of them cleanly on the next call.
        const prevAC = (window as any)._marginaliaAC as AbortController | undefined;
        if (prevAC) prevAC.abort();
        const ac = new AbortController();
        (window as any)._marginaliaAC = ac;
        const sig = ac.signal;

        // ── Recreate popover fresh (removes stale cloned listeners) ────────
        const oldPop = document.getElementById('marginalia-popover');
        if (oldPop) oldPop.remove();
        const pop = document.createElement('div');
        pop.id = 'marginalia-popover';
        pop.className = 'marginalia-popover';
        pop.setAttribute('role', 'tooltip');
        document.body.appendChild(pop);

        let hideTimer: ReturnType<typeof setTimeout> | null = null;
        const scheduleHide = () => { hideTimer = setTimeout(() => pop.classList.remove('is-visible'), 200); };
        const cancelHide   = () => { if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; } };

        const reposition = (anchor: HTMLElement) => {
          const rect = anchor.getBoundingClientRect();
          const pw = 260;
          // measure after content set, fall back to 0 if not yet rendered
          const ph = pop.offsetHeight || 0;
          const gap = 8;
          const top = (rect.top - ph - gap > 16) ? rect.top - ph - gap : rect.bottom + gap;
          const left = Math.max(8, Math.min(rect.left, window.innerWidth - pw - 8));
          pop.style.top  = `${top}px`;
          pop.style.left = `${left}px`;
        };

        const showPopoverFor = (anchor: HTMLElement, container: HTMLElement) => {
          cancelHide();
          const noteEl  = container.querySelector<HTMLElement>('.footnote');
          const labelEl = container.querySelector<HTMLElement>('.footnote-number');
          if (!noteEl || !labelEl) return;

          const allLabels = Array.from(document.querySelectorAll<HTMLElement>('.footnote-number'));
          const idx = allLabels.indexOf(labelEl) + 1;

          pop.innerHTML = `<span class="marginalia-popover-num">${idx}.</span><span class="marginalia-popover-text">${noteEl.innerHTML}</span>`;
          // Wire lightbox on images cloned into popover
          pop.querySelectorAll<HTMLImageElement>('img').forEach(img => {
            wireImgLightbox(img, (e) => { e.stopPropagation(); });
          });
          // Reserve space for images so reposition() gets correct height before load
          const imgs = pop.querySelectorAll<HTMLImageElement>('img');
          if (imgs.length) pop.style.minHeight = '160px';

          requestAnimationFrame(() => {
            reposition(anchor);
            pop.classList.add('is-visible');
            imgs.forEach(img => {
              if (img.complete) {
                pop.style.minHeight = '';
              } else {
                img.addEventListener('load',  () => { pop.style.minHeight = ''; reposition(anchor); }, { once: true });
                img.addEventListener('error', () => { pop.style.minHeight = ''; }, { once: true });
              }
            });
          });
        };

        pop.addEventListener('mouseenter', cancelHide, { signal: sig });
        pop.addEventListener('mouseleave', scheduleHide, { signal: sig });

        // ── Per-container wiring ───────────────────────────────────────────
        containers.forEach(container => {
          const noteEl  = container.querySelector<HTMLElement>('.footnote');
          const labelEl = container.querySelector<HTMLElement>('.footnote-number');
          if (!labelEl) return;

          // ── Hover highlighting (bidirectional, relatedTarget-safe) ───────
          // The float takes .footnote visually outside .footnote-container's
          // layout box, so mouseleave fires when crossing into the float.
          // We check relatedTarget to suppress false negatives.
          const highlight   = () => container.classList.add('is-highlighted');
          const unhighlight = (e: MouseEvent) => {
            const rt = e.relatedTarget as Node | null;
            if (rt && container.contains(rt)) return; // still inside
            container.classList.remove('is-highlighted');
          };

          container.addEventListener('mouseenter', highlight, { signal: sig });
          container.addEventListener('mouseleave', unhighlight as EventListener, { signal: sig });
          if (noteEl) {
            noteEl.addEventListener('mouseenter', highlight, { signal: sig });
            noteEl.addEventListener('mouseleave', unhighlight as EventListener, { signal: sig });
          }

          // ── Click behaviour ──────────────────────────────────────────────
          labelEl.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation(); // prevent document dismiss handler from closing the popover we just opened

            if (floatsVisible()) {
              // Desktop: scroll floated note into view + flash highlight
              if (!noteEl) return;
              noteEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
              container.classList.add('is-highlighted');
              setTimeout(() => container.classList.remove('is-highlighted'), 1500);
            } else {
              // <1100px: show popover
              showPopoverFor(labelEl, container);
            }
          }, { signal: sig });

          // ── Popover on hover (<1100px) ────────────────────────────────────
          container.addEventListener('mouseenter', () => {
            if (!floatsVisible()) showPopoverFor(labelEl, container);
          }, { signal: sig });
          container.addEventListener('mouseleave', () => {
            if (!floatsVisible()) scheduleHide();
          }, { signal: sig });
        });

        // ── Lightbox for images inside .footnote ──────────────────────────
        // Dispatch explicit image data so Lightbox doesn't fall back to
        // querySelectorAll('img') which would also pick up #lightbox-image itself.
        document.querySelectorAll<HTMLImageElement>('.footnote img').forEach(img => {
          wireImgLightbox(img, (e) => { e.stopPropagation(); });
        });

        // ── Global dismiss ─────────────────────────────────────────────────
        document.addEventListener('click', e => {
          if (!pop.contains(e.target as Node) && !(e.target as Element).closest?.('.footnote-container')) {
            pop.classList.remove('is-visible');
          }
        }, { signal: sig });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') pop.classList.remove('is-visible'); }, { signal: sig });

        // ── Dismiss popover / reflow notes on resize ───────────────────────
        let lastWasFloats = floatsVisible();
        let resizeTimer: ReturnType<typeof setTimeout> | null = null;
        window.addEventListener('resize', () => {
          const nowFloats = floatsVisible();
          if (nowFloats !== lastWasFloats) {
            pop.classList.remove('is-visible');
            document.querySelectorAll('.footnote-container.is-highlighted').forEach(c => c.classList.remove('is-highlighted'));
            lastWasFloats = nowFloats;
          }
          // Debounced re-layout so notes stay aligned after resize
          if (resizeTimer) clearTimeout(resizeTimer);
          resizeTimer = setTimeout(() => layoutMarginaliaFloats(), 100);
        }, { signal: sig, passive: true });
      }

      // Expose globally so BaseLayout's Swup hooks can call these
      window['initializeMarginalia']   = initMarginalia;
      window['layoutMarginaliaFloats'] = layoutMarginaliaFloats;

      // Double rAF: first frame exits font-swap reflow, second ensures paint is done
      function scheduleLayout() {
        requestAnimationFrame(() => requestAnimationFrame(() => layoutMarginaliaFloats()));
      }

      // Fresh browser load
      document.addEventListener('DOMContentLoaded', () => {
        initMarginalia();
        scheduleLayout();
        // Belt-and-suspenders: re-run after fonts settle (CDN swap may land late)
        document.fonts.ready.then(scheduleLayout);
      });

      // Swup page transition — this is the correct event for this codebase
      document.addEventListener('swup:page:view', () => {
        initMarginalia();
        scheduleLayout();
      });

      // Self-init: script evaluated into an already-live page (missed DOMContentLoaded)
      // Wrap in rAF so we don't read getBoundingClientRect before paint
      if (document.readyState !== 'loading') {
        requestAnimationFrame(() => {
          initMarginalia();
          scheduleLayout();
        });
      }

      window.addEventListener('pageshow', (e) => { if (e.persisted) { initMarginalia(); scheduleLayout(); } });
    </script>

    <!-- Contents sidebar collapse toggle -->
    <script>
      function initSidebarToggle() {
        const btn      = document.getElementById('sidebar-toc-header');
        const leftCol  = document.getElementById('post-left-sidebar');
        if (!btn || !leftCol || (btn as any)._wired) return;
        (btn as any)._wired = true;

        const KEY = 'kufrCleaner:sidebarCollapsed';
        if (localStorage.getItem(KEY) === 'true') {
          leftCol.classList.add('is-collapsed');
          btn.setAttribute('aria-expanded', 'false');
        }

        btn.addEventListener('click', () => {
          const collapsed = leftCol.classList.toggle('is-collapsed');
          btn.setAttribute('aria-expanded', String(!collapsed));
          localStorage.setItem(KEY, String(collapsed));
        });
      }

      window['initSidebarToggle'] = initSidebarToggle;
      document.addEventListener('DOMContentLoaded', initSidebarToggle);
      document.addEventListener('astro:page-load', initSidebarToggle);
      if (document.readyState !== 'loading') initSidebarToggle();
      window.addEventListener('pageshow', (e) => { if (e.persisted) initSidebarToggle(); });
    </script>

    <script define:vars={{ posts: visiblePosts.map(p => ({ id: p.id, data: { title: p.data.title } })), commentsEnabled: siteConfig.postOptions.comments.enabled, postTitle: post.data.title, postSlug: post.id }}>

      // Process wikilinks - unified logic for all wikilink types
      function initializeWikilinks() {
        const wikilinks = document.querySelectorAll('.wikilink[data-wikilink]');

        wikilinks.forEach(link => {
          const linkText = link.dataset.wikilink;

          // Skip same-page anchors (empty data-wikilink) - they're already properly formatted
          if (!linkText || linkText === '') {
            return;
          }

          const displayOverride = link.dataset.displayOverride;
          const currentDisplayText = link.textContent;

          // Find the matching post - use id (not slug, which is deprecated in Astro v6)
          const slug = linkText.toLowerCase()
            .replace(/[^a-z0-9\s-]/g, '')
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-')
            .replace(/^-+|-+$/g, '');

          // Helper function to create slug from title (same as resolveWikilink logic)
          const createSlugFromTitle = (title) => {
            return title.toLowerCase()
              .replace(/[^a-z0-9\s-]/g, '')
              .replace(/\s+/g, '-')
              .replace(/-+/g, '-')
              .replace(/^-+|-+$/g, '');
          };

          // First try exact id match (Astro v6 uses id, not slug)
          let post = posts.find(p => p.id === slug);

          // If not found, try title match (for wikilinks that use post titles)
          if (!post) {
            post = posts.find(p => createSlugFromTitle(p.data.title) === slug);
          }

          if (post) {
            // Update href - preserve anchor if present
            const currentHref = link.href || link.getAttribute('href') || '';
            const anchorMatch = currentHref.match(/#(.+)$/);
            const anchor = anchorMatch ? anchorMatch[1] : null;

            if (anchor) {
              link.href = `${import.meta.env.BASE_URL}posts/${post.id}#${anchor}`;
            } else {
              link.href = `${import.meta.env.BASE_URL}posts/${post.id}`;
            }

            if (displayOverride && displayOverride !== 'null' && displayOverride !== 'undefined') {
              // Wikilink with custom display: [[link|display]]
              link.textContent = displayOverride;
            } else if (displayOverride === 'null' || displayOverride === null || displayOverride === 'undefined' || displayOverride === undefined) {
              // Standard markdown link: [text](url) - NEVER change the display text
              // Keep currentDisplayText as-is
            } else {
              // Naked wikilink: [[link]] - use post title
              link.textContent = post.data.title;
            }
          } else {
            // Mark as broken link
            link.classList.add('wikilink-broken');
            link.title = 'Link not found';
          }
        });
      }

      window.initializeWikilinks = initializeWikilinks;
      // astro:page-load handles both initial load and Swup navigation
      document.addEventListener('astro:page-load', initializeWikilinks);

      // External links are now handled globally by BaseLayout Swup hooks

    </script>
    <!-- Heading permalink: copy URL to clipboard on click -->
    <script>
      function initHeadingPermalinks() {
        document.querySelectorAll<HTMLAnchorElement>('a[data-role="anchor"]').forEach(anchor => {
          if ((anchor as any)._permalinkWired) return;
          (anchor as any)._permalinkWired = true;

          anchor.addEventListener('click', (e) => {
            e.preventDefault();
            const href = anchor.getAttribute('href');
            if (!href) return;

            const url = new URL(window.location.href);
            url.hash = href;

            navigator.clipboard.writeText(url.toString()).catch(() => {});
            history.pushState(null, '', href);

            const target = document.getElementById(href.slice(1));
            if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });

            anchor.classList.add('permalink-copied');
            setTimeout(() => anchor.classList.remove('permalink-copied'), 1500);
          });
        });
      }

      document.addEventListener('DOMContentLoaded', initHeadingPermalinks);
      document.addEventListener('swup:page:view', initHeadingPermalinks);
    </script>

    <!-- Rough annotations -->
    <script>
      import { annotate } from 'rough-notation';

      function initAnnotations({ animate = true } = {}) {
        const spans = document.querySelectorAll<HTMLElement>('.rough-ann');
        if (!spans.length) return;

        // Remove all lingering rough-notation SVGs from body (Swup doesn't touch them —
        // rough-notation appends SVGs to <body> outside #swup-container)
        document.querySelectorAll('svg.rough-annotation').forEach(el => el.remove());
        const prev = (window as any)._roughAnnotations as any[] | undefined;
        if (prev?.length) prev.forEach(a => { try { a.hide(); } catch {} });

        // Read all annotation colors from CSS vars — defined in marginalia.css,
        // with light + dark variants. Override per-theme via [data-theme="*"].
        const cs = getComputedStyle(document.documentElement);
        const annColor = (type: string): string =>
          cs.getPropertyValue(`--ann-${type}`).trim() ||
          cs.getPropertyValue('--ann-highlight').trim();

        const annotations: any[] = [];

        spans.forEach(span => {
          const type = span.dataset.annType ?? 'highlight';
          const color = annColor(type);
          const opts: Record<string, any> = {
            type,
            color,
            iterations: 2,
            animate,
            animationDuration: 500,
          };

          // Block elements can wrap across lines — always enable multiline
          // except for circle (rough-notation wraps the whole element as one shape)
          if (type !== 'circle') opts.multiline = true;
          if (type === 'bracket') opts.brackets = ['left', 'right'];

          const ann = annotate(span, opts);
          ann.show();
          annotations.push(ann);
        });

        (window as any)._roughAnnotations = annotations;
      }

      // Expose globally for Swup hooks in BaseLayout
      window['initializeAnnotations'] = initAnnotations;
      // Fresh load: animate (no Swup transition running)
      document.addEventListener('DOMContentLoaded', () => initAnnotations({ animate: true }));
      // Swup navigation: wait for fade-in (200ms) to finish, then draw instantly
      // (animate:true conflicts with Swup's opacity transition — SVG renders invisible)
      document.addEventListener('astro:page-load', () => {
        setTimeout(() => initAnnotations({ animate: false }), 250);
      });
      // Self-init: script loaded into already-ready page (command palette from non-post page)
      if (document.readyState !== 'loading') setTimeout(() => initAnnotations({ animate: false }), 250);
      window.addEventListener('pageshow', (e) => {
        if (e.persisted) initAnnotations({ animate: true });
      });

      // Re-draw instantly (no animation) when dark/light mode toggles
      let _annLastDark = document.documentElement.classList.contains('dark');
      new MutationObserver(() => {
        const isDark = document.documentElement.classList.contains('dark');
        if (isDark !== _annLastDark) { _annLastDark = isDark; initAnnotations({ animate: false }); }
      }).observe(document.documentElement, { attributeFilter: ['class'] });
    </script>
  </Fragment>

  <!-- Lightbox is handled globally by BaseLayout -->

  <style>
    /* ── Banner overlap: content slides up over banner bottom ───────────── */
    .post-banner-overlap {
      margin-top: -3.5rem;
      position: relative;
      z-index: 10;
    }


    /* ── Break out of BaseLayout's max-width when sidebar is present ────── */
    :global(#main-content:has(.post-layout-grid.has-left-col)) {
      max-width: none !important;
    }

    /* ── Base grid: mobile / no-sidebar ─────────────────────────────────── */
    .post-layout-grid {
      display: grid;
      grid-template-columns: minmax(0, var(--contentWidth));
      justify-content: center;
      padding: 0 1rem;
    }

    .post-layout-article {
      min-width: 0;
      overflow: visible; /* must not clip floated notes */
      position: relative; /* containing block for absolute sidebar buttons + marginalia notes */
    }

    .post-layout-left-col {
      display: none;
    }

    /*
     * ≥1100px layout:
     *   [260px left col] [1fr article] [220px right gutter for marginalia]
     * Reader mode (sidebar hidden):
     *   [1fr article] [220px right gutter]  ← article expands, gutter kept for notes
     */
    @media (min-width: 1100px) {
      .post-layout-grid.has-left-col {
        grid-template-columns: 260px 1fr 220px;
        column-gap: 0.75rem;
        max-width: var(--page-width);
        margin-left: auto;
        margin-right: auto;
        padding: 0 1.5rem;
      }

      .post-layout-left-col {
        display: flex;
        flex-direction: column;
        grid-column: 1;
        grid-row: 1;
        position: sticky;
        top: 5rem;
        align-self: start;
        max-height: calc(100vh - 6rem);
        overflow: hidden;
        padding-top: 1rem;
        padding-bottom: 0.5rem;
        /* position: sticky creates a stacking context */
      }

      .post-layout-grid.has-left-col .post-layout-article {
        grid-column: 2;
        grid-row: 1;
      }
      /* col 3 (220px) intentionally empty — provides gutter for marginalia notes */

      /* ── Ornamental divider toggle ─────────────────────────────────────── */
      .sidebar-toc-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.18rem;
        width: 100%;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.1rem 0 0.55rem;
        color: rgb(var(--color-highlight-600));
        user-select: none;
        flex-shrink: 0;
        transition: color 0.15s;
      }
      .sidebar-toc-header:hover { color: rgb(var(--color-highlight-500)); }
      :global(.dark) .sidebar-toc-header { color: rgb(var(--color-highlight-400)); }
      :global(.dark) .sidebar-toc-header:hover { color: rgb(var(--color-highlight-300)); }

      /* Full-width line ─ ◈ ─ */
      .sidebar-toc-divider {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        width: 100%;
      }
      .sidebar-toc-line {
        flex: 1;
        height: 1px;
        background: rgb(var(--color-highlight-400) / 0.25);
        transition: background-color 0.15s;
      }
      .sidebar-toc-header:hover .sidebar-toc-line {
        background: rgb(var(--color-highlight-400) / 0.5);
      }
      .sidebar-toc-ornament {
        font-size: 0.7rem;
        opacity: 0.8;
        flex-shrink: 0;
        line-height: 1;
      }

      /* Chevron centered below ornament */
      .sidebar-toc-chevron {
        flex-shrink: 0;
        opacity: 0.55;
        transition: transform 0.2s ease, opacity 0.15s;
      }
      .sidebar-toc-header:hover .sidebar-toc-chevron { opacity: 0.85; }
      .post-layout-left-col.is-collapsed .sidebar-toc-chevron {
        transform: rotate(180deg);
      }

      /* ── Collapsible content: TOC + graph ────────────────────────────────── */
      .sidebar-toc-content {
        display: flex;
        flex-direction: column;
        flex: 1;
        min-height: 0;
        overflow: hidden;
        transition: opacity 0.18s ease, visibility 0.18s ease;
      }

      /*
       * Collapsed: content becomes invisible but column keeps its 260px width.
       * No layout shift — article and marginalia stay exactly where they are.
       */
      .post-layout-left-col.is-collapsed .sidebar-toc-content {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }

      /* TOC: natural height up to 60vh, scrolls internally if longer */
      .sidebar-toc-content :global(.toc-nav) {
        flex: 0 0 auto;
        min-height: 0;
        max-height: calc(60vh - 3rem);
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      .sidebar-toc-content :global(.toc-scroll-container) {
        flex: 1;
        min-height: 0;
      }

      /* Graph: sits right below TOC with a thin separator */
      .left-sidebar-graph {
        flex: 0 0 auto;
        margin-top: 0.5rem;
        padding-top: 0.5rem;
        border-top: 1px solid rgb(var(--color-primary-200) / 0.5);
      }
      :global(.dark) .left-sidebar-graph {
        border-top-color: rgb(var(--color-primary-700) / 0.5);
      }
    }
  </style>
</BaseLayout>
