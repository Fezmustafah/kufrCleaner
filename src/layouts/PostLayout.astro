---
import type { Post, Heading } from '@/types';
import { siteConfig } from '@/config';
import { generatePostSEO, generateBreadcrumbs, generateFAQSchema } from '@/utils/seo';
import { getCollection } from 'astro:content';
import { shouldShowPost, processPost, calculateReadingTime, generateTOC, getAdjacentPosts, formatDate, formatDateMobile, getReadingTimeMobile } from '@/utils/markdown';
import { getTagTitleMap, tagTitle } from '@/utils/tag-titles';
import BaseLayout from '@/layouts/BaseLayout.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import MobileTableOfContents from '@/components/MobileTableOfContents.astro';
import LinkedMentions from '@/components/LinkedMentions.astro';
import SiteGraph from '@/components/SiteGraph.astro';
import GiscusComments from '@/components/GiscusComments.astro';
import Lightbox from '@/components/Lightbox.astro';
import Icon from '@/components/Icon.astro';
import ImageWrapper from '@/components/ImageWrapper.astro';
import PageActions from '@/components/PageActions.astro';
import ReadingDeck from '@/components/ReadingDeck.astro';
import { devConfig } from '@/config/dev';
import { readFileSync } from 'fs';
import { join } from 'path';

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const tagTitles = await getTagTitleMap();

// Check if we're in development mode
const isDev = import.meta.env.DEV;

// Generate SEO data
const seoData = generatePostSEO(post, Astro.url.href);



// Generate structured data for the post
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "url": Astro.url.href,
  "inLanguage": siteConfig.language,
  ...(seoData.ogImage ? { "image": seoData.ogImage.url } : {}),
  ...(post.data.category ? { "articleSection": post.data.category } : {}),
  ...(post.data.targetKeyword || post.data.tags?.length
    ? { "keywords": post.data.targetKeyword || (post.data.tags || []).join(", ") }
    : {}),
  "author": {
    "@type": "Person",
    "name": post.data.author || siteConfig.author
  },
  // Reference the site-wide Organization node (@id) so Google consolidates the
  // publisher into one entity instead of a duplicate.
  "publisher": {
    "@id": siteConfig.site + "/#organization",
    "@type": "Organization",
    "name": siteConfig.title,
    "logo": {
      "@type": "ImageObject",
      "url": siteConfig.site + "/favicon.png"
    }
  },
  "isPartOf": { "@id": siteConfig.site + "/#website" },
  "datePublished": post.data.date.toISOString(),
  "dateModified": (post.data.modified || post.data.date).toISOString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  }
};

// BreadcrumbList: Home → Posts → this post. Enables breadcrumb rich results.
const breadcrumbData = generateBreadcrumbs([
  { name: "Home", url: `${siteConfig.site}/` },
  { name: "Posts", url: `${siteConfig.site}/posts/` },
  { name: post.data.title, url: Astro.url.href },
]);

// FAQPage: only when the post declares `faq` frontmatter (Q&A pairs).
const faqSchema = post.data.faq?.length
  ? generateFAQSchema(post.data.faq, Astro.url.href)
  : null;

// Get all posts for wikilink resolution
const allPosts = await getCollection('posts');
const visiblePosts = allPosts.filter(p => shouldShowPost(p, isDev));
const allTldrs = await getCollection('tldrs');
const tldr = allTldrs.find(entry => entry.id === `${post.id}/tldr`);

// Process the post content and get processed data including word count
const { Content, headings, wordCount, remarkPluginFrontmatter } = await processPost(post);
const readingTime = calculateReadingTime(post.body || '');

// Generate table of contents if enabled
const hideTOC = post.data.hideTOC === true;
const shouldShowTOC = !hideTOC && siteConfig.tableOfContents.enabled && headings.length > 0;
const toc = shouldShowTOC ? await generateTOC(headings) : [];

// Get adjacent posts for navigation
const { prev: prevPost, next: nextPost } = getAdjacentPosts(visiblePosts, post.id);

// ── Post banner image resolution (commented out — PostBanner disabled) ───────
// let resolvedImageSrc: string | undefined;
// let resolvedImageBasePath: string | undefined;
// if (post.data.image) { ... }

// Source citations quoted in the article body — counted at build time from
// callout markers (types are case-insensitive in remark-callouts).
const countMarkers = (re: RegExp) => (post.body || '').match(re)?.length || 0;
const sourceCounts = {
  quran: countMarkers(/^> ?\[!quran/gim),
  bible: countMarkers(/^> ?\[!bible/gim),
  hadith: countMarkers(/^> ?\[!hadith/gim),
  scholar: countMarkers(/^> ?\[!scholar/gim),
};

// Posts with {{margin notes}} (⟪⟫ is the MDX escape form) get the content
// block snugged toward the infobox so the pooled left whitespace can host
// margin notes beside the TOC rail. {{ in code fences may false-positive;
// harmless (just alignment).

const graphSidebarEnabled = siteConfig.postOptions.graphView.enabled && siteConfig.postOptions.graphView.showInSidebar;
let hasLocalGraphConnections = false;
if (graphSidebarEnabled) {
  try {
    const sitemapPath = join(process.cwd(), 'public', 'graph', 'sitemap.json');
    const sitemap = JSON.parse(readFileSync(sitemapPath, 'utf-8'));
    const entry = sitemap[`posts/${post.id}`];
    hasLocalGraphConnections = !!(
      (entry?.links?.length ?? 0) > 0 || (entry?.backlinks?.length ?? 0) > 0
    );
  } catch {
    hasLocalGraphConnections = false;
  }
}
---

<BaseLayout seoData={seoData}>
  <Fragment slot="head">
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    {faqSchema && (
      <script type="application/ld+json" set:html={faqSchema} />
    )}

    <!-- Banner image is preloaded via fetchpriority="high" on the ImageWrapper -->

    <!-- Post-specific meta tags -->
    {post.data.targetKeyword && (
      <meta name="keywords" content={post.data.targetKeyword}>
    )}
  </Fragment>

  <!-- PostBanner disabled for layout testing
  <PostBanner
    imageSrc={resolvedImageSrc}
    imageBasePath={resolvedImageBasePath}
  />
  -->

  <!-- Ghost element: gives Header scroll script a #post-banner offsetHeight to threshold against,
       preserving the navbar hide-on-scroll behaviour without the visual banner. -->
  <div id="post-banner" aria-hidden="true" style="position:absolute;height:clamp(260px,44vh,520px);width:1px;pointer-events:none;visibility:hidden;"></div>

  <div class="pt-3 pb-8">
    <div
      class:list={["post-layout-grid", (shouldShowTOC || hasLocalGraphConnections) && "has-left-col"]}
      style={`--contentWidth: ${siteConfig.layout.contentWidth}`}
    >

      <!-- Main content -->
      <article class="post-layout-article" data-pagefind-body>

        <!-- Post content wrapper -->
        <div class="post-content-wrapper px-0 md:px-9 pt-6 pb-4">
          <header class="mb-8">

            <!-- Category eyebrow -->
            {siteConfig.postOptions.categories && (post.data as any).category && (
              <a
                href={`${import.meta.env.BASE_URL}posts/category/${encodeURIComponent((post.data as any).category)}/`}
                class="inline-block text-xs font-semibold tracking-[0.12em] uppercase text-highlight-600 dark:text-highlight-400 mb-3 hover:opacity-75 transition-opacity"
                data-pagefind-meta="category"
                data-pagefind-filter="category"
              >
                {(post.data as any).category}
              </a>
            )}

            <!-- Title -->
            <h1 data-pagefind-meta="title" class="text-3xl md:text-4xl font-bold text-primary-900 dark:text-primary-50 leading-tight mb-3">
              {post.data.title}
            </h1>

            <!-- Single meta line: tags · bare updated date (wiki masthead — no
                 "Published/Updated" labels, no lead, no rule; the description is
                 SEO/card-only, and full dates live in the colophon at the bottom) -->
            <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-primary-400 dark:text-primary-500">

              {siteConfig.postOptions.tags && post.data.tags && post.data.tags.length > 0 && (
                <div class="flex flex-wrap items-center gap-x-1.5">
                  {post.data.tags.map((tag, i) => (
                    <>
                      {i > 0 && <span class="text-primary-300 dark:text-primary-700 select-none">/</span>}
                      <a
                        href={`${import.meta.env.BASE_URL}posts/tag/${encodeURIComponent(tag)}/`}
                        class="hover:text-secondary-500 dark:hover:text-secondary-300 transition-colors"
                        data-pagefind-filter="tag[data-raw-tag]"
                        data-raw-tag={tag}
                      >
                        {tagTitle(tagTitles, tag)}
                      </a>
                    </>
                  ))}
                  <span aria-hidden="true" class="select-none">·</span>
                </div>
              )}

              <time
                datetime={(post.data.modified ?? post.data.date).toISOString()}
                class="text-primary-300 dark:text-primary-600"
              >
                {formatDate(post.data.modified ?? post.data.date)}
              </time>

              {/* Publish date stays in the DOM for Pagefind's date meta */}
              <time datetime={post.data.date.toISOString()} data-pagefind-meta="date" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden">
                {formatDate(post.data.date)}
              </time>

            </div>
          </header>

          <ReadingDeck post={post} tldr={tldr} />

        <!-- Mobile TOC: sticky "Contents" popover, shown <1100px where the
             left-rail is hidden. Same headings as the rail. -->
        {shouldShowTOC && <MobileTableOfContents headings={toc} />}

        <!-- Article content -->
        <div class="prose dark:prose-dark max-w-none" id="post-content">
          <Content />
        </div>

        <!-- Colophon: document metadata + actions on one line, wiki-style —
             subtle, like reading a file's properties. -->
        {/* not-prose: page-actions-client relocates this inside #post-content
            (above the footnotes), where .prose typography would otherwise restyle it */}
        <section class="post-colophon not-prose" data-pagefind-ignore aria-label="About this article">
          <dl class="post-colophon-grid">
            <div>
              <dt>First published</dt>
              <dd><time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time></dd>
            </div>
            {/* No "Last revised" — the masthead already shows the bare revision date */}
            {siteConfig.postOptions.wordCount && wordCount && (
              <div>
                <dt>Length</dt>
                <dd>{wordCount.toLocaleString()} words · {siteConfig.postOptions.readingTime ? readingTime?.text : ''}</dd>
              </div>
            )}
            {(sourceCounts.quran > 0 || sourceCounts.bible > 0 || sourceCounts.hadith > 0 || sourceCounts.scholar > 0) && (
              <div>
                <dt>Sources cited</dt>
                <dd>
                  {[
                    sourceCounts.quran > 0 && `Qurʼan ${sourceCounts.quran}`,
                    sourceCounts.bible > 0 && `Bible ${sourceCounts.bible}`,
                    sourceCounts.hadith > 0 && `Hadith ${sourceCounts.hadith}`,
                    sourceCounts.scholar > 0 && `Scholars ${sourceCounts.scholar}`,
                  ].filter(Boolean).join(' · ')}
                </dd>
              </div>
            )}
          </dl>
          <PageActions
            postId={post.id}
            postTitle={post.data.title}
            postUrl={Astro.url.href}
          />
        </section>

        <!-- Connections: backlinks + local graph, side by side. The right
             gutter no longer hosts the graph — marginalia gets the whole strip. -->
        {(siteConfig.postOptions.linkedMentions.enabled || (graphSidebarEnabled && hasLocalGraphConnections)) && (
          <section class="post-connections" data-pagefind-ignore aria-label="Connections">
            <div class="post-connections-mentions">
              {siteConfig.postOptions.linkedMentions.enabled && (
                <LinkedMentions currentSlug={post.id} />
              )}
            </div>
            {graphSidebarEnabled && hasLocalGraphConnections && (
              <div class="post-connections-graph">
                <SiteGraph mode="sidebar" currentSlug={`posts/${post.id}`} />
              </div>
            )}
          </section>
        )}

        <!-- Post navigation — quiet text links; LinkedMentions above is the primary relation nav -->
        {siteConfig.postOptions.postNavigation && (prevPost || nextPost) && (
          <nav data-pagefind-ignore class="mt-8 pt-5 border-t border-primary-200/60 dark:border-primary-700/60 flex flex-wrap justify-between gap-x-6 gap-y-2 text-sm">
            {prevPost ? (
              <a
                href={`${import.meta.env.BASE_URL}posts/${prevPost.id}/`}
                class="group inline-flex items-center gap-1.5 max-w-[48%] text-primary-500 dark:text-primary-400 hover:text-highlight-600 dark:hover:text-highlight-400 transition-colors"
              >
                <Icon name="arrow-left" class="w-4 h-4 flex-shrink-0" />
                <span class="truncate">{prevPost.data.title}</span>
              </a>
            ) : <span></span>}

            {nextPost && (
              <a
                href={`${import.meta.env.BASE_URL}posts/${nextPost.id}/`}
                class="group inline-flex items-center gap-1.5 max-w-[48%] ml-auto text-right text-primary-500 dark:text-primary-400 hover:text-highlight-600 dark:hover:text-highlight-400 transition-colors"
              >
                <span class="truncate">{nextPost.data.title}</span>
                <Icon name="arrow-right" class="w-4 h-4 flex-shrink-0" />
              </a>
            )}
          </nav>
        )}

        <!-- Giscus Comments -->
        {siteConfig.postOptions.comments.enabled && (
          <div class="mt-16">
            <GiscusComments
              postTitle={post.data.title}
              postSlug={post.id}
              postUrl={Astro.url.href}
            />
          </div>
        )}
        </div>

        {/* Pagefind year filter + image meta — off-screen spans with text content, no hidden attribute */}
        <span data-pagefind-filter="year" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden">{String(post.data.date.getFullYear())}</span>
        <span data-pagefind-meta="image" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden">{seoData.ogImage?.url || ''}</span>
      </article>

      <!-- Left sidebar: minimal line-rail TOC (behaviour in toc-client.ts) -->
      {shouldShowTOC && (
        <aside class="post-layout-left-col" id="post-left-sidebar">
          <TableOfContents headings={toc} />
        </aside>
      )}

      <!-- Right column intentionally empty: the whole gutter belongs to
           marginalia now (infobox → colophon, graph → connections section). -->
    </div>
  </div>

  <!-- Scripts: hoisted by Astro to <head> as compiled modules.
       Previously wrapped in <Fragment slot="scripts"> which caused them to be rendered
       as inline uncompiled TypeScript in BaseLayout's body <slot name="scripts">.
       Without the Fragment wrapper, Astro's script hoisting compiles and deduplicates them. -->
    <!-- Marginalia: extracted to /src/scripts/marginalia-client.ts and imported globally from BaseLayout. -->

    <script define:vars={{ posts: visiblePosts.map(p => ({ id: p.id, data: { title: p.data.title } })), commentsEnabled: siteConfig.postOptions.comments.enabled, postTitle: post.data.title, postSlug: post.id, BASE_URL: import.meta.env.BASE_URL }}>

      // Process wikilinks - unified logic for all wikilink types
      function initializeWikilinks() {
        const wikilinks = document.querySelectorAll('.wikilink[data-wikilink]');

        wikilinks.forEach(link => {
          const linkText = link.dataset.wikilink;

          // Skip same-page anchors (empty data-wikilink) - they're already properly formatted
          if (!linkText || linkText === '') {
            return;
          }

          const displayOverride = link.dataset.displayOverride;
          const currentDisplayText = link.textContent;

          // Find the matching post - use id (not slug, which is deprecated in Astro v6)
          const slug = linkText.toLowerCase()
            .replace(/[^a-z0-9\s-]/g, '')
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-')
            .replace(/^-+|-+$/g, '');

          // Helper function to create slug from title (same slugification logic used server-side)
          const createSlugFromTitle = (title) => {
            return title.toLowerCase()
              .replace(/[^a-z0-9\s-]/g, '')
              .replace(/\s+/g, '-')
              .replace(/-+/g, '-')
              .replace(/^-+|-+$/g, '');
          };

          // First try exact id match (Astro v6 uses id, not slug)
          let post = posts.find(p => p.id === slug);

          // If not found, try title match (for wikilinks that use post titles)
          if (!post) {
            post = posts.find(p => createSlugFromTitle(p.data.title) === slug);
          }

          if (post) {
            // Update href - preserve anchor if present
            const currentHref = link.href || link.getAttribute('href') || '';
            const anchorMatch = currentHref.match(/#(.+)$/);
            const anchor = anchorMatch ? anchorMatch[1] : null;

            if (anchor) {
              link.href = `${BASE_URL}posts/${post.id}/#${anchor}`;
            } else {
              link.href = `${BASE_URL}posts/${post.id}/`;
            }

            if (displayOverride && displayOverride !== 'null' && displayOverride !== 'undefined') {
              // Wikilink with custom display: [[link|display]]
              link.textContent = displayOverride;
            } else if (displayOverride === 'null' || displayOverride === null || displayOverride === 'undefined' || displayOverride === undefined) {
              // Standard markdown link: [text](url) - NEVER change the display text
              // Keep currentDisplayText as-is
            } else {
              // Naked wikilink: [[link]] - use post title
              link.textContent = post.data.title;
            }
          } else {
            // Mark as broken link
            link.classList.add('wikilink-broken');
            link.title = 'Link not found';
          }
        });
      }

      window.initializeWikilinks = initializeWikilinks;
      // astro:page-load handles both initial load and Swup navigation
      document.addEventListener('astro:page-load', initializeWikilinks);

      // External links are now handled globally by BaseLayout Swup hooks

    </script>
    <!-- Heading permalink: copy URL to clipboard on click -->
    <script>
      import { haptics } from '@/scripts/haptics';

      function initHeadingPermalinks() {
        document.querySelectorAll<HTMLAnchorElement>('a[data-role="anchor"]').forEach(anchor => {
          if ((anchor as any)._permalinkWired) return;
          (anchor as any)._permalinkWired = true;

          anchor.addEventListener('click', (e) => {
            e.preventDefault();
            const href = anchor.getAttribute('href');
            if (!href) return;

            const url = new URL(window.location.href);
            url.hash = href;

            navigator.clipboard.writeText(url.toString())
              .then(() => haptics.success())
              .catch(() => {});
            history.pushState(null, '', href);

            const target = document.getElementById(href.slice(1));
            if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });

            anchor.classList.add('permalink-copied');
            setTimeout(() => anchor.classList.remove('permalink-copied'), 1500);
          });
        });

        // Tactile buzz when tapping a heading. behavior:'append' makes the anchor a
        // small icon, so wire the headings themselves — pointerdown fires on the
        // first iOS tap and keeps the switch-trick's user activation (unlike the
        // async copy .then()). Bubbles up from the icon too, so one buzz either way.
        document.querySelectorAll<HTMLElement>(
          '#post-content h2, #post-content h3, #post-content h4, #post-content h5, #post-content h6'
        ).forEach(h => {
          if ((h as any)._headingHaptic) return;
          (h as any)._headingHaptic = true;
          h.addEventListener('pointerdown', () => haptics.tap());
        });
      }

      document.addEventListener('DOMContentLoaded', initHeadingPermalinks);
      document.addEventListener('astro:page-load', initHeadingPermalinks);
    </script>

    <!-- Rough annotations: extracted to /src/scripts/annotations-client.ts and imported globally from BaseLayout. -->

  <!-- Lightbox is handled globally by BaseLayout -->

  <style>
    /* ── Banner overlap: content slides up over banner bottom ───────────── */
    .post-banner-overlap {
      margin-top: -3.5rem;
      position: relative;
      z-index: 10;
    }


    /* ── Break out of BaseLayout's max-width when sidebar is present ────── */
    :global(#main-content:has(.post-layout-grid.has-left-col)) {
      max-width: none !important;
    }

    /* ── Base grid: mobile / no-sidebar ─────────────────────────────────── */
    .post-layout-grid {
      display: grid;
      grid-template-columns: minmax(0, var(--contentWidth));
      justify-content: center;
      padding: 0 1rem;
    }

    .post-layout-article {
      min-width: 0;
      overflow: visible; /* must not clip floated notes */
      position: relative; /* containing block for absolute sidebar buttons + marginalia notes */
    }

    /* Anchor jumps (TOC links, hash loads, the desktop rail) must clear the
       fixed 3.5rem navbar instead of tucking the target heading under it. */
    :global(#post-content :is(h2, h3, h4, h5, h6)) {
      scroll-margin-top: 4.5rem;
    }

    .post-layout-left-col {
      display: none;
    }

    /* ── Colophon: document metadata + actions on one hairline-ruled line —
       the start of the end-zone (the TOC rail releases here). ── */
    .post-colophon {
      margin-top: 3rem;
      padding-top: 1.25rem;
      border-top: 1px solid rgb(var(--color-primary-200) / 0.8);
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: flex-end;
      gap: 1rem 2rem;
    }
    /* Actions stay on the metadata line: never wrap on desktop (the dl's own
       items may reflow instead), only stack on narrow screens */
    .post-colophon > :global(.post-actions-section) {
      flex-shrink: 0;
    }
    @media (min-width: 900px) {
      .post-colophon {
        flex-wrap: nowrap;
      }
      .post-colophon-grid {
        min-width: 0;
      }
    }
    :global(.dark) .post-colophon {
      border-top-color: rgb(var(--color-primary-700) / 0.8);
    }
    .post-colophon-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem 2.75rem;
      margin: 0;
    }
    .post-colophon-grid dt {
      font-size: 0.6875rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgb(var(--color-primary-400) / 0.85);
      margin-bottom: 0.15rem;
    }
    :global(.dark) .post-colophon-grid dt {
      color: rgb(var(--color-primary-500) / 0.85);
    }
    .post-colophon-grid dd {
      margin: 0;
      font-size: 0.8125rem;
      line-height: 1.5;
      color: rgb(var(--color-primary-600));
    }
    :global(.dark) .post-colophon-grid dd {
      color: rgb(var(--color-primary-400));
    }

    /* ── Connections: backlinks + local graph share the end-zone.
       No rule of its own — the colophon's hairline opens the end-zone and
       the section header is separation enough (fewer h-rules overall). ── */
    .post-connections {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      align-items: start;
      margin-top: 3rem;
    }
    .post-connections-graph {
      /* Node labels paint to the canvas edge — clip them at the cell */
      overflow: hidden;
    }
    @media (min-width: 900px) {
      .post-connections {
        grid-template-columns: 1fr 20rem;
      }
      /* Level the graph with the scrollable mentions list (below the
         "Connections" header: 1.5rem line + 1.5rem margin) */
      .post-connections-graph {
        margin-top: 3rem;
      }
      /* No backlinks → the graph is the whole section: full width */
      .post-connections:not(:has(#linked-mentions-toggle)) {
        grid-template-columns: 1fr;
      }
      .post-connections:not(:has(#linked-mentions-toggle)) .post-connections-graph {
        margin-top: 0;
        width: 100%;
      }
    }

    /*
     * ≥1100px layout:
     *   [260px left col] [1fr article] [220px right gutter for marginalia]
     * Reader mode (sidebar hidden):
     *   [1fr article] [220px right gutter]  ← article expands, gutter kept for notes
     */
    @media (min-width: 1100px) {
      .post-layout-grid.has-left-col {
        grid-template-columns: 1fr 15rem;
        column-gap: 0.5rem;
        max-width: var(--page-width);
        margin-left: auto;
        margin-right: auto;
        padding: 0 1.5rem;
      }

      /* TOC rail: pinned to the viewport's left edge, vertically centered
         (aarnphm). Out of the grid flow entirely — the freed column width
         goes to the article. toc-client toggles .toc-released once the post
         body ends (footnote section reaches mid-viewport) so the rail bows
         out where the "rest" of the document begins. */
      .post-layout-left-col {
        display: flex;
        flex-direction: column;
        position: fixed;
        left: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        z-index: 30;
        overflow: visible; /* floating TOC card extends past the rail */
        transition: opacity 0.3s ease;
      }
      .post-layout-left-col.toc-released {
        opacity: 0;
        pointer-events: none;
      }

      .post-layout-grid.has-left-col .post-layout-article {
        grid-column: 1;
        grid-row: 1;
      }

      /* Cap the content block at today's measure as --page-width widens the
         column (55.5rem = 51rem text + 2×2.25rem wrapper padding). Every
         post snugs toward the infobox so the geometry is identical whether
         or not a post has marginalia — the pooled whitespace always sits
         left of the text, between the TOC rail and the content, where margin
         notes live when present (see layoutMarginaliaFloats in
         marginalia-client.ts). */
      .post-layout-grid.has-left-col .post-content-wrapper {
        max-width: 55.5rem;
        margin-left: auto;
        margin-right: 0;
      }

    }

    /* ── Full layout at ≥1300px: wider gutter, roomier article ──────────── */
    @media (min-width: 1300px) {
      .post-layout-grid.has-left-col {
        grid-template-columns: 1fr 19rem;
        column-gap: 0.75rem;
      }
    }

    /* ── Compact prose at 1100-1299px ───────────────────────────────────── */
    @media (min-width: 1100px) and (max-width: 1299px) {
      :global(.post-layout-article .prose) {
        font-size: 1rem;
      }
      :global(.post-layout-article .prose h2) {
        font-size: 1.25em;
      }
      :global(.post-layout-article .prose h3) {
        font-size: 1.15em;
      }
    }
  </style>
</BaseLayout>
