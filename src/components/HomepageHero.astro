---
import { siteConfig } from '@/config';

interface Props {
  postCount: number;
  categoryCount: number;
}
const { postCount, categoryCount } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const hero = siteConfig.hero ?? {};
const heroImageRaw = hero.image;
const heroImage = heroImageRaw
  ? (heroImageRaw.startsWith('http') ? heroImageRaw : `${baseUrl}${heroImageRaw.replace(/^\//, '')}`)
  : undefined;
const overlayOpacity = hero.overlayOpacity ?? 0.55;
---

<section
  class="hero-section"
  style={heroImage ? `background-image: url('${heroImage}');` : undefined}
>

  <!-- Hero image overlay for text legibility -->
  {heroImage && (
    <div
      class="hero-image-overlay"
      style={`opacity: ${overlayOpacity};`}
      aria-hidden="true"
    />
  )}

  <div class="hero-inner">

    <!-- Top ornamental hairline -->
    <div class="hero-ornament-top" aria-hidden="true"></div>

    <!-- Site title -->
    <h1 class="hero-title">OpenIslam</h1>

    <!-- Subtitle -->
    <p class="hero-subtitle">Evidence-Based Islamic Scholarship & Apologetics</p>

    <!-- Mission statement -->
    <p class="hero-mission">
      Scholarly refutations of doubts about Islam — drawing on manuscript evidence,
      hadith authentication, Quranic linguistics, and Islamic history.
      Built for Muslims and researchers who need answers that hold up to scrutiny.
    </p>

    <!-- Live stats bar -->
    <div class="hero-stats" aria-label={`${postCount} articles across ${categoryCount} topics`}>
      <span>{postCount} articles</span>
      <span class="hero-stats-sep" aria-hidden="true">·</span>
      <span>{categoryCount} topics</span>
    </div>

    <!-- CTAs -->
    <div class="hero-ctas">
      <a href={`${baseUrl}posts/`} class="hero-btn-primary">
        Browse All Articles
      </a>
      <a href={`${baseUrl}search/`} class="hero-btn-outline">
        Search
      </a>
    </div>

    <!-- Bottom ornamental divider -->
    <div class="hero-divider" aria-hidden="true">
      <span class="hero-divider-ornament">◇ ✦ ◇</span>
    </div>

  </div>

  <!-- Scroll hint -->
  <div class="hero-scroll-hint" aria-hidden="true">↓</div>

</section>


<style>
  /* ── Section — full initial viewport, full-bleed, extends behind navbar ── */
  .hero-section {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow-x: clip;
    margin-top: -3.5rem;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: calc(3.5rem + 4rem) 2rem 3rem;
    background-color: #0D0A05;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  /* ── Dark overlay — dims the hero image for text legibility ── */
  .hero-image-overlay {
    position: absolute;
    inset: 0;
    background: #0D0A05;
    z-index: 0;
    pointer-events: none;
  }

  /* ── Inner content ── */
  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  /* ── Top ornament ── */
  .hero-ornament-top {
    width: 100%;
    height: 1px;
    margin: 0 auto 2rem;
    background:
      linear-gradient(to right, transparent, rgb(var(--color-highlight-400) / 0.55)) 0 0 / 46% 1px no-repeat,
      linear-gradient(to left,  transparent, rgb(var(--color-highlight-400) / 0.55)) 100% 0 / 46% 1px no-repeat;
    position: relative;
    overflow: visible;
  }
  .hero-ornament-top::before {
    content: '◈';
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    color: rgb(var(--color-highlight-400));
    font-size: 0.9rem;
    line-height: 1;
    white-space: nowrap;
  }

  /* ── Title ── */
  .hero-title {
    font-family: var(--font-heading, serif);
    font-size: clamp(1.9rem, 7vw, 3.8rem);
    font-weight: 600;
    letter-spacing: clamp(0.06em, 2vw, 0.15em);
    color: rgb(var(--color-primary-50));
    text-shadow: 0 0 60px rgb(var(--color-highlight-500) / 0.3);
    line-height: 1.1;
    margin: 0 0 0.85rem;
    text-transform: uppercase;
  }

  /* ── Subtitle ── */
  .hero-subtitle {
    font-family: var(--font-prose, serif);
    font-style: italic;
    font-size: clamp(0.95rem, 2.5vw, 1.2rem);
    color: rgb(var(--color-highlight-300));
    letter-spacing: 0.02em;
    margin: 0 0 1.5rem;
  }

  /* ── Mission ── */
  .hero-mission {
    font-family: var(--font-prose, serif);
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    line-height: 1.85;
    color: rgb(var(--color-primary-200));
    max-width: 36rem;
    margin: 0 auto 1.75rem;
  }

  /* ── Stats bar ── */
  .hero-stats {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-prose, serif);
    font-style: italic;
    font-size: 0.9rem;
    color: rgb(var(--color-primary-300));
    border-top: 1px solid rgb(var(--color-highlight-500) / 0.35);
    border-bottom: 1px solid rgb(var(--color-highlight-500) / 0.35);
    padding: 0.45rem 1.25rem;
    margin: 0 auto 2rem;
    letter-spacing: 0.04em;
  }
  .hero-stats-sep { color: rgb(var(--color-highlight-600) / 0.5); }

  /* ── CTAs ── */
  .hero-ctas {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.75rem;
  }

  .hero-btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1.35rem;
    min-height: 2.75rem;
    background: rgb(var(--color-highlight-500));
    color: #fff;
    font-family: var(--font-prose, serif);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    border-radius: 0.2rem;
    text-decoration: none;
    border: 1px solid rgb(var(--color-highlight-500));
    transition: background 0.18s, border-color 0.18s;
    white-space: nowrap;
  }
  .hero-btn-primary:hover {
    background: rgb(var(--color-highlight-400));
    border-color: rgb(var(--color-highlight-400));
    text-decoration: none;
  }

  .hero-btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.1rem;
    min-height: 2.75rem;
    background: transparent;
    color: rgb(var(--color-highlight-300));
    font-family: var(--font-prose, serif);
    font-size: 0.95rem;
    font-weight: 500;
    border: 1px solid rgb(var(--color-highlight-500) / 0.55);
    border-radius: 0.2rem;
    cursor: pointer;
    transition: border-color 0.18s, color 0.18s;
    white-space: nowrap;
  }
  .hero-btn-outline:hover {
    border-color: rgb(var(--color-highlight-400));
    color: rgb(var(--color-highlight-200));
  }
  .hero-btn-outline kbd {
    font-family: var(--font-mono, monospace);
    font-size: 0.7rem;
    padding: 0.1em 0.35em;
    background: rgb(var(--color-primary-800));
    border: 1px solid rgb(var(--color-primary-600) / 0.6);
    border-bottom-width: 2px;
    border-radius: 0.15rem;
    color: rgb(var(--color-primary-300));
  }
  @media (hover: none) and (pointer: coarse) {
    .hero-btn-outline kbd { display: none; }
  }

  .hero-btn-ghost {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-prose, serif);
    font-size: 0.9rem;
    color: rgb(var(--color-primary-400));
    text-decoration: none;
    border-bottom: 1px dotted rgb(var(--color-primary-600));
    padding: 0.6rem 0.25rem 0.05em;
    min-height: 2.75rem;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .hero-btn-ghost:hover {
    color: rgb(var(--color-highlight-400));
    border-bottom-color: rgb(var(--color-highlight-500));
    text-decoration: none;
  }

  /* ── Bottom divider ── */
  .hero-divider {
    width: 100%;
    height: 1px;
    margin: 0 auto;
    background:
      linear-gradient(to right, transparent, rgb(var(--color-highlight-500) / 0.5)) 0 0 / 46% 1px no-repeat,
      linear-gradient(to left,  transparent, rgb(var(--color-highlight-500) / 0.5)) 100% 0 / 46% 1px no-repeat;
    position: relative;
    overflow: visible;
  }
  .hero-divider-ornament {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    color: rgb(var(--color-highlight-400));
    font-size: 0.65em;
    letter-spacing: 0.35em;
    white-space: nowrap;
  }

  /* ── Scroll hint ── */
  .hero-scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: rgb(var(--color-highlight-500) / 0.5);
    font-size: 1rem;
    animation: bounce 2s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(6px); }
  }

  /* ── Tablet (481px–768px) ── */
  @media (max-width: 768px) {
    .hero-inner { max-width: 38rem; margin: 0 auto; }
    .hero-mission { font-size: clamp(0.9rem, 3vw, 1.1rem); }
  }

  /* ── Mobile (≤480px) ── */
  @media (max-width: 480px) {
    .hero-section { padding: calc(3.5rem + 3rem) 1rem 2rem; }
    .hero-ornament-top { margin-bottom: 1.25rem; }
    .hero-ctas { gap: 0.6rem; flex-direction: column; align-items: stretch; }
    .hero-btn-primary,
    .hero-btn-outline { width: 100%; justify-content: center; }
    .hero-btn-ghost { margin-top: 0.25rem; justify-content: center; }
    .hero-stats { font-size: 0.82rem; padding: 0.4rem 0.9rem; }
  }
</style>
