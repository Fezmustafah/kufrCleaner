---
import { siteConfig } from '@/config';

interface Props {
  postCount: number;
  categoryCount: number;
  totalWords?: number;
}
const { postCount, categoryCount, totalWords = 0 } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const hero = siteConfig.hero ?? {};
const heroImageRaw = hero.image;
const heroImage = heroImageRaw
  ? (heroImageRaw.startsWith('http') ? heroImageRaw : `${baseUrl}${heroImageRaw.replace(/^\//, '')}`)
  : undefined;
const overlayOpacity = hero.overlayOpacity ?? 0.55;
---

<section
  class="hero-section"
  style={heroImage ? `background-image: url('${heroImage}');` : undefined}
>

  <!-- Hero image overlay for text legibility -->
  {heroImage && (
    <div
      class="hero-image-overlay"
      style={`opacity: ${overlayOpacity};`}
      aria-hidden="true"
    />
  )}

  <div class="hero-inner">

    <p class="hero-kicker">A scholarly reference</p>

    <h1 class="hero-title">
      Reasoned responses to the <em>allegations against Islam</em>.
    </h1>

    <p class="hero-lede">
      Point-by-point answers — sourced, cited, and written for clarity.
      Search any claim to read the scholarly response.
    </p>

    <!--
      Answer-engine search — the input is a trigger that opens the search
      palette (seeded with anything typed); see homepage-hero-client.ts.
      Falls back to submitting the form to the /search page without JS.
    -->
    <div id="hero-search-wrap" class="hero-search-wrap">
      <form class="hero-search" role="search" method="get" action={`${baseUrl}search/`}>
        <span class="hero-search-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
        </span>
        <label for="hero-q" class="sr-only">Search allegations and refutations</label>
        <input
          id="hero-q"
          name="q"
          type="search"
          autocomplete="off"
          placeholder="Did Islam spread by the sword?"
        />
        <button type="submit" class="hero-search-go">Find the answer</button>
      </form>
    </div>

    <!-- Live stats — count up on load -->
    <div class="hero-stats" role="group" aria-label={`${postCount} articles across ${categoryCount} topics`}>
      <div class="hero-stat">
        <span class="hero-stat-n" data-count={postCount}>{postCount}</span>
        <span class="hero-stat-l">Articles</span>
      </div>
      <div class="hero-stat">
        <span class="hero-stat-n" data-count={categoryCount}>{categoryCount}</span>
        <span class="hero-stat-l">Topics covered</span>
      </div>
      {totalWords > 0 && (
        <div class="hero-stat">
          <span class="hero-stat-n" data-count={totalWords} data-format="compact">{totalWords}</span>
          <span class="hero-stat-l">Words of research</span>
        </div>
      )}
    </div>

    <a href={`${baseUrl}posts/`} class="hero-browse">or browse all {postCount} articles →</a>

  </div>

  <!-- Scroll hint -->
  <div class="hero-scroll-hint" aria-hidden="true">↓</div>

</section>


<style>
  /* ── Section — full initial viewport, full-bleed, extends behind navbar ── */
  .hero-section {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow-x: clip;
    margin-top: -3.5rem;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: calc(3.5rem + 4rem) 2rem 3rem;
    background-color: #0D0A05;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-image-overlay {
    position: absolute;
    inset: 0;
    background: #0D0A05;
    z-index: 0;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 46rem;
    margin: 0 auto;
    width: 100%;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0);
    white-space: nowrap; border: 0;
  }

  /* ── Kicker ── */
  .hero-kicker {
    font-family: var(--font-prose, serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgb(var(--color-highlight-300));
    margin: 0 0 1.1rem;
  }

  /* ── Title (mission-as-headline) ── */
  .hero-title {
    font-family: var(--font-heading, serif);
    font-size: clamp(2.1rem, 5.5vw, 3.9rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: rgb(var(--color-primary-50));
    text-shadow: 0 0 60px rgb(var(--color-highlight-500) / 0.25);
    line-height: 1.08;
    margin: 0 0 1.1rem;
    text-wrap: balance;
  }
  .hero-title em {
    font-style: italic;
    font-weight: 500;
    color: rgb(var(--color-highlight-300));
  }

  /* ── Lede ── */
  .hero-lede {
    font-family: var(--font-prose, serif);
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    line-height: 1.75;
    color: rgb(var(--color-primary-200));
    max-width: 40rem;
    margin: 0 auto 2rem;
    text-wrap: pretty;
  }

  /* ── Search ── */
  .hero-search-wrap {
    position: relative;
    max-width: 38rem;
    margin: 0 auto 2.25rem;
    z-index: 5;
  }
  .hero-search {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    padding: 0.2rem 0.3rem 0.2rem 1rem;
    background: rgb(0 0 0 / 0.3);
    border: 1px solid rgb(var(--color-highlight-500) / 0.35);
    border-radius: 0.6rem;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
  }
  .hero-search:focus-within {
    border-color: rgb(var(--color-highlight-400) / 0.9);
    background: rgb(0 0 0 / 0.4);
    box-shadow: 0 0 0 3px rgb(var(--color-highlight-500) / 0.16);
  }
  .hero-search-icon {
    color: rgb(var(--color-highlight-300));
    display: inline-flex;
    flex: none;
  }
  .hero-search input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    color: rgb(var(--color-primary-50));
    font-family: var(--font-prose, serif);
    font-size: clamp(1rem, 2vw, 1.15rem);
    padding: 0.85rem 0;
    outline: none;
    appearance: none;
    -webkit-appearance: none;
  }
  .hero-search input::placeholder {
    color: rgb(var(--color-primary-300) / 0.85);
    font-style: italic;
  }
  /* Strip native type=search chrome — the chevron, the clear ✕, and the
     saved-searches dropdown affordance Chrome paints inside the field. */
  .hero-search input::-webkit-search-decoration,
  .hero-search input::-webkit-search-cancel-button,
  .hero-search input::-webkit-search-results-button,
  .hero-search input::-webkit-search-results-decoration {
    -webkit-appearance: none;
    appearance: none;
    display: none;
  }
  /* Keep Chrome autofill from painting a light box over the dark glass. */
  .hero-search input:-webkit-autofill,
  .hero-search input:-webkit-autofill:hover,
  .hero-search input:-webkit-autofill:focus {
    -webkit-text-fill-color: rgb(var(--color-primary-50));
    caret-color: rgb(var(--color-primary-50));
    transition: background-color 9999s ease-out 0s;
  }
  .hero-search-go {
    flex: none;
    background: rgb(var(--color-highlight-600));
    color: #fff;
    border: 0;
    border-radius: 0.4rem;
    padding: 0.7rem 1.15rem;
    font-family: var(--font-prose, serif);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .hero-search-go:hover { background: rgb(var(--color-highlight-700)); }
  .hero-search-go:active { background: rgb(var(--color-highlight-800)); }

  /* ── Stats (count-up) ── */
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: center;
    gap: 2.25rem;
    margin: 0 auto 1.75rem;
  }
  .hero-stat { text-align: center; }
  .hero-stat-n {
    display: block;
    font-family: var(--font-heading, serif);
    font-size: clamp(1.7rem, 4vw, 2.3rem);
    font-weight: 600;
    line-height: 1;
    color: rgb(var(--color-highlight-300));
    font-variant-numeric: tabular-nums;
  }
  .hero-stat-l {
    display: block;
    font-family: var(--font-prose, serif);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--color-primary-300));
    margin-top: 0.4rem;
  }

  /* ── Browse fallback link ── */
  .hero-browse {
    font-family: var(--font-prose, serif);
    font-size: 0.9rem;
    color: rgb(var(--color-primary-300));
    text-decoration: none;
    border-bottom: 1px dotted rgb(var(--color-highlight-500) / 0.5);
    padding-bottom: 1px;
    transition: color 0.15s, border-color 0.15s;
  }
  .hero-browse:hover {
    color: rgb(var(--color-highlight-300));
    border-bottom-color: rgb(var(--color-highlight-400));
  }

  /* ── Scroll hint ── */
  .hero-scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: rgb(var(--color-highlight-500) / 0.5);
    font-size: 1rem;
    animation: bounce 2s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(6px); }
  }

  @media (max-width: 480px) {
    .hero-section { padding: calc(3.5rem + 3rem) 1rem 2rem; }
    .hero-search { flex-wrap: wrap; padding: 0.5rem; gap: 0.5rem; }
    .hero-search input { flex-basis: 100%; padding: 0.5rem 0.25rem; }
    .hero-search-go { width: 100%; }
    .hero-stats { gap: 1.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-scroll-hint { animation: none; }
  }
</style>

<!-- Behaviour lives in /src/scripts/homepage-hero-client.ts, loaded globally from
     BaseLayout. A component-inline script only ships with pages that render the
     component, so it never runs when this page is reached via Swup nav from a
     page without it (Swup doesn't execute the fetched page's scripts). -->
