---
import type { CollectionEntry } from 'astro:content';
import { formatDate, formatDateMobile, processMarkdown, calculateReadingTime, getReadingTimeMobile } from '../utils/markdown';
import { siteConfig, getPostCardAspectRatio } from '../config';
import { getOptimizedFormat } from '@/utils/images';
import { getTagTitleMap, tagTitle } from '@/utils/tag-titles';
import ImageWrapper from './ImageWrapper.astro';
import Icon from '@/components/Icon.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  featured?: boolean;
  eager?: boolean;
  context?: 'featured' | 'recent' | 'posts' | 'tags';
}

const { post, featured = false, eager = false, context = 'posts' } = Astro.props;

const { excerpt, wordCount } = processMarkdown(post.body || '');
const readingTime = calculateReadingTime(post.body || '');
const { title, description, date, tags, image: rawImage, imageAlt, category } = post.data as any;

const image = (() => {
  if (!rawImage) return rawImage;
  let v = Array.isArray(rawImage) ? rawImage[0] : rawImage;
  if (typeof v !== 'string') return v;
  if (v.startsWith('[[') && v.endsWith(']]')) return v.slice(2, -2);
  return v;
})();

const shouldShowCoverImage = (() => {
  if (!image) return false;
  const s = siteConfig.postOptions.showPostCardCoverImages;
  switch (s) {
    case 'all': return true;
    case 'featured': return context === 'featured' || featured;
    case 'home': return context === 'featured' || context === 'recent';
    case 'posts': return context === 'posts' || context === 'tags';
    case 'featured-and-posts': return context === 'featured' || context === 'posts' || context === 'tags' || featured;
    default: return false;
  }
})();

const postUrl = `${import.meta.env.BASE_URL}posts/${post.id}/`;
const tagTitles = await getTagTitleMap();
---

<!--
  Card link pattern: title <a> has ::before overlay covering the whole card.
  Category + tag <a> elements sit above it via z-index.
  This avoids invalid nested <a> HTML and makes the ENTIRE card clickable.
-->
<article class={`group ${featured ? 'featured-post' : 'post-card'}`} role="article" aria-labelledby={`post-title-${post.id}`}>

  {/* ── Top: image or same-height placeholder ── */}
  {image && shouldShowCoverImage ? (
    <div class="overflow-hidden rounded-t-lg bg-primary-100 dark:bg-primary-800" style={`aspect-ratio: ${getPostCardAspectRatio()};`}>
      <ImageWrapper
        src={(() => {
          let p = image;
          if (!p || typeof p !== 'string') return '';
          if (p.startsWith('[[') && p.endsWith(']]')) p = p.slice(2, -2);
          if (p.startsWith('http')) return p;
          const fileBased = p.startsWith('attachments/');
          if (fileBased) p = p.replace('attachments/', '');
          else if (p.startsWith('images/') || p.startsWith('attachments/')) p = p.replace(/^(images|attachments)\//, '');
          return getOptimizedFormat(p);
        })()}
        basePath={(() => {
          if (typeof image === 'string' && image.startsWith('http')) return '';
          let p = image;
          if (typeof p === 'string' && p.startsWith('[[') && p.endsWith(']]')) p = p.slice(2, -2);
          if (typeof p === 'string' && p.startsWith('attachments/')) return '/posts/attachments/';
          if (post.id) return `/posts/${post.id}/`;
          return '/posts/attachments/';
        })()}
        alt={imageAlt || `Featured image for post: ${title}`}
        class="w-full h-full group-hover:scale-102 transition-all duration-300"
        width={800} height={450} format="webp" quality={85}
        loading={featured || eager ? 'eager' : 'lazy'}
        fetchpriority={featured || eager ? 'high' : 'auto'}
      />
    </div>
  ) : null}

  {/* ── Card body ── */}
  <div class={`p-4 ${image && shouldShowCoverImage ? 'rounded-b-lg' : 'rounded-lg'}`}>

    {/* Category — own line, right-aligned, above title */}
    {category && siteConfig.postOptions.categories && (
      <div class="mb-1 relative z-10">
        <a
          href={`${import.meta.env.BASE_URL}posts/category/${encodeURIComponent(category)}/`}
          class="text-[0.7rem] font-bold tracking-[0.14em] uppercase text-highlight-600 dark:text-highlight-400 hover:text-highlight-700 dark:hover:text-highlight-300 transition-colors"
          aria-label={`View posts in ${category}`}
        >
          {category}
        </a>
      </div>
    )}

    {/* Title */}
    <h3
      id={`post-title-${post.id}`}
      class={`font-medium leading-snug mb-2 ${featured ? 'text-xl' : 'text-lg'}`}
    >
      <a href={postUrl} class="card-link text-primary-900 dark:text-primary-100 group-hover:text-highlight-600 dark:group-hover:text-highlight-400 transition-colors">
        {title}
      </a>
    </h3>

    {/* Description — featured card + listing pages (category / tag) */}
    {description && (featured || context === 'posts' || context === 'tags') && (
      <p class={`text-primary-600 dark:text-primary-300 line-clamp-2 leading-relaxed mb-2 ${featured ? 'text-base' : 'text-sm'}`}>
        {description}
      </p>
    )}

    {/* Meta row */}
    <div class="flex flex-wrap items-center gap-x-2.5 gap-y-1 text-sm text-primary-400 dark:text-primary-500">
      <time datetime={date.toISOString()}>
        <span class="hidden sm:inline">{formatDate(date)}</span>
        <span class="sm:hidden">{formatDateMobile(date)}</span>
      </time>
      {siteConfig.postOptions.readingTime && readingTime && (
        <>
          <span aria-hidden="true">·</span>
          <span>
            <span class="hidden sm:inline">{readingTime.text && readingTime.text !== 'read0' && readingTime.text !== '' ? readingTime.text : '1 min read'}</span>
            <span class="sm:hidden">{getReadingTimeMobile(readingTime)}</span>
          </span>
        </>
      )}
      {siteConfig.postOptions.wordCount && wordCount !== undefined && (
        <>
          <span aria-hidden="true">·</span>
          <span>
            <span class="hidden sm:inline">{wordCount === 1 ? '1 word' : `${wordCount} words`}</span>
            <span class="sm:hidden">{wordCount === 1 ? '1 word' : `${wordCount.toLocaleString()} words`}</span>
          </span>
        </>
      )}
    </div>

    {/* Tags — bottom left, z-10 above card overlay */}
    {tags && tags.length > 0 && siteConfig.postOptions.tags && (
      <div class="mt-2 flex flex-wrap gap-1.5 relative z-10">
        {tags.slice(0, 3).map((tag: string) => (
          <a
            href={`${import.meta.env.BASE_URL}posts/tag/${encodeURIComponent(tag)}/`}
            class="tag-chip"
            aria-label={`View posts tagged with ${tagTitle(tagTitles, tag)}`}
          >
            <Icon name="tag" class="w-2.5 h-2.5 opacity-70" />
            {tagTitle(tagTitles, tag)}
          </a>
        ))}
        {tags.length > 3 && (
          <span class="inline-flex items-center text-[0.8rem] text-highlight-500 dark:text-highlight-400 px-2 py-0.5 rounded-md border border-highlight-400/25 dark:border-highlight-600/30">
            +{tags.length - 3}
          </span>
        )}
      </div>
    )}

  </div>
</article>

<style>
  /* ── Card link overlay pattern ──────────────────────────────────────────────
     .card-link::before covers the entire article so clicking anywhere
     on the card (except category/tag links) navigates to the post.
     Category + tag wrappers have z-10 to sit above this overlay.         */
  :global(.post-card),
  :global(.featured-post) {
    position: relative;
  }
  .card-link::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
  }
</style>
