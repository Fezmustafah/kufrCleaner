---
/**
 * Breadcrumbs component
 * Renders: Posts > [path segments] > Title
 * - If frontmatter `category` exists, uses that as a linked crumb
 * - If post ID contains `/`, parses path segments as unlinked crumbs
 * - Mobile: hides middle crumbs, shows only first and last
 */
import Icon from '@/components/Icon.astro';

interface Props {
  postId: string;
  title: string;
  category?: string;
  class?: string;
}

const { postId, title, category, class: className = '' } = Astro.props;

type Crumb = { label: string; href?: string };

const crumbs: Crumb[] = [{ label: 'Posts', href: '/posts' }];

if (category) {
  crumbs.push({
    label: category,
    href: `/posts/category/${encodeURIComponent(category)}`,
  });
} else {
  // Parse path segments from post ID (e.g. "thoughts/philosophy/post" → ["thoughts","philosophy"])
  const segments = postId.split('/').slice(0, -1); // drop final segment (it's the post itself)
  for (let i = 0; i < segments.length; i++) {
    const seg = segments[i];
    const label = seg
      .replace(/-/g, ' ')
      .replace(/\b\w/g, (c) => c.toUpperCase());
    const href = '/posts/' + segments.slice(0, i + 1).join('/');
    crumbs.push({ label, href });
  }
}

crumbs.push({ label: title }); // current page, no href
---

<nav
  class:list={['breadcrumbs flex items-center flex-wrap gap-1 text-sm', className]}
  aria-label="Breadcrumb"
>
  {crumbs.map((crumb, i) => {
    const isLast = i === crumbs.length - 1;
    const isMiddle = i > 0 && !isLast;
    return (
      <>
        {i > 0 && (
          <Icon
            name="chevron-right"
            class:list={[
              'w-3 h-3 shrink-0 text-primary-300 dark:text-primary-600',
              isMiddle && 'breadcrumbs-middle-sep',
            ]}
          />
        )}
        {isLast ? (
          <span
            class="text-primary-700 dark:text-primary-200 font-medium truncate max-w-[14rem] sm:max-w-xs"
            aria-current="page"
          >
            {crumb.label}
          </span>
        ) : crumb.href ? (
          <a
            href={crumb.href}
            class:list={[
              'text-primary-500 dark:text-primary-400 hover:text-highlight-600 dark:hover:text-highlight-400 transition-colors shrink-0',
              isMiddle && 'breadcrumbs-middle',
            ]}
          >
            {crumb.label}
          </a>
        ) : (
          <span
            class:list={[
              'text-primary-500 dark:text-primary-400 shrink-0',
              isMiddle && 'breadcrumbs-middle',
            ]}
          >
            {crumb.label}
          </span>
        )}
      </>
    );
  })}
</nav>

<style>
  /* Hide middle crumbs on small screens */
  @media (max-width: 480px) {
    .breadcrumbs-middle,
    .breadcrumbs-middle-sep {
      display: none;
    }
  }
</style>
