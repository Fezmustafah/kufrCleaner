---
/**
 * MarginaliaDesktop — vanilla JS desktop margin column
 * Replaces ametrine's React MarginaliaManager with a pure Astro + script approach.
 * Only the column shell is server-rendered; JS handles absolute positioning of each note.
 * Re-initializes on Swup's page:view event for seamless transitions.
 */
import type { MarginaliaEntry } from '../utils/remark-marginalia';

interface Props {
  marginalia: MarginaliaEntry[];
}

const { marginalia = [] } = Astro.props;

if (!marginalia || marginalia.length === 0) return null;
---

<div id="marginalia-column" class="marginalia-column-js" aria-label="Margin notes">
  {marginalia.map((note) => (
    <div
      class="marginalia-note"
      data-note-id={String(note.id)}
      style="top: 0px; opacity: 0;"
    >
      <span class="marginalia-note-num">{note.id}.</span>
      <span class="marginalia-note-text" set:html={note.html} />
    </div>
  ))}
</div>

<script>
  // ── Constants ────────────────────────────────────────────────────────────
  const NOTE_GAP = 8;                   // px gap between stacked notes
  const ESTIMATED_LINE_HEIGHT = 20;     // px per line (estimate for unseen notes)
  const ESTIMATED_CHARS_PER_LINE = 50;  // chars per line in the 240px column
  const BASE_PADDING = 16;              // vertical padding per note (estimate)
  const RENDER_DELAY = 100;             // ms before first position calculation

  // ── Position calculation ─────────────────────────────────────────────────
  function calculatePositions(): void {
    const column = document.getElementById('marginalia-column');
    if (!column) return;

    const markers = document.querySelectorAll<HTMLElement>('.marginalia-marker');
    if (markers.length === 0) return;

    let lastBottom = 0;

    markers.forEach((marker) => {
      const rect = marker.getBoundingClientRect();
      const article = marker.closest('article');
      if (!article) return;

      const articleRect = article.getBoundingClientRect();
      const relativeTop = rect.top - articleRect.top;

      const id = marker.getAttribute('data-marginalia-id');
      if (!id) return;

      const noteEl = column.querySelector<HTMLElement>(`[data-note-id="${id}"]`);
      if (!noteEl) return;

      // Prevent overlap with the previous note
      let top = relativeTop;
      if (top < lastBottom + NOTE_GAP) {
        top = lastBottom + NOTE_GAP;
      }

      noteEl.style.top = `${top}px`;
      noteEl.style.opacity = '1';

      // Use the rendered height once the note is visible; estimate otherwise
      const renderedHeight = noteEl.getBoundingClientRect().height;
      const actualHeight = renderedHeight > 0
        ? renderedHeight
        : Math.ceil(noteEl.textContent!.length / ESTIMATED_CHARS_PER_LINE)
            * ESTIMATED_LINE_HEIGHT + BASE_PADDING;

      lastBottom = top + actualHeight;
    });
  }

  // ── Bidirectional hover highlighting ─────────────────────────────────────
  function attachHoverListeners(): void {
    const column = document.getElementById('marginalia-column');
    if (!column) return;

    // Note → marker highlight
    column.querySelectorAll<HTMLElement>('.marginalia-note').forEach((noteEl) => {
      const id = noteEl.getAttribute('data-note-id');

      noteEl.addEventListener('mouseenter', () => {
        const ref = document.querySelector(
          `.marginalia-marker[data-marginalia-id="${id}"] .marginalia-ref`,
        );
        ref?.classList.add('highlight');
      });

      noteEl.addEventListener('mouseleave', () => {
        const ref = document.querySelector(
          `.marginalia-marker[data-marginalia-id="${id}"] .marginalia-ref`,
        );
        ref?.classList.remove('highlight');
      });
    });

    // Marker → note highlight
    document.querySelectorAll<HTMLElement>('.marginalia-marker').forEach((markerEl) => {
      const id = markerEl.getAttribute('data-marginalia-id');
      const ref = markerEl.querySelector('.marginalia-ref');

      ref?.addEventListener('mouseenter', () => {
        const noteNum = document.querySelector(
          `.marginalia-note[data-note-id="${id}"] .marginalia-note-num`,
        );
        noteNum?.classList.add('highlight');
      });

      ref?.addEventListener('mouseleave', () => {
        const noteNum = document.querySelector(
          `.marginalia-note[data-note-id="${id}"] .marginalia-note-num`,
        );
        noteNum?.classList.remove('highlight');
      });
    });
  }

  // ── Image-aware initial calculation ──────────────────────────────────────
  function waitForImages(): void {
    const column = document.getElementById('marginalia-column');
    if (!column) return;

    const images = column.querySelectorAll<HTMLImageElement>('img');
    if (images.length === 0) {
      calculatePositions();
      return;
    }

    let loaded = 0;
    const total = images.length;

    const onLoad = () => {
      loaded += 1;
      if (loaded === total) calculatePositions();
    };

    images.forEach((img) => {
      if (img.complete) {
        onLoad();
      } else {
        img.addEventListener('load', onLoad);
        img.addEventListener('error', onLoad); // count errors so we don't block
      }
    });
  }

  // ── ResizeObserver with debounce ─────────────────────────────────────────
  let resizeObserver: ResizeObserver | null = null;
  let debounceTimer: ReturnType<typeof setTimeout> | null = null;

  function observeResize(): void {
    resizeObserver?.disconnect();

    const column = document.getElementById('marginalia-column');
    const article = document.querySelector('article');
    if (!column) return;

    resizeObserver = new ResizeObserver(() => {
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(calculatePositions, 150);
    });

    if (article) resizeObserver.observe(article);
    resizeObserver.observe(column);
  }

  // ── Main init ─────────────────────────────────────────────────────────────
  function initMarginalia(): void {
    attachHoverListeners();
    observeResize();
    setTimeout(waitForImages, RENDER_DELAY);
  }

  // Initial load
  document.addEventListener('DOMContentLoaded', initMarginalia);

  // Swup page transitions — re-initialize after every navigation
  document.addEventListener('page:view', initMarginalia);
</script>
