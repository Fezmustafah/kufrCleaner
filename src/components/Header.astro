---
import { siteConfig } from '../config';
import Icon from './Icon.astro';
import NavDrawer from './widget/NavDrawer.astro';

interface NavLink {
  name: string;
  url: string;
  external?: boolean;
}

const base = import.meta.env.BASE_URL;
const withBase = (u: string) => (u.startsWith('http') ? u : `${base}${u.replace(/^\//, '')}`);

const links: NavLink[] = siteConfig.navigation.pages
  .filter((p: any) => p.url && p.url.trim() !== '' && !p.url.replace(/\/?$/, '/').endsWith('/search/'))
  .map((p: any) => ({
    name: p.title,
    url: withBase(p.url),
    external: p.url.startsWith('http'),
  }));

const searchUrl = withBase('search/');
---

<!--
  Wiki chrome: no bar background at all — just the logo (left) and a cluster of
  glass action buttons (right). Nav links live behind the hamburger on every
  viewport (NavDrawer). Legibility over content comes from the buttons' own
  backdrop-blur glass, not a full-width bar.
-->
<div id="top-row" class="h-14 z-50 pointer-events-none relative">
  <div id="navbar-wrapper" class="pointer-events-auto fixed top-0 inset-x-0 z-50 h-14 nav-at-top">

    <div id="navbar" class="onload-animation h-full">
      <div class="relative h-full max-w-[var(--page-width)] md:px-4 mx-auto px-4 flex items-center">

        <!-- ── Left: logo/home ─────────────────────────────────────────── -->
        <a href={base} class="nav-home-link shrink-0" aria-label={siteConfig.title}>
          <!-- Theme-adaptive: green wordmark on light header, cream wordmark on dark -->
          <img src={withBase('logo-light.png')} alt={siteConfig.title} class="h-11 w-auto shrink-0 block dark:hidden" />
          <img src={withBase('logo.png')} alt="" aria-hidden="true" class="h-11 w-auto shrink-0 hidden dark:block" />
        </a>

        <!-- ── Center: empty — nav links live behind the hamburger ────── -->
        <div class="flex-1"></div>

        <!-- ── Right: actions (circular glass) — just search + menu; graph and
             appearance live in the drawer ── -->
        <div class="flex items-center gap-1.5 shrink-0">
          <!-- Toggles the search palette only — the /search page is reachable
               via the drawer's "Advanced search" link -->
          <button type="button" aria-label="Search" class="nav-glass-btn" id="nav-search-btn">
            <Icon name="search" class="w-4 h-4" />
          </button>

          <!-- Hamburger — all viewports; opens the nav drawer -->
          <button
            aria-label="Menu"
            aria-expanded="false"
            aria-controls="nav-drawer"
            class="nav-glass-btn"
            id="nav-menu-switch"
          >
            <Icon name="menu" class="w-4 h-4 nav-menu-icon-open" />
            <Icon name="x" class="w-4 h-4 nav-menu-icon-close" />
          </button>
        </div>

      </div>
    </div>
  </div>

</div>

<!-- Keep the fixed drawer outside #top-row as well as #navbar-wrapper. Both
     elements establish stacking contexts below the reading deck; placing the
     drawer here lets its own z-index correctly layer it above deck mode. -->
<NavDrawer links={links} />

<script>
// The Header persists across Swup navigations; guard its one-time bindings below.
let navBound = false;
function loadNavScript() {
  const wrapper = document.getElementById('navbar-wrapper');

  // nav-at-top gates the dark-hero tint only (homepage): past this the hero is
  // gone and the action buttons revert to their normal light-glass palette.
  const T_TOP = 90;

  // Auto-hide: slide the navbar away while reading down, bring it back on any
  // scroll-up and always near the top. HIDE_AFTER keeps it visible through the
  // transparent→frosted crossfade; the ±4px deadband absorbs trackpad jitter.
  // (.navbar-hidden uses a transform — safe ONLY because #navbar-wrapper has no
  // position:fixed descendants; the graph modal overlay is a sibling.)
  const HIDE_AFTER = 160;
  let lastY = Math.max(0, document.documentElement.scrollTop || document.body.scrollTop);

  function updateNav() {
    if (!wrapper) return;
    const scrollY = document.documentElement.scrollTop || document.body.scrollTop;

    wrapper.classList.toggle('nav-at-top', scrollY < T_TOP);

    // Auto-hide (clamp: macOS rubber-band overscroll reports out-of-range values)
    const y = Math.max(0, scrollY);
    const menuOpen = document.getElementById('nav-drawer')?.classList.contains('is-open');
    if (y < HIDE_AFTER || menuOpen) {
      wrapper.classList.remove('navbar-hidden');
    } else if (y > lastY + 4) {
      wrapper.classList.add('navbar-hidden');
    } else if (y < lastY - 4) {
      wrapper.classList.remove('navbar-hidden');
    }
    lastY = y;
  }

  // rAF-throttle the scroll handler so we touch layout at most once per frame
  // (reading scrollTop + writing styles on every raw scroll event causes jank).
  let navTicking = false;
  function onNavScroll() {
    if (navTicking) return;
    navTicking = true;
    requestAnimationFrame(() => { updateNav(); navTicking = false; });
  }

  // Tear down previous listener (Swup navigations)
  const prev = (window as any)._navbarScroll;
  if (prev) window.removeEventListener('scroll', prev, false);
  (window as any)._navbarScroll = onNavScroll;
  window.addEventListener('scroll', onNavScroll, { passive: true });

  // Detect dark hero on this page — only homepage has .hero-section
  // When present, outer nav items get white text while transparent
  if (document.querySelector('.hero-section')) {
    wrapper?.classList.add('has-dark-hero');
  } else {
    wrapper?.classList.remove('has-dark-hero');
  }

  // The wrapper persists across Swup navigations — always land on a new page
  // with the navbar shown (back-nav can restore a deep scroll position where
  // no scroll-up event would ever reveal it).
  wrapper?.classList.remove('navbar-hidden');
  updateNav();

  // Mark the drawer link matching this page (re-run per navigation)
  const path = location.pathname.replace(/\/+$/, '') || '/';
  document.querySelectorAll<HTMLAnchorElement>('#nav-drawer a.nd-item').forEach(a => {
    const linkPath = new URL(a.href, location.origin).pathname.replace(/\/+$/, '') || '/';
    if (linkPath === path) a.setAttribute('aria-current', 'page');
    else a.removeAttribute('aria-current');
  });

  // Bind persistent-element listeners exactly once. loadNavScript re-runs on every
  // astro:page-load (to refresh the scroll/dark-hero state above), so without this
  // guard each navigation would stack another handler and the mobile menu / feature
  // buttons would cancel themselves out — the "freeze until refresh" bug.
  if (!navBound) {
    navBound = true;

    // ── Nav drawer (all viewports) ─────────────────────────────────────────────
    const drawer = document.getElementById('nav-drawer');
    const scrim = document.getElementById('nav-drawer-scrim');
    const setDrawer = (open: boolean) => {
      drawer?.classList.toggle('is-open', open);
      scrim?.classList.toggle('is-open', open);
      drawer?.setAttribute('aria-hidden', String(!open));
      document.getElementById('nav-menu-switch')?.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open || document.body.classList.contains('reading-deck-open') ? 'hidden' : '';
      if (open) drawer?.focus();
      else {
        // Collapse the palette dropdown so the drawer reopens tidy
        const list = document.getElementById('nd-themes');
        if (list) list.hidden = true;
        document.getElementById('nd-palette-trigger')?.setAttribute('aria-expanded', 'false');
      }
    };
    const drawerIsOpen = () => !!drawer?.classList.contains('is-open');
    (window as any).__setNavDrawer = setDrawer;

    document.getElementById('nav-menu-switch')?.addEventListener('click', () => {
      setDrawer(!drawerIsOpen());
    });
    document.getElementById('nav-drawer-close')?.addEventListener('click', () => setDrawer(false));
    scrim?.addEventListener('click', () => setDrawer(false));
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && drawerIsOpen()) setDrawer(false);
    });
    // Link clicks close it — the drawer persists across Swup navigations,
    // so it would otherwise survive the page swap still open.
    drawer?.addEventListener('click', e => {
      if ((e.target as Element).closest('a')) setDrawer(false);
    });

    // Search — navbar button and drawer row both toggle the search palette
    document.getElementById('nav-search-btn')?.addEventListener('click', () => {
      const sp = (window as any).searchPalette;
      if (sp) sp.toggle();
      else window.location.href = document.getElementById('nd-adv-search')?.getAttribute('href') || '/search/';
    });
    document.getElementById('nd-search')?.addEventListener('click', () => {
      setDrawer(false);
      (window as any).searchPalette?.open();
    });

    // Graph is a plain link to /graph-view/ — the drawer's "any <a> click
    // closes it" handler above covers it, and Swup handles the navigation.

    // ── Appearance (drawer footer) ─────────────────────────────────────────
    // Mode: light / dark / auto. Storage contract matches the site bootstrap:
    // localStorage 'theme' = 'light' | 'dark'; ABSENT = follow the system.
    const applyMode = (mode: string) => {
      const html = document.documentElement;
      const dark = mode === 'dark' ||
        (mode === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches);
      if (mode === 'auto') localStorage.removeItem('theme');
      else localStorage.setItem('theme', mode);
      html.classList.remove('light', 'dark');
      html.classList.add(dark ? 'dark' : 'light');
      window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: dark ? 'dark' : 'light' } }));
    };
    const markAppearance = () => {
      const mode = localStorage.getItem('theme') ?? 'auto';
      document.querySelectorAll<HTMLElement>('#nd-mode .nd-mode-btn').forEach(b =>
        b.setAttribute('aria-checked', String(b.dataset.mode === mode)));
      const theme = document.documentElement.getAttribute('data-theme');
      let activeRow: HTMLElement | null = null;
      document.querySelectorAll<HTMLElement>('#nd-themes .nd-theme').forEach(b => {
        const on = b.dataset.theme === theme;
        b.setAttribute('aria-checked', String(on));
        if (on) activeRow = b;
      });
      // Mirror the active palette onto the dropdown trigger
      if (activeRow) {
        const name = document.getElementById('nd-palette-name');
        const swatch = document.getElementById('nd-palette-swatch');
        const rowSwatch = (activeRow as HTMLElement).querySelector<HTMLElement>('.nd-swatch');
        if (name) name.textContent =
          (activeRow as HTMLElement).querySelector('.nd-theme-name')?.textContent ?? '';
        if (swatch && rowSwatch) swatch.style.cssText = rowSwatch.style.cssText;
      }
    };
    // Palette dropdown open/close
    const paletteTrigger = document.getElementById('nd-palette-trigger');
    const paletteList = document.getElementById('nd-themes');
    const setPaletteList = (open: boolean) => {
      if (!paletteTrigger || !paletteList) return;
      paletteList.hidden = !open;
      paletteTrigger.setAttribute('aria-expanded', String(open));
      if (open) paletteList.querySelector<HTMLElement>('[aria-checked="true"]')
        ?.scrollIntoView({ block: 'nearest' });
    };
    paletteTrigger?.addEventListener('click', () => setPaletteList(!!paletteList?.hidden));
    document.getElementById('nd-mode')?.addEventListener('click', (e) => {
      const btn = (e.target as Element).closest<HTMLElement>('.nd-mode-btn');
      if (!btn?.dataset.mode) return;
      applyMode(btn.dataset.mode);
      markAppearance();
    });
    // In auto mode, follow live system changes
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      if (localStorage.getItem('theme')) return; // explicit choice wins
      const html = document.documentElement;
      html.classList.remove('light', 'dark');
      html.classList.add(e.matches ? 'dark' : 'light');
      window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: e.matches ? 'dark' : 'light' } }));
    });
    document.getElementById('nd-themes')?.addEventListener('click', (e) => {
      const btn = (e.target as Element).closest<HTMLElement>('.nd-theme');
      if (!btn?.dataset.theme) return;
      (window as any).changeTheme?.(btn.dataset.theme);
      markAppearance();
      setPaletteList(false); // selection made — tuck the list away
    });
    window.addEventListener('themechange', markAppearance);
    markAppearance();

    // Platform-correct shortcut hint on the drawer search row
    const kbd = document.getElementById('nd-search-kbd');
    if (kbd && /mac/i.test(navigator.platform)) kbd.textContent = '⌘K';
  }
}

loadNavScript();
document.addEventListener('swup:page:view', loadNavScript);
</script>

<style>
  /* ── Wrapper ── */
  #navbar-wrapper {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  #navbar-wrapper.navbar-hidden {
    opacity: 0;
    transform: translateY(-3.5rem);
    pointer-events: none;
  }

  /* ── Hamburger icon swap (menu ⇄ x, driven by aria-expanded) ── */
  #nav-menu-switch :global(.nav-menu-icon-close) { display: none; }
  #nav-menu-switch[aria-expanded="true"] :global(.nav-menu-icon-close) { display: block; }
  #nav-menu-switch[aria-expanded="true"] :global(.nav-menu-icon-open) { display: none; }

  /* ── Home link — plain text, no bg hover ── */
  .nav-home-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    color: rgb(var(--color-primary-700));
    transition: color 0.15s ease;
    padding: 0.375rem 0.5rem;
  }
  :global(.dark) .nav-home-link { color: rgb(var(--color-primary-200)); }
  .nav-home-link:hover { color: var(--primary); text-decoration: none; }

  /* ── Glass action buttons (top state) ─────────────────────────────────────
     .nav-glass-btn + #theme-toggle share identical glass styling.
     Using both selectors avoids passing class props into sub-components.    */
  :global(.nav-glass-btn),
  :global(#theme-toggle) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    background: rgb(var(--color-primary-50) / 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgb(var(--color-highlight-600) / 0.2);
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.05);
    color: rgb(var(--color-primary-600));
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease,
                box-shadow 0.15s ease, backdrop-filter 0.15s ease, transform 0.1s ease;
    cursor: pointer;
    text-decoration: none;
    flex-shrink: 0;
  }
  :global(.dark .nav-glass-btn),
  :global(.dark #theme-toggle) {
    background: rgb(var(--color-primary-800) / 0.55);
    color: rgb(var(--color-primary-300));
    border-color: rgb(var(--color-highlight-600) / 0.15);
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.15);
  }
  :global(.nav-glass-btn:hover),
  :global(#theme-toggle:hover) {
    color: var(--primary);
    background: rgb(var(--color-primary-50) / 0.9);
    border-color: rgb(var(--color-highlight-500) / 0.35);
    text-decoration: none;
  }
  :global(.dark .nav-glass-btn:hover),
  :global(.dark #theme-toggle:hover) {
    background: rgb(var(--color-primary-800) / 0.9);
  }
  :global(.nav-glass-btn:active),
  :global(#theme-toggle:active) {
    transform: scale(0.9);
  }
  @media (hover: none) and (pointer: coarse) {
    :global(.nav-glass-btn),
    :global(#theme-toggle) {
      width: 2.75rem;
      height: 2.75rem;
    }
  }

  /* ── Dark hero (homepage): white tint for outer items at top ── */
  #navbar-wrapper.nav-at-top.has-dark-hero .nav-home-link {
    color: rgb(var(--color-highlight-300));
  }
  #navbar-wrapper.nav-at-top.has-dark-hero .nav-home-link:hover {
    color: rgb(var(--color-highlight-100));
  }
  #navbar-wrapper.nav-at-top.has-dark-hero :global(.nav-glass-btn),
  #navbar-wrapper.nav-at-top.has-dark-hero :global(#theme-toggle) {
    background: rgb(var(--color-primary-900) / 0.55);
    border-color: rgb(var(--color-highlight-600) / 0.4);
    color: rgb(var(--color-highlight-300));
    box-shadow: 0 2px 12px rgb(var(--color-highlight-900) / 0.15);
  }
  #navbar-wrapper.nav-at-top.has-dark-hero :global(.nav-glass-btn:hover),
  #navbar-wrapper.nav-at-top.has-dark-hero :global(#theme-toggle:hover) {
    background: rgb(var(--color-primary-800) / 0.7);
    border-color: rgb(var(--color-highlight-500) / 0.6);
    color: rgb(var(--color-highlight-100));
  }
</style>
