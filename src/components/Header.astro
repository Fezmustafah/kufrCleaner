---
import { siteConfig } from '../config';
import ThemeToggle from './ThemeToggle.astro';
import Icon from './Icon.astro';
import NavMenuPanel from './widget/NavMenuPanel.astro';

interface NavLink {
  name: string;
  url: string;
  external?: boolean;
}

const base = import.meta.env.BASE_URL;
const withBase = (u: string) => (u.startsWith('http') ? u : `${base}${u.replace(/^\//, '')}`);

const links: NavLink[] = siteConfig.navigation.pages
  .filter((p: any) => p.url && p.url.trim() !== '' && !p.url.replace(/\/?$/, '/').endsWith('/search/'))
  .map((p: any) => ({
    name: p.title,
    url: withBase(p.url),
    external: p.url.startsWith('http'),
  }));

const searchUrl = withBase('search/');

const hasShortcut = siteConfig.commandPalette.shortcut && siteConfig.commandPalette.shortcut.trim();
const shortcutKey = hasShortcut
  ? siteConfig.commandPalette.shortcut.split('+').pop()?.toUpperCase() || 'K'
  : '';
const allSectionsDisabled =
  !siteConfig.commandPalette.sections.quickActions &&
  !siteConfig.commandPalette.sections.pages &&
  !siteConfig.commandPalette.sections.social;
const paletteIcon = allSectionsDisabled ? 'search' : 'command';
---

<!--
  Layout mirrors astro-obsidian:
    [logo/home]  [nav-pill (center)]  [actions]

  Two layered backgrounds:
  1. #navbar-bg  — full-width frosted, opacity 0→1 as user scrolls (palette vars)
  2. #nav-pill   — floating rounded-full behind center links, visible at top,
                   fades once #navbar-bg takes over
-->
<div id="top-row" class="h-14 z-50 pointer-events-none relative">
  <div id="navbar-wrapper" class="pointer-events-auto fixed top-0 inset-x-0 z-50 h-14 nav-at-top">

    <!-- Full-width frosted bg (scroll state) -->
    <div id="navbar-bg" aria-hidden="true"></div>

    <div id="navbar" class="onload-animation h-full">
      <div class="relative h-full max-w-[var(--page-width)] md:px-4 mx-auto px-4 flex items-center">

        <!-- ── Left: logo/home ─────────────────────────────────────────── -->
        <a href={base} class="nav-home-link shrink-0" aria-label="Home">
          <Icon name="home" class="w-4 h-4" />
          <span>{siteConfig.title}</span>
        </a>

        <!-- ── Center: nav pill ───────────────────────────────────────── -->
        <div class="flex-1 flex justify-center">

          <!-- Desktop pill -->
          <nav id="nav-pill" class="relative hidden md:flex rounded-full group" aria-label="Main navigation">
            <!-- Radial gradient hover glow (mirrors astro-obsidian's mouse-follow effect) -->
            <div id="nav-pill-glow" class="absolute -inset-px rounded-full opacity-0 pointer-events-none transition-opacity duration-500" aria-hidden="true"></div>

            <div class="relative text-base px-4 flex items-center">
              {links.map(l => (
                <a
                  href={l.url}
                  target={l.external ? '_blank' : undefined}
                  aria-label={l.name}
                  class="nav-link block px-4 py-1.5 transition-colors duration-150"
                >
                  <span class="flex items-center gap-1.5">
                    {l.name}
                    {l.external && (
                      <Icon name="external-link" class="w-3 h-3 opacity-40" />
                    )}
                  </span>
                </a>
              ))}
            </div>
          </nav>

          <!-- Mobile: spacer so actions stay right-aligned -->
          <div class="md:hidden flex-1"></div>
        </div>

        <!-- ── Right: actions (circular glass, mirrors astro-obsidian SearchButton) ── -->
        <div class="flex items-center gap-1.5 shrink-0">
          <a href={searchUrl} aria-label="Search" class="nav-glass-btn">
            <Icon name="search" class="w-4 h-4" />
          </a>

          {siteConfig.featureButton === 'mode' && <ThemeToggle />}

          {siteConfig.featureButton === 'graph' && siteConfig.postOptions.graphView.enabled && (
            <button id="header-graph-button" class="nav-glass-btn" aria-label="Open graph view">
              <Icon name="git-fork" class="w-4 h-4" />
            </button>
          )}

          {siteConfig.featureButton === 'theme' && (
            <button id="header-theme-button" class="nav-glass-btn" aria-label="Change theme">
              <Icon name="palette" class="w-4 h-4" />
            </button>
          )}

          {siteConfig.commandPalette.enabled && (
            <button
              id="command-palette-trigger"
              class="nav-glass-btn"
              aria-label={`Open command palette${hasShortcut ? ` (${shortcutKey})` : ''}`}
            >
              <Icon name={paletteIcon} class="w-4 h-4" />
            </button>
          )}

          <!-- Mobile hamburger -->
          <button aria-label="Menu" class="nav-glass-btn md:!hidden" id="nav-menu-switch">
            <Icon name="menu" class="w-4 h-4" />
          </button>
        </div>

        <!-- Mobile dropdown panel -->
        <NavMenuPanel links={links} />

      </div>
    </div>
  </div>
</div>

<script>
function loadNavScript() {
  const wrapper = document.getElementById('navbar-wrapper');
  const bg      = document.getElementById('navbar-bg');
  const pill    = document.getElementById('nav-pill');
  const glow    = document.getElementById('nav-pill-glow');

  // ── Scroll: transparent → frosted ─────────────────────────────────────────
  // Matches astro-obsidian thresholds: 0–60px = transparent, 60–120px = crossfade
  const T1 = 60;   // start fading full-width bg
  const T2 = 120;  // fully opaque

  function updateNav() {
    if (!bg || !wrapper) return;
    const scrollY = document.documentElement.scrollTop || document.body.scrollTop;

    // Full-width frosted bg opacity: 0 below T1, linear 0→1 between T1–T2
    const bgOpacity = scrollY <= T1 ? 0 : Math.min(1, (scrollY - T1) / (T2 - T1));
    bg.style.opacity = String(bgOpacity);

    // nav-at-top: pill visible, outer items adapt to dark hero
    // Removed when bg is dominant (>50% opaque)
    if (bgOpacity < 0.5) {
      wrapper.classList.add('nav-at-top');
    } else {
      wrapper.classList.remove('nav-at-top');
    }
  }

  // Tear down previous listener (Swup navigations)
  const prev = (window as any)._navbarScroll;
  if (prev) window.removeEventListener('scroll', prev, false);
  (window as any)._navbarScroll = updateNav;
  window.addEventListener('scroll', updateNav, { passive: true });

  // Detect dark hero on this page — only homepage has .hero-section
  // When present, outer nav items get white text while transparent
  if (document.querySelector('.hero-section')) {
    wrapper?.classList.add('has-dark-hero');
  } else {
    wrapper?.classList.remove('has-dark-hero');
  }

  updateNav();

  // ── Radial gradient hover on nav pill (astro-obsidian mouse-follow effect) ──
  if (pill && glow) {
    pill.addEventListener('mousemove', (e: MouseEvent) => {
      const b = pill.getBoundingClientRect();
      const x = e.clientX - b.left;
      const y = e.clientY - b.top;
      const r = Math.sqrt(b.width ** 2 + b.height ** 2) / 2.5;
      (glow as HTMLElement).style.background =
        `radial-gradient(${r}px circle at ${x}px ${y}px, rgb(var(--color-highlight-500) / 0.15) 0%, transparent 65%)`;
      (glow as HTMLElement).style.opacity = '1';
    });
    pill.addEventListener('mouseleave', () => {
      (glow as HTMLElement).style.opacity = '0';
    });
  }

  // ── Mobile menu ────────────────────────────────────────────────────────────
  document.getElementById('nav-menu-switch')?.addEventListener('click', () => {
    document.getElementById('nav-menu-panel')?.classList.toggle('float-panel-closed');
  });
  document.addEventListener('click', e => {
    const panel = document.getElementById('nav-menu-panel');
    if (panel && !panel.classList.contains('float-panel-closed')) {
      if (!(e.target as Element).closest('#nav-menu-switch, #nav-menu-panel'))
        panel.classList.add('float-panel-closed');
    }
  });

  // ── Feature buttons ────────────────────────────────────────────────────────
  document.getElementById('header-graph-button')?.addEventListener('click', () => {
    if ((window as any).openGraphModal) (window as any).openGraphModal();
  });
  document.getElementById('header-theme-button')?.addEventListener('click', () => {
    if ((window as any).siteConfig?.commandPalette?.enabled)
      window.dispatchEvent(new CustomEvent('openCommandPalette'));
    else
      (window as any).themeSelectorInstance?.open?.();
  });
  document.getElementById('command-palette-trigger')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('openCommandPalette'));
  });
}

loadNavScript();
document.addEventListener('swup:page:view', loadNavScript);
</script>

<style>
  /* ── Wrapper ── */
  #navbar-wrapper {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  #navbar-wrapper.navbar-hidden {
    opacity: 0;
    transform: translateY(-3.5rem);
    pointer-events: none;
  }

  /* ── Full-width frosted bg (scroll state) ── */
  #navbar-bg {
    position: absolute;
    inset: 0;
    background: var(--card-bg);
    backdrop-filter: blur(16px) saturate(150%);
    -webkit-backdrop-filter: blur(16px) saturate(150%);
    border-bottom: 1px solid rgb(var(--color-highlight-600) / 0.15);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Nav pill ── */
  /* Light mode: amber gold (matches "Browse the Library" button) */
  #nav-pill {
    background: rgb(var(--color-highlight-600) / 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgb(var(--color-highlight-400) / 0.4);
    box-shadow: 0 4px 20px rgb(var(--color-highlight-900) / 0.2);
    transition: background 0.25s ease, box-shadow 0.25s ease,
                border-color 0.25s ease, backdrop-filter 0.25s ease;
  }
  :global(.dark) #nav-pill {
    background: rgb(var(--color-primary-800) / 0.92);
    border-color: rgb(var(--color-highlight-600) / 0.2);
    box-shadow: 0 4px 20px rgb(0 0 0 / 0.25);
  }
  /* Shed glass when full-width header bg takes over */
  #navbar-wrapper:not(.nav-at-top) #nav-pill {
    background: transparent;
    border-color: transparent;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  /* ── Nav link colours ── */
  /* On amber pill (light mode at top): light text */
  .nav-link { color: rgb(var(--color-primary-50)); }
  :global(.dark) .nav-link { color: rgb(var(--color-primary-100)); }
  .nav-link:hover { color: rgb(255 255 255); }
  /* When scrolled (transparent pill, frosted header): use dark text in light mode */
  #navbar-wrapper:not(.nav-at-top) .nav-link { color: rgb(var(--color-primary-900)); }
  :global(.dark) #navbar-wrapper:not(.nav-at-top) .nav-link { color: rgb(var(--color-primary-100)); }
  #navbar-wrapper:not(.nav-at-top) .nav-link:hover { color: var(--primary); }

  /* ── Home link — plain text, no bg hover ── */
  .nav-home-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    color: rgb(var(--color-primary-700));
    transition: color 0.15s ease;
    padding: 0.375rem 0.5rem;
  }
  :global(.dark) .nav-home-link { color: rgb(var(--color-primary-200)); }
  .nav-home-link:hover { color: var(--primary); text-decoration: none; }

  /* ── Glass action buttons (top state) ─────────────────────────────────────
     .nav-glass-btn + #theme-toggle share identical glass styling.
     Using both selectors avoids passing class props into sub-components.    */
  :global(.nav-glass-btn),
  :global(#theme-toggle) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    background: rgb(var(--color-primary-50) / 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgb(var(--color-highlight-600) / 0.2);
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.05);
    color: rgb(var(--color-primary-600));
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease,
                box-shadow 0.15s ease, backdrop-filter 0.15s ease, transform 0.1s ease;
    cursor: pointer;
    text-decoration: none;
    flex-shrink: 0;
  }
  :global(.dark .nav-glass-btn),
  :global(.dark #theme-toggle) {
    background: rgb(var(--color-primary-800) / 0.55);
    color: rgb(var(--color-primary-300));
    border-color: rgb(var(--color-highlight-600) / 0.15);
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.15);
  }
  :global(.nav-glass-btn:hover),
  :global(#theme-toggle:hover) {
    color: var(--primary);
    background: rgb(var(--color-primary-50) / 0.9);
    border-color: rgb(var(--color-highlight-500) / 0.35);
    text-decoration: none;
  }
  :global(.dark .nav-glass-btn:hover),
  :global(.dark #theme-toggle:hover) {
    background: rgb(var(--color-primary-800) / 0.9);
  }
  :global(.nav-glass-btn:active),
  :global(#theme-toggle:active) {
    transform: scale(0.9);
  }
  @media (hover: none) and (pointer: coarse) {
    :global(.nav-glass-btn),
    :global(#theme-toggle) {
      width: 2.75rem;
      height: 2.75rem;
    }
  }

  /* ── Scrolled state: buttons shed glass and blend into the frosted header ── */
  #navbar-wrapper:not(.nav-at-top) :global(.nav-glass-btn),
  #navbar-wrapper:not(.nav-at-top) :global(#theme-toggle) {
    background: transparent;
    border-color: transparent;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
  #navbar-wrapper:not(.nav-at-top) :global(.nav-glass-btn:hover),
  #navbar-wrapper:not(.nav-at-top) :global(#theme-toggle:hover) {
    background: var(--btn-plain-bg-hover);
    border-color: transparent;
  }

  /* ── Dark hero (homepage): white tint for outer items at top ── */
  #navbar-wrapper.nav-at-top.has-dark-hero .nav-home-link {
    color: rgb(var(--color-highlight-300));
  }
  #navbar-wrapper.nav-at-top.has-dark-hero .nav-home-link:hover {
    color: rgb(var(--color-highlight-100));
  }
  #navbar-wrapper.nav-at-top.has-dark-hero :global(.nav-glass-btn),
  #navbar-wrapper.nav-at-top.has-dark-hero :global(#theme-toggle) {
    background: rgb(var(--color-primary-900) / 0.55);
    border-color: rgb(var(--color-highlight-600) / 0.4);
    color: rgb(var(--color-highlight-300));
    box-shadow: 0 2px 12px rgb(var(--color-highlight-900) / 0.15);
  }
  #navbar-wrapper.nav-at-top.has-dark-hero :global(.nav-glass-btn:hover),
  #navbar-wrapper.nav-at-top.has-dark-hero :global(#theme-toggle:hover) {
    background: rgb(var(--color-primary-800) / 0.7);
    border-color: rgb(var(--color-highlight-500) / 0.6);
    color: rgb(var(--color-highlight-100));
  }
  /* Pill nav links on dark hero: already light from the amber pill rule above */
  #navbar-wrapper.nav-at-top.has-dark-hero .nav-link:hover {
    color: rgb(255 255 255);
  }
</style>
