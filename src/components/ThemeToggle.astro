---
import Icon from './Icon.astro';
---

<!--
  Button is persistent across Swup navigations (it lives in the fixed header).
  Wire the click listener exactly once — no Swup re-init needed.
  Icons swap via CSS .dark class on <html>, no JS required.
-->
<button id="theme-toggle" type="button" aria-label="Toggle between light and dark theme">
  <!-- Light mode: show moon (→ click to go dark) -->
  <span class="ti-light" aria-hidden="true">
    <Icon name="moon" class="w-4 h-4" />
  </span>
  <!-- Dark mode: show sun (→ click to go light) -->
  <span class="ti-dark" aria-hidden="true">
    <Icon name="sun" class="w-4 h-4" />
  </span>
</button>

<script>
  // Named function so addEventListener deduplicates if script somehow runs twice
  function _themeToggleClick() {
    const html = document.documentElement;
    const next = html.classList.contains('dark') ? 'light' : 'dark';
    localStorage.setItem('theme', next);
    html.classList.remove('light', 'dark');
    html.classList.add(next);
    window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: next } }));
  }

  // Wire once — the button element persists across Swup page transitions
  const btn = document.getElementById('theme-toggle');
  if (btn) btn.addEventListener('click', _themeToggleClick);
</script>

<style>
  /* Icon visibility driven purely by the .dark class on <html> */
  .ti-light { display: flex; align-items: center; }
  .ti-dark  { display: none;  align-items: center; }

  :global(.dark) .ti-light { display: none; }
  :global(.dark) .ti-dark  { display: flex; }
</style>
