---
import Icon from './Icon.astro';
// Scroll to top / bottom buttons — a fixed rail at bottom-right.
// z-30: must sit UNDER the navbar (50), nav drawer scrim/panel (80/90),
// search palette (9995) and graph modal (9990).
---

<div id="scroll-rail" class="fixed bottom-20 right-6 z-30 flex flex-col gap-2">
  <button id="scroll-to-top" class="scroll-btn hidden" aria-label="Scroll to top">
    <Icon name="arrow-up" class="w-4 h-4" />
  </button>
  <button id="scroll-to-bottom" class="scroll-btn hidden" aria-label="Scroll to bottom">
    <Icon name="arrow-down" class="w-4 h-4" />
  </button>
</div>

<script>
  // Component persists across Swup navigations (outside #swup-container) —
  // bind once; visibility re-computes on scroll and per page view.
  function initScrollRail() {
    const topBtn = document.getElementById('scroll-to-top');
    const bottomBtn = document.getElementById('scroll-to-bottom');
    if (!topBtn || !bottomBtn) return;

    function update() {
      const y = window.scrollY;
      const remaining = document.documentElement.scrollHeight - innerHeight - y;
      topBtn!.classList.toggle('hidden', y < 300);
      bottomBtn!.classList.toggle('hidden', remaining < 300);
    }

    // A #hash in the URL makes Chrome re-anchor to that heading whenever late
    // layout shifts (lazy images) happen — programmatic scrolls don't count as
    // "user scrolled", so the ride down gets hijacked back to the anchor.
    // Shed the fragment before scrolling.
    function dropAnchor() {
      if (location.hash)
        history.replaceState(history.state, '', location.pathname + location.search);
    }

    topBtn.addEventListener('click', () => {
      dropAnchor();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // "Bottom" is a moving target: lazy images inflate the page during the
    // ride, so a single scrollTo lands at the stale height. Re-issue the
    // scroll whenever it settles short, until the true bottom stops growing.
    // Any user input (including clicking the top button) cancels the chase.
    bottomBtn.addEventListener('click', () => {
      dropAnchor();
      let cancelled = false;
      const cancel = () => { cancelled = true; };
      ['wheel', 'touchstart', 'keydown', 'mousedown'].forEach(type =>
        window.addEventListener(type, cancel, { once: true, passive: true }));

      let lastY = -1, stillFrames = 0, hops = 0;
      const glide = () => {
        window.scrollTo({ top: document.documentElement.scrollHeight, behavior: 'smooth' });
        const watch = () => {
          if (cancelled) return;
          const y = window.scrollY;
          stillFrames = y === lastY ? stillFrames + 1 : 0;
          lastY = y;
          if (stillFrames > 8) {
            const remaining = document.documentElement.scrollHeight - innerHeight - y;
            if (remaining > 2 && hops++ < 6) glide();
            return;
          }
          requestAnimationFrame(watch);
        };
        requestAnimationFrame(watch);
      };
      glide();
    });

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { update(); ticking = false; });
    }, { passive: true });

    update();
    // Page height changes across Swup navigations — re-evaluate
    document.addEventListener('swup:page:view', () => setTimeout(update, 50));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollRail);
  } else {
    initScrollRail();
  }
</script>

<style>
  .scroll-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    border: 1px solid rgb(var(--color-highlight-600) / 0.2);
    background: rgb(var(--color-primary-50) / 0.8);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: rgb(var(--color-primary-600));
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.08);
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease,
                transform 0.1s ease;
  }
  :global(.dark) .scroll-btn {
    background: rgb(var(--color-primary-800) / 0.8);
    border-color: rgb(var(--color-highlight-600) / 0.15);
    color: rgb(var(--color-primary-300));
  }
  .scroll-btn:hover {
    color: var(--primary);
    background: rgb(var(--color-primary-50) / 0.95);
    border-color: rgb(var(--color-highlight-500) / 0.35);
  }
  :global(.dark) .scroll-btn:hover {
    background: rgb(var(--color-primary-800) / 0.95);
  }
  .scroll-btn:active { transform: scale(0.9); }
  .scroll-btn.hidden { display: none; }

  @media (max-width: 640px) {
    #scroll-rail { bottom: 5rem; right: 1rem; }
  }
  @media (max-width: 480px) {
    #scroll-rail { bottom: 4.5rem; right: 0.75rem; }
  }
</style>
