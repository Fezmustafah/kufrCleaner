---
import type { Heading } from '@/types';
import Icon from './Icon.astro';
import { getTableOfContentsDepth } from '@/config';

export interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

const maxDepth = getTableOfContentsDepth();
const filteredHeadings = headings.filter(h => h.depth >= 2 && h.depth <= maxDepth);
const shouldShowTOC = filteredHeadings.length > 1;

const minDepth = filteredHeadings.length > 0
  ? Math.min(...filteredHeadings.map(h => h.depth))
  : 2;

let topCount = 0;
const processedHeadings = filteredHeadings.map(h => {
  const isTop = h.depth === minDepth;
  if (isTop) topCount++;
  const level = h.depth - minDepth + 1;
  return { ...h, isTop, count: isTop ? topCount : 0, level };
});
---

{shouldShowTOC && (
  <nav class="toc-nav" data-max-depth={maxDepth}>
    <div class="toc-header">
      <Icon name="list" class="toc-header-icon" />
      <span class="toc-header-title">Contents</span>
    </div>

    <div class="toc-scroll-container" id="toc-scroll-container">
      <div class="toc-content" id="toc-content-list">
        {processedHeadings.map(h => (
          <a
            href={`#${h.slug}`}
            class={`toc-item toc-level-${h.depth - minDepth}`}
            data-heading={h.slug}
            title={h.text}
            aria-label={h.text}
          >
            <div class={`toc-badge ${h.isTop ? 'toc-badge-index' : ''}`}>
              {h.isTop
                ? h.count
                : h.level === 2
                  ? <span class="toc-badge-dot"></span>
                  : <span class="toc-badge-dot toc-badge-dot-sm"></span>
              }
            </div>
            <span class={`toc-label ${h.isTop ? 'toc-label-primary' : h.level === 2 ? 'toc-label-primary' : 'toc-label-secondary'}`}>{h.text}</span>
          </a>
        ))}
        <!-- Indicator inside toc-content so getBoundingClientRect is relative to it -->
        <div class="toc-active-indicator" id="toc-active-indicator"></div>
      </div>
    </div>
  </nav>
)}

<script>
  let tocObserver: IntersectionObserver | null = null;
  let scrollTimeout: number | null = null;

  function initializeTableOfContents() {
    const nav = document.querySelector('.toc-nav') as HTMLElement | null;
    if (!nav) return;

    const tocItems = Array.from(nav.querySelectorAll<HTMLAnchorElement>('.toc-item'));
    const scrollContainer = document.getElementById('toc-scroll-container') as HTMLElement | null;
    const tocContent = document.getElementById('toc-content-list') as HTMLElement | null;
    const indicator = document.getElementById('toc-active-indicator') as HTMLElement | null;

    if (!tocItems.length) return;

    if (scrollContainer) scrollContainer.style.maxHeight = 'calc(100vh - 20rem)';

    // Collect content headings
    const maxDepth = parseInt(nav.dataset.maxDepth || '6', 10);
    const selectors: string[] = [];
    for (let i = 2; i <= Math.min(maxDepth, 6); i++) selectors.push(`h${i}`);
    const headingSelector = selectors.join(', ');

    const contentSelectors = ['#post-content','#page-content','#project-content','#documentation-content','.prose'];
    let headings: HTMLElement[] = [];
    for (const c of contentSelectors) {
      const found = Array.from(document.querySelectorAll<HTMLElement>(`${c} ${headingSelector}`));
      if (found.length > 0) { headings = found; break; }
    }
    if (!headings.length) return;

    // ── Exact Firefly getVisibleHeadingIds from toc-utils.ts ────────────────
    function getVisibleHeadingIds(): string[] {
      const visibleHeadingIds: string[] = [];

      headings.forEach(heading => {
        if (heading.id) {
          const rect = heading.getBoundingClientRect();
          const isVisible = rect.top < window.innerHeight && rect.bottom > 0;
          if (isVisible) visibleHeadingIds.push(heading.id);
        }
      });

      // Fallback: no visible headings — find closest to top of screen
      if (visibleHeadingIds.length === 0 && headings.length > 0) {
        let closestHeading: string | null = null;
        let minDistance = Number.POSITIVE_INFINITY;
        headings.forEach(heading => {
          if (heading.id) {
            const rect = heading.getBoundingClientRect();
            const distance = Math.abs(rect.top);
            if (distance < minDistance) {
              minDistance = distance;
              closestHeading = heading.id;
            }
          }
        });
        if (closestHeading) visibleHeadingIds.push(closestHeading);
      }

      return visibleHeadingIds;
    }

    // ── Firefly: scroll TOC sidebar to center the active item ───────────────
    function scrollToActiveItem(activeItem: HTMLElement): void {
      if (!scrollContainer) return;
      if (scrollTimeout) clearTimeout(scrollTimeout);

      scrollTimeout = window.setTimeout(() => {
        const containerRect = scrollContainer.getBoundingClientRect();
        const itemRect = activeItem.getBoundingClientRect();
        const isVisible = itemRect.top >= containerRect.top && itemRect.bottom <= containerRect.bottom;

        if (!isVisible) {
          // activeItem.offsetTop is relative to tocContent (its offsetParent).
          // Add tocContent.offsetTop to get position relative to scrollContainer.
          const contentOffset = tocContent ? tocContent.offsetTop : 0;
          const targetScroll = contentOffset + activeItem.offsetTop - scrollContainer.clientHeight / 2 + activeItem.clientHeight / 2;
          scrollContainer.scrollTo({ top: Math.max(0, targetScroll), behavior: 'smooth' });
        }
      }, 100);
    }

    // ── Firefly: position indicator using getBoundingClientRect ─────────────
    function updateActiveIndicator(activeItems: HTMLAnchorElement[]): void {
      if (!indicator || !tocContent) return;
      if (activeItems.length === 0) { indicator.style.opacity = '0'; return; }

      const contentRect = tocContent.getBoundingClientRect();
      const firstRect = activeItems[0].getBoundingClientRect();
      const lastRect  = activeItems[activeItems.length - 1].getBoundingClientRect();

      const top    = firstRect.top - contentRect.top;
      const height = lastRect.bottom - firstRect.top;

      indicator.style.top    = `${top}px`;
      indicator.style.height = `${height}px`;
      indicator.style.opacity = '1';

      scrollToActiveItem(activeItems[0]);
    }

    // ── Firefly: update all active states ───────────────────────────────────
    function updateActiveState(): void {
      if (!tocItems.length) return;
      const visibleIds = getVisibleHeadingIds();

      tocItems.forEach(item => item.classList.remove('visible'));

      const activeItems = tocItems.filter(item => {
        const id = item.getAttribute('data-heading') || '';
        return visibleIds.includes(id);
      });

      activeItems.forEach(item => item.classList.add('visible'));
      updateActiveIndicator(activeItems);
    }

    // ── IntersectionObserver just triggers a recalc (Firefly pattern) ───────
    if (tocObserver) tocObserver.disconnect();

    tocObserver = new IntersectionObserver(() => {
      updateActiveState();
    }, {
      rootMargin: '0px 0px 0px 0px',
      threshold: 0,
    });

    headings.forEach(h => tocObserver!.observe(h));

    // Initial state
    updateActiveState();
  }

  (window as any).initializeTableOfContents = initializeTableOfContents;

  document.addEventListener('DOMContentLoaded', initializeTableOfContents);
  document.addEventListener('swup:page:view', () => {
    if (scrollTimeout) clearTimeout(scrollTimeout);
    initializeTableOfContents();
  });
</script>

<style>
  /* ── Container ─────────────────────────────────────────────────────────── */
  .toc-nav {
    background: rgb(var(--color-base-50));
    border: 1px solid rgb(var(--color-primary-200) / 0.7);
    border-radius: 0.875rem;
    overflow: hidden;
    width: 100%;
    box-sizing: border-box;
    margin-top: 1rem;
  }
  :global(.dark) .toc-nav {
    background: rgb(var(--color-primary-900));
    border-color: rgb(var(--color-primary-700) / 0.6);
  }

  /* ── Header ────────────────────────────────────────────────────────────── */
  .toc-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem 0.5rem;
    border-bottom: 1px solid rgb(var(--color-primary-200) / 0.5);
  }
  :global(.dark) .toc-header {
    border-bottom-color: rgb(var(--color-primary-700) / 0.4);
  }
  .toc-header-icon {
    width: 0.9rem;
    height: 0.9rem;
    color: rgb(var(--color-highlight-600));
    flex-shrink: 0;
  }
  :global(.dark) .toc-header-icon {
    color: rgb(var(--color-highlight-400));
  }
  .toc-header-title {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(var(--color-primary-500));
  }
  :global(.dark) .toc-header-title {
    color: rgb(var(--color-primary-400));
  }

  /* ── Scroll container ──────────────────────────────────────────────────── */
  .toc-scroll-container {
    position: relative;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
    padding: 0.25rem 0.125rem 1.25rem;
    scrollbar-width: thin;
    scrollbar-color: rgb(var(--color-primary-300) / 0.5) transparent;
  }
  :global(.dark) .toc-scroll-container {
    scrollbar-color: rgb(var(--color-primary-600) / 0.4) transparent;
  }
  .toc-scroll-container::-webkit-scrollbar { width: 4px; }
  .toc-scroll-container::-webkit-scrollbar-track { background: transparent; }
  .toc-scroll-container::-webkit-scrollbar-thumb {
    background: rgb(var(--color-primary-300) / 0.5);
    border-radius: 4px;
  }
  :global(.dark) .toc-scroll-container::-webkit-scrollbar-thumb {
    background: rgb(var(--color-primary-600) / 0.4);
  }

  /* ── Content list — exact Firefly toc.css ─────────────────────────────── */
  .toc-content {
    display: flex;
    flex-direction: column;
    gap: 0.28rem;
    position: relative;
    overflow: visible;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    contain: layout;
    align-items: stretch;
    padding: 0.125rem 0;
  }

  /* ── Item ──────────────────────────────────────────────────────────────── */
  .toc-item {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: inherit;
    border-radius: 0.875rem;
    transition:
      background-color 0.14s ease,
      transform 0.14s ease,
      color 0.14s ease;
    width: 100%;
    min-width: 0;
    flex-shrink: 0;
    max-width: 100%;
    overflow: hidden;
    box-sizing: border-box;
    position: relative;
    padding: 0.48rem 0.62rem;
    min-height: 2.2rem;
  }

  .toc-item:hover {
    background: rgb(var(--color-primary-100) / 0.84);
    transform: translateX(1px);
  }
  :global(.dark) .toc-item:hover {
    background: rgb(var(--color-primary-800) / 0.84);
  }

  /* Indentation — 0-based levels matching Firefly */
  .toc-level-0 { padding-left: 0.62rem; }
  .toc-level-1 { padding-left: 1.08rem; }
  .toc-level-2 { padding-left: 1.62rem; }

  /* ── Active indicator — exact Firefly toc.css ──────────────────────────── */
  .toc-active-indicator {
    position: absolute;
    left: 0;
    right: 0;
    background: rgb(var(--color-primary-100) / 0.78);
    border-radius: 0.875rem;
    transition: top 0.18s ease, height 0.18s ease, opacity 0.14s ease;
    box-shadow: 0 6px 18px -14px rgb(var(--color-highlight-600) / 0.55);
    z-index: -1;
    pointer-events: none;
  }
  :global(.dark) .toc-active-indicator {
    background: rgb(var(--color-primary-800) / 0.78);
    box-shadow: 0 6px 18px -14px rgb(var(--color-highlight-400) / 0.55);
  }

  /* ── Badge — exact Firefly toc.css ─────────────────────────────────────── */
  .toc-badge {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 0.5rem;
    font-size: 0.68rem;
    font-weight: 700;
    line-height: 1;
  }

  .toc-badge-index {
    background: rgb(var(--color-primary-100));
    color: rgb(var(--color-primary-600));
  }
  :global(.dark) .toc-badge-index {
    background: rgb(var(--color-primary-800));
    color: rgb(var(--color-primary-300));
  }

  .toc-badge-dot {
    display: block;
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 999px;
    background: rgb(var(--color-primary-300));
    transition: background-color 0.14s ease;
  }
  :global(.dark) .toc-badge-dot {
    background: rgb(var(--color-primary-600));
  }

  .toc-badge-dot-sm {
    width: 0.34rem;
    height: 0.34rem;
    background: rgb(var(--color-primary-200));
  }
  :global(.dark) .toc-badge-dot-sm {
    background: rgb(var(--color-primary-700));
  }

  /* ── Active state — exact Firefly toc.css ──────────────────────────────── */
  .toc-item.visible .toc-label {
    color: rgb(var(--color-highlight-600));
    opacity: 1;
  }
  :global(.dark) .toc-item.visible .toc-label {
    color: rgb(var(--color-highlight-400));
  }

  .toc-item.visible .toc-badge-dot,
  .toc-item.visible .toc-badge-dot-sm {
    background: rgb(var(--color-highlight-500));
  }
  :global(.dark) .toc-item.visible .toc-badge-dot,
  :global(.dark) .toc-item.visible .toc-badge-dot-sm {
    background: rgb(var(--color-highlight-400));
  }

  .toc-item.visible .toc-badge-index {
    background: rgb(var(--color-highlight-100));
    color: rgb(var(--color-highlight-600));
  }
  :global(.dark) .toc-item.visible .toc-badge-index {
    background: rgb(var(--color-highlight-900) / 0.5);
    color: rgb(var(--color-highlight-400));
  }

  /* ── Label — exact Firefly toc.css ─────────────────────────────────────── */
  .toc-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
    flex: 1;
    max-width: calc(100% - 2.4rem);
    box-sizing: border-box;
    font-size: 0.86rem;
    line-height: 1.3;
    letter-spacing: 0.01em;
  }

  .toc-label-primary {
    color: rgb(var(--color-primary-600));
  }
  :global(.dark) .toc-label-primary {
    color: rgb(var(--color-primary-300));
  }

  .toc-label-secondary {
    color: rgb(var(--color-primary-400));
  }
  :global(.dark) .toc-label-secondary {
    color: rgb(var(--color-primary-500));
  }
</style>
