---
import type { Heading } from '@/types';
import { getTableOfContentsDepth } from '@/config';

export interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

const maxDepth = getTableOfContentsDepth();
const filteredHeadings = headings.filter(h => h.depth >= 2 && h.depth <= maxDepth);
const shouldShowTOC = filteredHeadings.length > 1;

const minDepth = filteredHeadings.length > 0
  ? Math.min(...filteredHeadings.map(h => h.depth))
  : 2;

let topCount = 0;
const processedHeadings = filteredHeadings.map(h => {
  const isTop = h.depth === minDepth;
  if (isTop) topCount++;
  const level = h.depth - minDepth + 1;
  return { ...h, isTop, count: isTop ? topCount : 0, level };
});
---

{shouldShowTOC && (
  <nav class="toc-nav" data-max-depth={maxDepth}>
    <div class="toc-scroll-container" id="toc-scroll-container">
      <div class="toc-content" id="toc-content-list">
        {processedHeadings.map(h => (
          <a
            href={`#${h.slug}`}
            class={`toc-item toc-level-${h.depth - minDepth}`}
            data-heading={h.slug}
            title={h.text}
            aria-label={h.text}
          >
            <div class={`toc-badge ${h.isTop ? 'toc-badge-index' : ''}`}>
              {h.isTop
                ? String(h.count).replace(/[0-9]/g, d => '٠١٢٣٤٥٦٧٨٩'[parseInt(d)])
                : h.level === 2
                  ? <span class="toc-badge-dot"></span>
                  : <span class="toc-badge-dot toc-badge-dot-sm"></span>
              }
            </div>
            <span class={`toc-label ${h.isTop ? 'toc-label-primary' : h.level === 2 ? 'toc-label-primary' : 'toc-label-secondary'}`}>{h.text}</span>
          </a>
        ))}
        <div class="toc-active-indicator" id="toc-active-indicator"></div>
      </div>
    </div>
  </nav>
)}

<!-- Script extracted to /src/scripts/toc-client.ts and imported globally
     from BaseLayout so it loads on every page (works around Astro+Swup
     reloadScripts:false: per-component scripts that aren't on the initial page
     never run after Swup nav). The init function no-ops when .toc-nav
     is not in the DOM. -->


<style>
  /* ── Container — no card, matches fuwari's clean list ─────────────────── */
  .toc-nav {
    width: 100%;
    box-sizing: border-box;
  }

  /* ── Scroll container — fade mask at top/bottom (fuwari toc-inner-wrapper) */
  .toc-scroll-container {
    position: relative;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
    padding: 1.5rem 0.125rem 1.5rem;
    scrollbar-width: thin;
    scrollbar-color: rgb(var(--color-primary-300) / 0.5) transparent;
    mask-image: linear-gradient(
      to bottom,
      transparent,
      black 1.5rem,
      black calc(100% - 1.5rem),
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent,
      black 1.5rem,
      black calc(100% - 1.5rem),
      transparent
    );
  }
  :global(.dark) .toc-scroll-container {
    scrollbar-color: rgb(var(--color-primary-600) / 0.4) transparent;
  }
  .toc-scroll-container::-webkit-scrollbar { width: 4px; }
  .toc-scroll-container::-webkit-scrollbar-track { background: transparent; }
  .toc-scroll-container::-webkit-scrollbar-thumb {
    background: rgb(var(--color-primary-300) / 0.5);
    border-radius: 4px;
  }
  :global(.dark) .toc-scroll-container::-webkit-scrollbar-thumb {
    background: rgb(var(--color-primary-600) / 0.4);
  }

  /* ── Content list ─────────────────────────────────────────────────────── */
  .toc-content {
    display: flex;
    flex-direction: column;
    gap: 0.28rem;
    position: relative;
    overflow: visible;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    contain: layout;
    align-items: stretch;
    padding: 0.125rem 0;
  }

  /* ── Item ──────────────────────────────────────────────────────────────── */
  .toc-item {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-md);
    transition:
      background-color 0.14s ease,
      transform 0.14s ease,
      color 0.14s ease;
    width: 100%;
    min-width: 0;
    flex-shrink: 0;
    max-width: 100%;
    overflow: hidden;
    box-sizing: border-box;
    position: relative;
    padding: 0.28rem 0.62rem;
    min-height: 1.8rem;
  }
  .toc-item:hover {
    background: rgb(var(--color-primary-100) / 0.84);
    transform: translateX(1px);
  }
  :global(.dark) .toc-item:hover {
    background: rgb(var(--color-primary-800) / 0.84);
  }

  /* Indentation */
  .toc-level-0 { padding-left: 0.62rem; }
  .toc-level-1 { padding-left: 1.08rem; }
  .toc-level-2 { padding-left: 1.62rem; }

  /* ── Active indicator — fuwari style: no shadow, hover = dashed border ── */
  .toc-active-indicator {
    position: absolute;
    left: 0;
    right: 0;
    background: rgb(var(--color-highlight-400) / 0.07);
    border-radius: var(--radius-xs);
    border: 1px dashed transparent;
    transition:
      top 0.18s ease,
      height 0.18s ease,
      opacity 0.14s ease,
      background-color 0.14s ease,
      border-color 0.14s ease;
    z-index: -1;
    pointer-events: none;
  }
  :global(.dark) .toc-active-indicator {
    background: rgb(var(--color-highlight-500) / 0.08);
  }
  /* Dashed border only after intentional mouse movement (JS adds .is-hovered) */
  .toc-nav.is-hovered .toc-active-indicator {
    background: rgb(var(--color-highlight-400) / 0.05);
    border-color: rgb(var(--color-highlight-400) / 0.35);
  }
  :global(.dark) .toc-nav.is-hovered .toc-active-indicator {
    border-color: rgb(var(--color-highlight-500) / 0.35);
  }

  /* ── Badge ─────────────────────────────────────────────────────────────── */
  .toc-badge {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: var(--radius-xs);
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1;
  }
  .toc-badge-index {
    background: rgb(var(--color-highlight-100) / 0.6);
    color: rgb(var(--color-highlight-700));
    border: 1px solid rgb(var(--color-highlight-300) / 0.4);
  }
  :global(.dark) .toc-badge-index {
    background: rgb(var(--color-highlight-900) / 0.35);
    color: rgb(var(--color-highlight-300));
    border-color: rgb(var(--color-highlight-700) / 0.4);
  }
  .toc-badge-dot {
    display: block;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 0;
    transform: rotate(45deg);
    background: rgb(var(--color-primary-300));
    transition: background-color 0.14s ease, transform 0.14s ease;
  }
  :global(.dark) .toc-badge-dot {
    background: rgb(var(--color-primary-600));
  }
  .toc-badge-dot-sm {
    width: 0.28rem;
    height: 0.28rem;
    background: rgb(var(--color-primary-200));
  }
  :global(.dark) .toc-badge-dot-sm {
    background: rgb(var(--color-primary-700));
  }

  /* ── Active state ──────────────────────────────────────────────────────── */
  .toc-item.visible .toc-label {
    color: rgb(var(--color-highlight-600));
    opacity: 1;
  }
  :global(.dark) .toc-item.visible .toc-label {
    color: rgb(var(--color-highlight-400));
  }
  .toc-item.visible .toc-badge-dot,
  .toc-item.visible .toc-badge-dot-sm {
    background: rgb(var(--color-highlight-500));
    transform: rotate(45deg) scale(1.15);
  }
  :global(.dark) .toc-item.visible .toc-badge-dot,
  :global(.dark) .toc-item.visible .toc-badge-dot-sm {
    background: rgb(var(--color-highlight-400));
    transform: rotate(45deg) scale(1.15);
  }
  .toc-item.visible .toc-badge-index {
    background: rgb(var(--color-highlight-100));
    color: rgb(var(--color-highlight-600));
  }
  :global(.dark) .toc-item.visible .toc-badge-index {
    background: rgb(var(--color-highlight-900) / 0.5);
    color: rgb(var(--color-highlight-400));
  }

  /* ── Label ─────────────────────────────────────────────────────────────── */
  .toc-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
    flex: 1;
    max-width: calc(100% - 2.4rem);
    box-sizing: border-box;
    font-size: 0.86rem;
    line-height: 1.3;
    letter-spacing: 0.01em;
  }
  .toc-label-primary {
    color: rgb(var(--color-primary-600));
  }
  :global(.dark) .toc-label-primary {
    color: rgb(var(--color-primary-300));
  }
  .toc-label-secondary {
    color: rgb(var(--color-primary-400));
  }
  :global(.dark) .toc-label-secondary {
    color: rgb(var(--color-primary-500));
  }
</style>
