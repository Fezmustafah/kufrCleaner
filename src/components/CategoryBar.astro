---
import { getCollection } from 'astro:content';
import { shouldShowPost } from '@/utils/markdown';
import Icon from '@/components/Icon.astro';

interface Props {
  currentCategory?: string;
  class?: string;
}

const { currentCategory, class: className = '' } = Astro.props;
const isDev = import.meta.env.DEV;

const allPosts = await getCollection('posts');
const visiblePosts = allPosts.filter(p => shouldShowPost(p, isDev));

// Build category list with counts
const categoryMap = new Map<string, number>();
for (const post of visiblePosts) {
  const cat = (post.data as any).category;
  if (cat) categoryMap.set(cat, (categoryMap.get(cat) ?? 0) + 1);
}
const categories = Array.from(categoryMap.entries())
  .sort((a, b) => a[0].localeCompare(b[0]))
  .map(([name, count]) => ({ name, count, url: `/posts/category/${encodeURIComponent(name)}` }));

const totalPosts = visiblePosts.length;
---

<div
  class:list={['category-bar', className]}
  id="category-bar"
  data-home-path="/posts"
  data-current-post-category={currentCategory || ''}
>
  <div class="category-bar-inner flex gap-2">
    <a
      href="/posts"
      class="category-pill text-sm px-2 py-1 rounded-lg shrink-0 transition-colors duration-150 ease-out flex items-center justify-center"
      data-category-name=""
      aria-label="All posts"
    >
      <Icon name="home" class="text-lg w-4 h-4" />
    </a>

    <div class="category-divider shrink-0"></div>

    <div class="scroll-area relative">
      <div class="scroll-fade scroll-fade-left" aria-hidden="true"></div>
      <div class="category-scroll flex gap-2 overflow-x-auto">
        {categories.map(cat => (
          <a
            href={cat.url}
            class="category-pill text-sm px-3 py-1 rounded-lg whitespace-nowrap transition-colors duration-150 ease-out flex items-center justify-center"
            data-category-name={cat.name}
          >
            {cat.name}
            <span class="text-xs opacity-60 ml-1">{cat.count}</span>
          </a>
        ))}
      </div>
      <div class="scroll-fade scroll-fade-right" aria-hidden="true"></div>
    </div>
  </div>
</div>

<style>
  .category-bar {
    background: rgb(var(--color-base-50));
    border: 1px solid rgb(var(--color-primary-200) / 0.7);
    border-radius: 0.875rem;
    padding: 0.5rem 0.75rem;
    margin-bottom: 1rem;
    overflow: hidden;
  }
  :global(.dark) .category-bar {
    background: rgb(var(--color-primary-900));
    border-color: rgb(var(--color-primary-700) / 0.6);
  }

  .category-divider {
    width: 1px;
    align-self: stretch;
    background: rgb(var(--color-primary-200));
    flex-shrink: 0;
  }
  :global(.dark) .category-divider {
    background: rgb(var(--color-primary-700));
  }

  .scroll-area {
    flex: 1;
    min-width: 0;
    position: relative;
  }

  .scroll-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2.5rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity 300ms ease-in-out;
    z-index: 1;
  }
  .scroll-fade[data-visible] { opacity: 1; }
  .scroll-fade-left {
    left: 0;
    background: linear-gradient(to left, transparent, rgb(var(--color-base-50)));
  }
  .scroll-fade-right {
    right: 0;
    background: linear-gradient(to right, transparent, rgb(var(--color-base-50)));
  }
  :global(.dark) .scroll-fade-left {
    background: linear-gradient(to left, transparent, rgb(var(--color-primary-900)));
  }
  :global(.dark) .scroll-fade-right {
    background: linear-gradient(to right, transparent, rgb(var(--color-primary-900)));
  }

  .category-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }
  .category-scroll::-webkit-scrollbar { display: none; }

  .category-pill {
    border: 1.5px solid rgb(var(--color-primary-200));
    color: rgb(var(--color-primary-600));
    background: transparent;
    font-weight: 500;
  }
  :global(.dark) .category-pill {
    border-color: rgb(var(--color-primary-700));
    color: rgb(var(--color-primary-300));
  }
  .category-pill:hover {
    border-color: rgb(var(--color-highlight-500));
    color: rgb(var(--color-highlight-600));
  }
  :global(.dark) .category-pill:hover {
    border-color: rgb(var(--color-highlight-400));
    color: rgb(var(--color-highlight-400));
  }

  /* Hard active — current category page */
  .category-pill[data-active] {
    background: rgb(var(--color-highlight-600));
    border-color: rgb(var(--color-highlight-600));
    color: white;
  }
  :global(.dark) .category-pill[data-active] {
    background: rgb(var(--color-highlight-500));
    border-color: rgb(var(--color-highlight-500));
    color: white;
  }
  .category-pill[data-active]:hover { opacity: 0.9; }

  /* Soft active — viewing a post in this category */
  .category-pill[data-soft-active] {
    border-color: rgb(var(--color-primary-200));
    background: rgb(var(--color-highlight-100) / 0.6);
    color: rgb(var(--color-highlight-700));
  }
  :global(.dark) .category-pill[data-soft-active] {
    border-color: rgb(var(--color-primary-700));
    background: rgb(var(--color-highlight-900) / 0.3);
    color: rgb(var(--color-highlight-300));
  }
</style>

<script>
  let delayedScrollTimer: number | undefined;

  function getCategoryBarState(bar: HTMLElement, currentUrl: URL) {
    const pathname = currentUrl.pathname.replace(/\/$/, '');
    const homePath = (bar.getAttribute('data-home-path') || '/posts').replace(/\/$/, '');
    const isHome = pathname === homePath || pathname === '' || pathname === '/';
    const isCategoryPage = pathname.startsWith('/posts/category/');

    return {
      isHome,
      isCategoryPage,
      activeCategory: isCategoryPage
        ? decodeURIComponent(pathname.replace('/posts/category/', '').split('/')[0])
        : '',
    };
  }

  function setActiveCategory(bar: HTMLElement, currentUrl: URL) {
    const { isHome, activeCategory } = getCategoryBarState(bar, currentUrl);
    const postCategory = (bar.getAttribute('data-current-post-category') || '').trim();
    const pills = bar.querySelectorAll<HTMLAnchorElement>('.category-pill');

    pills.forEach(p => {
      p.removeAttribute('data-active');
      p.removeAttribute('data-soft-active');
    });

    if (isHome) {
      bar.querySelector<HTMLAnchorElement>('.category-pill[data-category-name=""]')
        ?.setAttribute('data-active', '');
      return;
    }

    if (activeCategory) {
      pills.forEach(p => {
        if (p.getAttribute('data-category-name') === activeCategory)
          p.setAttribute('data-active', '');
      });
      return;
    }

    // On a post page — soft-highlight its category
    if (postCategory) {
      pills.forEach(p => {
        if (p.getAttribute('data-category-name') === postCategory)
          p.setAttribute('data-soft-active', '');
      });
    }
  }

  function scrollActivePillIntoView(bar: HTMLElement, behavior: ScrollBehavior = 'smooth') {
    const active =
      bar.querySelector<HTMLAnchorElement>('.category-pill[data-active]') ||
      bar.querySelector<HTMLAnchorElement>('.category-pill[data-soft-active]');
    const scroll = bar.querySelector<HTMLElement>('.category-scroll');
    if (!active || !scroll) return;
    const scrollLeft = active.offsetLeft - scroll.offsetLeft - (scroll.clientWidth - active.offsetWidth) / 2;
    scroll.scrollTo({ left: Math.max(0, scrollLeft), behavior });
  }

  function updateScrollHint() {
    const bar = document.getElementById('category-bar');
    if (!bar) return;
    const scroll = bar.querySelector<HTMLElement>('.category-scroll');
    const fadeLeft = bar.querySelector<HTMLElement>('.scroll-fade-left');
    const fadeRight = bar.querySelector<HTMLElement>('.scroll-fade-right');
    if (!scroll || !fadeLeft || !fadeRight) return;

    const hasOverflow = scroll.scrollWidth > scroll.clientWidth + 1;
    const atStart = scroll.scrollLeft <= 1;
    const atEnd = scroll.scrollLeft + scroll.clientWidth >= scroll.scrollWidth - 1;

    hasOverflow && !atStart ? fadeLeft.setAttribute('data-visible', '') : fadeLeft.removeAttribute('data-visible');
    hasOverflow && !atEnd  ? fadeRight.setAttribute('data-visible', '') : fadeRight.removeAttribute('data-visible');
  }

  function initScrollFeatures() {
    const bar = document.getElementById('category-bar');
    if (!bar) return;
    const scroll = bar.querySelector<HTMLElement>('.category-scroll');
    if (!scroll || scroll.dataset.featuresBound === 'true') { updateScrollHint(); return; }
    scroll.dataset.featuresBound = 'true';

    scroll.addEventListener('wheel', e => {
      if (scroll.scrollWidth <= scroll.clientWidth) return;
      e.preventDefault();
      scroll.scrollLeft += e.deltaY;
    }, { passive: false });

    scroll.addEventListener('scroll', updateScrollHint);
    window.addEventListener('resize', updateScrollHint);
    updateScrollHint();
  }

  function updateCategoryBar() {
    const bar = document.getElementById('category-bar');
    if (!bar) return;

    setActiveCategory(bar, new URL(window.location.href));
    scrollActivePillIntoView(bar, 'auto');
    updateScrollHint();
  }

  function initClickHandlers() {
    const bar = document.getElementById('category-bar');
    if (!bar || bar.dataset.clickBound === 'true') return;
    bar.dataset.clickBound = 'true';
    bar.addEventListener('click', e => {
      const pill = (e.target as Element).closest<HTMLAnchorElement>('.category-pill');
      if (!pill || e.defaultPrevented || (e as MouseEvent).metaKey || (e as MouseEvent).ctrlKey) return;
      const targetUrl = new URL(pill.href, window.location.href);
      if (targetUrl.origin !== window.location.origin) return;
      setActiveCategory(bar, targetUrl);
      scrollActivePillIntoView(bar, 'auto');
    });
  }

  updateCategoryBar();
  initClickHandlers();
  initScrollFeatures();

  document.addEventListener('swup:page:view', () => {
    updateCategoryBar();
    initScrollFeatures();
  });

  // Swup early update to prevent flicker during navigation
  function setupSwupEarlyUpdate() {
    if (!(window as any).swup?.hooks) return;
    (window as any).swup.hooks.on('visit:start', (visit: any) => {
      const bar = document.getElementById('category-bar');
      if (!bar) return;
      setActiveCategory(bar, new URL(visit.to.url, window.location.href));
    });
  }
  if ((window as any).swup?.hooks) setupSwupEarlyUpdate();
  else document.addEventListener('swup:enable', setupSwupEarlyUpdate);
</script>
