---
import type { GraphConfig } from '@/graph/config';
import Graph from '@/graph/components/graph/Graph.astro';
import '@/graph/graph.css';

export type GraphMode = 'sidebar' | 'hero';

interface Props {
    mode: GraphMode;
    currentSlug?: string;
    config?: Partial<GraphConfig>;
    class?: string;
}

const {
    mode,
    currentSlug = '',
    config: configOverride = {},
    class: className,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const sitemapUrl = `${base}graph/sitemap.json`;

// Physics, hover, zoom, and styling all run on starlight-site-graph defaults.
// The only deviations are site choices (depth, actions, tag rendering) and the
// label model: labels counter-scale by 1/k (screen-constant size), so
// labelOpacityScale is retuned per mode around that.
const BASE_CONFIG: Partial<GraphConfig> = {
    // sidebar: depth=1 (direct neighbors only)
    // hero: depth=-1 (full global graph on /graph-view/)
    depth: mode === 'sidebar' ? 1 : -1,
    scale: mode === 'sidebar' ? 1.0 : 1.1,

    // Zoom-driven label opacity: getCurrentLabelOpacity(k) = max((k * labelOpacityScale - 1) / 0.9, 0)
    // sidebar (initial scale 1.0, labelOpacityScale 2.0): (1.0 * 2.0 - 1) / 0.9 ≈ 1.11 → labels fully
    //   visible at rest — small local graph, titles ARE the content.
    // hero (labelOpacityScale 0.45): hidden until k ≈ 2.2 (1/0.45), fully opaque at
    //   k ≈ 4.2 ((1+0.9)/0.45) — labels are screen-constant size (renderer
    //   counter-scales by 1/k), so they only appear once the view is sparse
    //   enough for 1200+ titles not to smear into each other.
    labelOpacityScale: mode === 'sidebar' ? 2.0 : 0.45,
    renderExternal: false,
    tagRenderMode: 'node',
    actions: mode === 'sidebar'
        ? ['fullscreen', 'depth', 'reset-zoom', 'settings']
        : ['reset-zoom', 'render-arrows', 'settings'],
};

const graphConfig = { ...BASE_CONFIG, ...configOverride } as GraphConfig;
---

<div class:list={['slsg-wrapper', `slsg-mode-${mode}`, className]}>
    <Graph
        slug={currentSlug}
        config={graphConfig}
        sitemapUrl={sitemapUrl}
        trailingSlashes={false}
    />
</div>

<style is:global>
.slsg-wrapper { display: block; width: 100%; height: 100%; }

.slsg-mode-sidebar { height: 220px; }
.slsg-mode-hero    { width: 100vw; height: 100vh; }
</style>
