---

{iconPath && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden={title ? undefined : true}
    set:html={title ? `<title>${escapeHtml(title)}</title>${iconPath}` : iconPath}
  />
)}