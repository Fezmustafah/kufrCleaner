---
// src/components/PageActions.astro
import Icon from '@/components/Icon.astro';

interface Props {
  postId: string;
  postTitle: string;
  postUrl: string;
}

const { postId, postTitle, postUrl } = Astro.props;

const prompt       = encodeURIComponent(`Read ${postUrl} and answer my questions about it.`);
const encodedUrl   = encodeURIComponent(postUrl);
const encodedTitle = encodeURIComponent(postTitle);
const mdPath       = `/posts/${postId}.md`;

const shareItems = [
  { icon: 'x-twitter', label: 'X',         href: `https://x.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}` },
  { icon: 'whatsapp',  label: 'WhatsApp',   href: `https://wa.me/?text=${encodedTitle}%20${encodedUrl}` },
  { icon: 'telegram',  label: 'Telegram',   href: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}` },
  { icon: 'linkedin',  label: 'LinkedIn',   href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}` },
  { icon: 'reddit',    label: 'Reddit',     href: `https://reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}` },
  { icon: 'facebook',  label: 'Facebook',   href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}` },
  { icon: 'bluesky',   label: 'Bluesky',    href: `https://bsky.app/intent/compose?text=${encodedTitle}%20${encodedUrl}` },
  { icon: 'mail',      label: 'Email',      href: `mailto:?subject=${encodedTitle}&body=${encodedUrl}` },
];

const aiItems = [
  { label: 'ChatGPT',    href: `https://chatgpt.com/?q=${prompt}` },
  { label: 'Claude',     href: `https://claude.ai/new?q=${prompt}` },
  { label: 'Perplexity', href: `https://perplexity.ai/?q=${prompt}` },
];
---

<aside class="post-actions-section" data-pagefind-ignore aria-label="Share and actions">

  <div class="pa-btn-row">

    <!-- Share dropdown -->
    <div class="pa-dropdown" data-dropdown-id="share">
      <button id="pa-toggle-share" class="pa-pill pa-dropdown-toggle"
        aria-haspopup="true" aria-expanded="false" aria-controls="pa-menu-share" type="button">
        <Icon name="share-2" size={13} class="pa-pill-icon" />
        <span>Share</span>
        <Icon name="chevron-down" size={11} class="pa-chevron" />
      </button>
      <div id="pa-menu-share" class="pa-menu" role="menu">
        {shareItems.map(({ icon, label, href }) => (
          <a href={href} target="_blank" rel="noopener noreferrer"
             class="pa-menu-item" role="menuitem">
            <Icon name={icon} size={13} class="pa-menu-icon" />
            <span>{label}</span>
            <Icon name="external-link" size={11} class="pa-menu-ext" />
          </a>
        ))}
      </div>
    </div>

    <!-- Open in AI dropdown -->
    <div class="pa-dropdown" data-dropdown-id="ai">
      <button id="pa-toggle-ai" class="pa-pill pa-dropdown-toggle"
        aria-haspopup="true" aria-expanded="false" aria-controls="pa-menu-ai" type="button">
        <Icon name="sparkles" size={13} class="pa-pill-icon" />
        <span>Open in AI</span>
        <Icon name="chevron-down" size={11} class="pa-chevron" />
      </button>
      <div id="pa-menu-ai" class="pa-menu" role="menu">
        {aiItems.map(({ label, href }) => (
          <a href={href} target="_blank" rel="noopener noreferrer"
             class="pa-menu-item" role="menuitem">
            <span>{label}</span>
            <Icon name="external-link" size={11} class="pa-menu-ext" />
          </a>
        ))}
      </div>
    </div>

  </div>
</aside>

<style>
  /* No margins/divider of its own — the colophon in PostLayout hosts this
     inline with the document metadata. */

  /* ── Button row ──────────────────────────────────────────────── */
  .pa-btn-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  /* ── Shared pill style ───────────────────────────────────────── */
  :global(.pa-pill) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    height: 2rem;
    padding: 0 0.75rem;
    border-radius: 999px;
    border: 1px solid rgb(var(--color-primary-200) / 1);
    background: transparent;
    color: rgb(var(--color-primary-500) / 1);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    text-decoration: none;
    transition: background 0.1s, border-color 0.1s, color 0.1s;
    line-height: 1;
  }
  :global(.dark .pa-pill) {
    border-color: rgb(var(--color-primary-700) / 1);
    color: rgb(var(--color-primary-400) / 1);
  }
  :global(.pa-pill:hover) {
    background: rgb(var(--color-primary-100) / 1);
    border-color: rgb(var(--color-primary-300) / 1);
    color: rgb(var(--color-primary-700) / 1);
  }
  :global(.dark .pa-pill:hover) {
    background: rgb(var(--color-primary-800) / 1);
    border-color: rgb(var(--color-primary-600) / 1);
    color: rgb(var(--color-primary-200) / 1);
  }

  .pa-pill-icon { flex-shrink: 0; opacity: 0.7; }

  .pa-chevron {
    flex-shrink: 0;
    opacity: 0.5;
    transition: transform 0.15s ease;
  }
  :global(.pa-dropdown-toggle[aria-expanded="true"]) .pa-chevron {
    transform: rotate(180deg);
  }

  /* Copy success */
  :global(.pa-copy-btn.is-copied) {
    color: rgb(var(--color-highlight-600) / 1);
    border-color: rgb(var(--color-highlight-300) / 1);
    background: rgb(var(--color-highlight-50) / 0.4);
  }
  :global(.dark .pa-copy-btn.is-copied) {
    color: rgb(var(--color-highlight-400) / 1);
    border-color: rgb(var(--color-highlight-700) / 1);
    background: rgb(var(--color-highlight-900) / 0.25);
  }

  /* ── Dropdown ────────────────────────────────────────────────── */
  .pa-dropdown { position: relative; }

  .pa-menu {
    display: none;
    position: absolute;
    bottom: calc(100% + 0.375rem);  /* open upward — section is always near page bottom */
    top: auto;
    left: 0;
    z-index: 50;
    min-width: 180px;
    padding: 0.25rem;
    border-radius: 0.625rem;
    background: rgb(var(--color-primary-50) / 1);
    border: 1px solid rgb(var(--color-primary-200) / 1);
    box-shadow: 0 4px 16px -2px rgb(0 0 0 / 0.1), 0 2px 4px -1px rgb(0 0 0 / 0.06);
  }
  :global(.dark) .pa-menu {
    background: rgb(var(--color-primary-900) / 1);
    border-color: rgb(var(--color-primary-700) / 1);
    box-shadow: 0 4px 16px -2px rgb(0 0 0 / 0.4), 0 2px 4px -1px rgb(0 0 0 / 0.3);
  }
  .pa-menu.is-open { display: block; }

  .pa-menu-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.625rem;
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    color: rgb(var(--color-primary-600) / 1);
    text-decoration: none;
    transition: background 0.1s;
  }
  :global(.dark) .pa-menu-item {
    color: rgb(var(--color-primary-300) / 1);
  }
  .pa-menu-item:hover {
    background: rgb(var(--color-primary-100) / 1);
    color: rgb(var(--color-primary-800) / 1);
  }
  :global(.dark) .pa-menu-item:hover {
    background: rgb(var(--color-primary-800) / 1);
    color: rgb(var(--color-primary-100) / 1);
  }
  .pa-menu-icon { flex-shrink: 0; opacity: 0.8; }
  .pa-menu-ext  { flex-shrink: 0; opacity: 0.35; margin-left: auto; }

  .pa-menu-item span { flex: 1; }
</style>

<!-- Behaviour lives in /src/scripts/page-actions-client.ts, loaded globally from
     BaseLayout. A component-inline script only ships with pages that render the
     component, so it never runs when a post is reached via Swup nav from a page
     without it (Swup doesn't execute the fetched page's scripts). -->

