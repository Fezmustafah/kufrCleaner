---
// src/components/PageActions.astro
import Icon from '@/components/Icon.astro';

interface Props {
  postId: string;    // post.id — used to build /posts/{id}.md URL
  postTitle: string; // post.data.title — URL-encoded for share links
  postUrl: string;   // Astro.url.href — full canonical URL
}

const { postId, postTitle, postUrl } = Astro.props;

const prompt    = encodeURIComponent(`Read ${postUrl} and answer my questions about it.`);
const encodedUrl   = encodeURIComponent(postUrl);
const encodedTitle = encodeURIComponent(postTitle);
const mdPath       = `/posts/${postId}.md`;

const shareLinks = [
  { icon: 'x-twitter',  label: 'X',         href: `https://x.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}` },
  { icon: 'whatsapp',   label: 'WhatsApp',   href: `https://wa.me/?text=${encodedTitle}%20${encodedUrl}` },
  { icon: 'telegram',   label: 'Telegram',   href: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}` },
  { icon: 'linkedin',   label: 'LinkedIn',   href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}` },
  { icon: 'reddit',     label: 'Reddit',     href: `https://reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}` },
  { icon: 'facebook',   label: 'Facebook',   href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}` },
  { icon: 'bluesky',    label: 'Bluesky',    href: `https://bsky.app/intent/compose?text=${encodedTitle}%20${encodedUrl}` },
  { icon: 'mail',       label: 'Email',      href: `mailto:?subject=${encodedTitle}&body=${encodedUrl}` },
];

const aiLinks = [
  { label: 'ChatGPT',    href: `https://chatgpt.com/?q=${prompt}` },
  { label: 'Claude',     href: `https://claude.ai/new?q=${prompt}` },
  { label: 'Perplexity', href: `https://perplexity.ai/?q=${prompt}` },
];
---

<aside class="post-actions-section" data-pagefind-ignore aria-label="Share and actions">

  <!-- Divider with label -->
  <div class="pa-divider">
    <span class="pa-divider-label">Share this article</span>
  </div>

  <!-- Platform share buttons -->
  <div class="pa-share-row">
    {shareLinks.map(({ icon, label, href }) => (
      <a href={href} target="_blank" rel="noopener noreferrer" class="pa-share-btn">
        <Icon name={icon} class="pa-share-icon" size={14} />
        <span>{label}</span>
      </a>
    ))}
  </div>

  <!-- AI + Copy row -->
  <div class="pa-secondary-row">
    <div class="pa-ai-group">
      <Icon name="sparkles" class="pa-section-icon" size={13} />
      {aiLinks.map(({ label, href }) => (
        <a href={href} target="_blank" rel="noopener noreferrer" class="pa-ai-btn">
          {label}
        </a>
      ))}
    </div>

    <button
      class="pa-copy-btn"
      data-md-path={mdPath}
      aria-label="Copy raw Markdown to clipboard"
      type="button"
    >
      <span class="pa-copy-icon-wrap">
        <Icon name="clipboard" class="pa-btn-icon" size={13} />
      </span>
      <span class="pa-check-icon-wrap" aria-hidden="true" style="display:none">
        <Icon name="check" class="pa-btn-icon" size={13} />
      </span>
      <span class="pa-copy-label">Copy Markdown</span>
    </button>
  </div>

</aside>

<style>
  .post-actions-section {
    margin-top: 3rem;
    padding-top: 0;
  }

  /* ── Divider ─────────────────────────────────────────────────── */
  .pa-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    color: rgb(var(--color-primary-400) / 1);
  }
  :global(.dark) .pa-divider {
    color: rgb(var(--color-primary-500) / 1);
  }
  .pa-divider::before,
  .pa-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgb(var(--color-primary-200) / 1);
  }
  :global(.dark) .pa-divider::before,
  :global(.dark) .pa-divider::after {
    background: rgb(var(--color-primary-700) / 1);
  }
  .pa-divider-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    white-space: nowrap;
    color: rgb(var(--color-primary-400) / 1);
  }
  :global(.dark) .pa-divider-label {
    color: rgb(var(--color-primary-500) / 1);
  }

  /* ── Share buttons row ──────────────────────────────────────── */
  .pa-share-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.625rem;
  }

  .pa-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    height: 1.875rem;
    padding: 0 0.625rem;
    border-radius: 999px;
    border: 1px solid rgb(var(--color-primary-200) / 1);
    background: transparent;
    color: rgb(var(--color-primary-500) / 1);
    font-size: 0.75rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.1s, border-color 0.1s, color 0.1s;
  }
  :global(.dark) .pa-share-btn {
    border-color: rgb(var(--color-primary-700) / 1);
    color: rgb(var(--color-primary-400) / 1);
  }
  .pa-share-btn:hover {
    background: rgb(var(--color-primary-100) / 1);
    border-color: rgb(var(--color-primary-300) / 1);
    color: rgb(var(--color-primary-700) / 1);
  }
  :global(.dark) .pa-share-btn:hover {
    background: rgb(var(--color-primary-800) / 1);
    border-color: rgb(var(--color-primary-600) / 1);
    color: rgb(var(--color-primary-200) / 1);
  }

  .pa-share-icon {
    flex-shrink: 0;
    opacity: 0.75;
  }

  /* ── Secondary row (AI + Copy) ──────────────────────────────── */
  .pa-secondary-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem;
  }

  .pa-ai-group {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  .pa-section-icon {
    color: rgb(var(--color-primary-400) / 1);
    flex-shrink: 0;
    margin-right: 0.125rem;
  }
  :global(.dark) .pa-section-icon {
    color: rgb(var(--color-primary-500) / 1);
  }

  /* AI buttons — slightly more muted than share, no icon */
  .pa-ai-btn {
    display: inline-flex;
    align-items: center;
    height: 1.875rem;
    padding: 0 0.625rem;
    border-radius: 999px;
    border: 1px solid rgb(var(--color-primary-200) / 1);
    background: transparent;
    color: rgb(var(--color-primary-500) / 1);
    font-size: 0.75rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.1s, border-color 0.1s, color 0.1s;
  }
  :global(.dark) .pa-ai-btn {
    border-color: rgb(var(--color-primary-700) / 1);
    color: rgb(var(--color-primary-400) / 1);
  }
  .pa-ai-btn:hover {
    background: rgb(var(--color-primary-100) / 1);
    border-color: rgb(var(--color-primary-300) / 1);
    color: rgb(var(--color-primary-700) / 1);
  }
  :global(.dark) .pa-ai-btn:hover {
    background: rgb(var(--color-primary-800) / 1);
    border-color: rgb(var(--color-primary-600) / 1);
    color: rgb(var(--color-primary-200) / 1);
  }

  /* Copy button */
  .pa-copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    height: 1.875rem;
    padding: 0 0.625rem;
    border-radius: 999px;
    border: 1px solid rgb(var(--color-primary-200) / 1);
    background: transparent;
    color: rgb(var(--color-primary-500) / 1);
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.1s, border-color 0.1s, color 0.1s;
    margin-left: auto; /* push to right in the secondary row */
  }
  :global(.dark) .pa-copy-btn {
    border-color: rgb(var(--color-primary-700) / 1);
    color: rgb(var(--color-primary-400) / 1);
  }
  .pa-copy-btn:hover {
    background: rgb(var(--color-primary-100) / 1);
    border-color: rgb(var(--color-primary-300) / 1);
    color: rgb(var(--color-primary-700) / 1);
  }
  :global(.dark) .pa-copy-btn:hover {
    background: rgb(var(--color-primary-800) / 1);
    border-color: rgb(var(--color-primary-600) / 1);
    color: rgb(var(--color-primary-200) / 1);
  }
  .pa-copy-btn.is-copied {
    color: rgb(var(--color-highlight-600) / 1);
    border-color: rgb(var(--color-highlight-300) / 1);
    background: rgb(var(--color-highlight-50) / 0.4);
  }
  :global(.dark) .pa-copy-btn.is-copied {
    color: rgb(var(--color-highlight-400) / 1);
    border-color: rgb(var(--color-highlight-700) / 1);
    background: rgb(var(--color-highlight-900) / 0.25);
  }

  .pa-btn-icon {
    flex-shrink: 0;
    opacity: 0.75;
  }
</style>

<script>
  function initializePageActions() {
    document.querySelectorAll<HTMLButtonElement>('.pa-copy-btn').forEach((btn) => {
      const fresh = btn.cloneNode(true) as HTMLButtonElement;
      btn.parentNode?.replaceChild(fresh, btn);

      const copyWrap  = fresh.querySelector<HTMLElement>('.pa-copy-icon-wrap');
      const checkWrap = fresh.querySelector<HTMLElement>('.pa-check-icon-wrap');
      const label     = fresh.querySelector<HTMLElement>('.pa-copy-label');
      let resetTimer: ReturnType<typeof setTimeout> | null = null;

      fresh.addEventListener('click', async () => {
        const mdPath = fresh.dataset.mdPath;
        if (!mdPath) return;
        try {
          const res = await fetch(mdPath);
          if (!res.ok) throw new Error(`${res.status}`);
          const text = await res.text();
          await navigator.clipboard.writeText(text);

          fresh.classList.add('is-copied');
          if (copyWrap)  copyWrap.style.display  = 'none';
          if (checkWrap) checkWrap.style.display = '';
          if (label)     label.textContent = 'Copied!';

          if (resetTimer) clearTimeout(resetTimer);
          resetTimer = setTimeout(() => {
            fresh.classList.remove('is-copied');
            if (copyWrap)  copyWrap.style.display  = '';
            if (checkWrap) checkWrap.style.display = 'none';
            if (label)     label.textContent = 'Copy Markdown';
            resetTimer = null;
          }, 2000);
        } catch (err) {
          if (import.meta.env.DEV) console.warn('[PageActions] copy failed:', err);
        }
      });
    });
  }

  (window as any).initializePageActions = initializePageActions;
  document.addEventListener('DOMContentLoaded', initializePageActions);
</script>
