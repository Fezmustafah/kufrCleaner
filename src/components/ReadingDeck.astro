---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import globalRefs from '@/data/global-refs.json';
import { optimizePostImagePath } from '@/utils/images';
import { siteConfig } from '@/config';
import '@/styles/reading-deck.css';

interface Props {
  post?: CollectionEntry<'posts'>;
  tldr?: CollectionEntry<'tldrs'>;
  // Standalone/demo mode (used when `post` is omitted, e.g. the homepage demo):
  // pass metadata explicitly and point the slides feed at a custom source element.
  title?: string;
  description?: string;
  coverImage?: string;
  id?: string;
  slidesSource?: string; // CSS selector for the slides source; posts default to #post-content
  hideEntry?: boolean; // suppress the built-in entry CTA (caller supplies its own [data-deck-open])
}

const { post, tldr, slidesSource, hideEntry } = Astro.props;

// Real posts gate the slides feed on the global Deep Read flag; a standalone
// deck (no `post`) exists solely to show its slides, so it's always on.
const hasSlides = post ? siteConfig.postOptions.readingDeck : true;
const hasTldr = Boolean(tldr?.body?.trim());

const postId = post?.id ?? Astro.props.id ?? 'deck';
const deckTitle = post?.data.title ?? Astro.props.title ?? '';
const deckDescription = post?.data.description ?? Astro.props.description ?? '';

const coverImageValue = post ? (post.data.banner || post.data.image || '') : '';
const coverImage = coverImageValue
  ? optimizePostImagePath(coverImageValue, post!.id, post!.id)
  : (Astro.props.coverImage ?? '');

let TldrContent: any = null;
if (hasTldr && tldr) {
  ({ Content: TldrContent } = await render(tldr));
}

const citationKeys = Array.from(new Set(
  Array.from(
    `${post?.body || ''}\n${tldr?.body || ''}`.matchAll(/\[@([a-zA-Z0-9_:.-]+)\]/g),
    (match) => match[1],
  ),
));

const citations = citationKeys
  .map((key, index) => {
    const ref = (globalRefs as Array<Record<string, unknown>>).find((entry) => entry.id === key);
    return ref ? { ...ref, number: index + 1 } : null;
  })
  .filter(Boolean) as Array<Record<string, unknown> & { number: number; id: string }>;

const citationText = (ref: Record<string, unknown>) => [
  ref.author,
  ref.title,
  ref.publisher,
  ref.year,
].filter(Boolean).join('. ');
---

{(hasSlides || hasTldr) && !hideEntry && (
  <section class="reading-deck-entry not-prose" data-pagefind-ignore aria-label="Alternate reading modes">
    <div class="reading-deck-entry-copy">
      <span class="reading-deck-entry-kicker">Choose your pace</span>
      <p>
        {hasTldr
          ? 'Get the argument quickly, or move through the full article one section at a time.'
          : 'Move through the full article one section at a time.'}
      </p>
    </div>
    <div class="reading-deck-entry-actions">
      {hasTldr && (
        <button type="button" class="reading-deck-entry-primary" data-deck-open="tldr">
          Start quick read
          <span aria-hidden="true">↗</span>
        </button>
      )}
      {hasSlides && (
        <button type="button" class="reading-deck-entry-secondary" data-deck-open="slides">
          Start deep read
          <span aria-hidden="true">→</span>
        </button>
      )}
    </div>
  </section>
)}

{(hasSlides || hasTldr) && (
  <>
    <dialog
      class="reading-deck"
      data-reading-deck
      data-pagefind-ignore
      data-post-id={postId}
      data-post-title={deckTitle}
      data-post-description={deckDescription}
      data-cover-image={coverImage}
      data-has-slides={String(hasSlides)}
      data-has-tldr={String(hasTldr)}
      data-deck-slides-source={slidesSource}
      aria-labelledby="reading-deck-title"
    >
      <div class="reading-deck-shell">
        <header class="reading-deck-topbar">
          <button type="button" class="reading-deck-back-button" data-deck-close aria-label="Go back to article" title="Go back to article">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M15 18l-6-6 6-6" />
            </svg>
            <span>Article</span>
          </button>

          <div class="reading-deck-heading">
            <h2 id="reading-deck-title" title={deckTitle}><span class="reading-deck-title-text">{deckTitle}</span><span class="reading-deck-title-caret" aria-hidden="true"></span></h2>
            {(hasSlides && hasTldr) && (
              <div class="reading-deck-switcher" role="group" aria-label="Reading mode">
                <span class="reading-deck-switcher-thumb" aria-hidden="true"></span>
                <button type="button" data-deck-feed="tldr"><span class="deck-mode-wide">TLDR view</span><span class="deck-mode-short">TLDR</span></button>
                <button type="button" data-deck-feed="slides"><span class="deck-mode-wide">Deep read</span><span class="deck-mode-short">Deep</span></button>
              </div>
            )}
            <span class:list={['reading-deck-mode', { 'sr-only': hasSlides && hasTldr }]} data-deck-mode-label>Reading deck</span>
          </div>

          <div class="reading-deck-site-actions" aria-label="Site tools">
            <button type="button" class="reading-deck-icon-button" data-deck-search aria-label="Search the wiki" title="Search the wiki">
              <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg>
            </button>
            <button type="button" class="reading-deck-icon-button" data-deck-menu aria-label="Open site menu" title="Open site menu">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
            </button>
          </div>
        </header>

        <div class="reading-deck-progress" data-deck-progress aria-label="Deck progress">
        </div>

        <main class="reading-deck-stage" data-deck-stage>
          <div class="reading-deck-track" data-deck-track></div>
          <div class="reading-deck-hud" data-deck-hud aria-hidden="true">
            <span class="reading-deck-hud-title" data-deck-hud-title></span>
            <span class="reading-deck-hud-count" data-deck-hud-count></span>
          </div>
          <div class="reading-deck-rail" data-deck-rail aria-hidden="true">
            <span class="reading-deck-rail-fill" data-deck-rail-fill></span>
          </div>
          <button type="button" class="reading-deck-nudge" data-deck-nudge aria-label="Next section">
            <svg viewBox="0 0 30 24" aria-hidden="true"><path d="M2 12h22M18 6l6 6-6 6" /></svg>
          </button>
          <button type="button" class="reading-deck-neighbor reading-deck-neighbor--previous" data-deck-neighbor="-1" aria-label="Go to previous card"></button>
          <button type="button" class="reading-deck-neighbor reading-deck-neighbor--next" data-deck-neighbor="1" aria-label="Go to next card"></button>
          <div class="reading-deck-scroll-shadow" data-deck-scroll-shadow hidden aria-hidden="true"></div>
          <p class="reading-deck-swipe-hint" data-deck-swipe-hint hidden aria-hidden="true">
            Swipe to continue <span aria-hidden="true">→</span>
          </p>

          <section class="reading-deck-finish" data-deck-finish hidden aria-labelledby="reading-deck-finish-title">
            <div class="reading-deck-finish-card">
              <span class="reading-deck-finish-mark" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M5 4.5A2.5 2.5 0 0 1 7.5 2H19v17H7.5A2.5 2.5 0 0 0 5 21.5z"/><path d="M5 4.5v17M9 7h6M9 11h4"/></svg>
              </span>
              <span class="reading-deck-finish-kicker">Deck complete</span>
              <h3 id="reading-deck-finish-title" data-deck-finish-title>You reached the end</h3>
              <p data-deck-finish-copy>The complete argument is now in view.</p>
              <div class="reading-deck-finish-actions">
                <button type="button" class="reading-deck-finish-primary" data-deck-finish-primary data-deck-action="article">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                  <span data-deck-finish-primary-label>Back to article</span>
                </button>
                <button type="button" data-deck-action="share">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="18" cy="5" r="2.5"/><circle cx="6" cy="12" r="2.5"/><circle cx="18" cy="19" r="2.5"/><path d="m8.2 10.8 7.6-4.5M8.2 13.2l7.6 4.5"/></svg>
                  <span>Share</span>
                </button>
                <button type="button" data-deck-action="restart">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4v6h6"/><path d="M5.5 15a7 7 0 1 0 .9-7.9L4 10"/></svg>
                  <span>Start over</span>
                </button>
              </div>
            </div>
          </section>
        </main>

        <p class="sr-only" aria-live="polite" aria-atomic="true" data-deck-status></p>

        <footer class="reading-deck-controls">
          <button type="button" data-deck-prev>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
            <span>Previous</span>
          </button>
          <button type="button" class="reading-deck-position" data-deck-index-open aria-label="Open deck contents">
            <span class="reading-deck-position-icon" aria-hidden="true">
              <i></i><i></i><i></i>
            </span>
            <span class="reading-deck-position-copy">
              <small><span data-deck-position>1 / 1</span> · <span data-deck-card-title>Overview</span></small>
            </span>
          </button>
          <button type="button" data-deck-next>
            <span>Next</span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
          </button>
        </footer>
      </div>

      <section class="reading-deck-overlay" data-deck-index hidden role="dialog" aria-modal="true" aria-labelledby="reading-deck-index-title">
        <div class="reading-deck-overlay-panel reading-deck-index-panel">
          <header>
            <div>
              <span>Navigate</span>
              <h3 id="reading-deck-index-title">Contents</h3>
            </div>
            <button type="button" class="reading-deck-icon-button" data-deck-index-close aria-label="Close card index">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" /></svg>
            </button>
          </header>
          <ol data-deck-index-list></ol>
        </div>
      </section>

      <aside
        class="reading-deck-note-popover"
        data-deck-source-panel
        hidden
        role="dialog"
        aria-modal="false"
        aria-label="Reference note"
        tabindex="-1"
      >
        <div class="prose dark:prose-dark" data-deck-source-content></div>
      </aside>

      <section class="reading-deck-overlay reading-deck-image-overlay" data-deck-image-panel hidden role="dialog" aria-modal="true" aria-label="Expanded image">
        <button type="button" class="reading-deck-icon-button reading-deck-image-close" data-deck-image-close aria-label="Close expanded image">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" /></svg>
        </button>
        <img data-deck-image alt="" />
      </section>
    </dialog>

    {hasTldr && TldrContent && (
      <template data-deck-source-template="tldr">
        <div class="prose dark:prose-dark" data-deck-source-root="tldr">
          <TldrContent />
        </div>
      </template>
    )}

    {citations.length > 0 && (
      <template data-deck-citation-template>
        <section class="deck-citation-registry" aria-labelledby="deck-citation-heading">
          <h2 id="deck-citation-heading">Bibliography</h2>
          <ol>
            {citations.map((ref) => (
              <li id={`ref-${ref.id}`} data-citation-id={ref.id}>
                <span>{citationText(ref)}</span>
                {ref.doi && <a href={`https://doi.org/${ref.doi}`}>DOI</a>}
                {!ref.doi && ref.url && <a href={String(ref.url)}>Source</a>}
              </li>
            ))}
          </ol>
        </section>
      </template>
    )}
  </>
)}
