---
import type { CollectionEntry } from 'astro:content';
import { formatDate, isValidDate } from '../utils/markdown';
import { normalizeStatus, getStatusClasses, getStatusDisplayText, hasStatusStyling } from '../utils/status';
import Icon from './Icon.astro';

interface Props {
  manuscript: CollectionEntry<'manuscripts'>;
  eager?: boolean;
}

const { manuscript } = Astro.props;

const {
  title,
  subtitle,
  abstract,
  authors,
  date,
  type,
  status: rawStatus,
  tags,
  doi,
  url,
  pdf,
  publishedIn,
  volume,
  issue,
  pages,
  references,
} = manuscript.data;

const status = normalizeStatus(rawStatus ?? 'draft');
const displayDate = isValidDate(date) ? formatDate(date) : '';
const authorList = Array.isArray(authors) ? authors : authors ? [authors] : [];
const displayAuthors = authorList.length > 3
  ? `${authorList.slice(0, 2).join(', ')} et al.`
  : authorList.join(', ');

const typeLabels: Record<string, string> = {
  essay: 'Essay',
  paper: 'Paper',
  'research-note': 'Research Note',
  review: 'Review',
  preprint: 'Preprint',
  other: 'Manuscript',
};
const typeLabel = typeLabels[type ?? 'essay'] ?? 'Manuscript';

const venueStr = [publishedIn, volume ? `vol. ${volume}` : null, issue ? `no. ${issue}` : null, pages ? `pp. ${pages}` : null]
  .filter(Boolean).join(', ');

const refCount = references?.length ?? 0;
const href = `/manuscripts/${manuscript.id}/`;

const doiHref = doi ? `https://doi.org/${doi}` : null;
const pdfHref = pdf ? `/manuscripts/${pdf}` : null;
---

<!-- Stretched-link card: outer div is position:relative, title <a> stretches via ::after -->
<div class="group relative border border-primary-200 dark:border-primary-700 rounded-lg overflow-hidden hover:border-primary-400 dark:hover:border-primary-500 transition-all duration-200 bg-white dark:bg-primary-900 hover:shadow-md">
  <!-- Card header bar -->
  <div class="flex items-center justify-between px-4 py-2 bg-primary-50 dark:bg-primary-800 border-b border-primary-200 dark:border-primary-700">
    <span class="font-mono text-xs text-highlight-600 dark:text-highlight-400 font-semibold tracking-wider uppercase">
      {typeLabel}
    </span>
    <span class="text-xs text-primary-400 dark:text-primary-500">{displayDate}</span>
  </div>

  <!-- Card body -->
  <div class="p-5">
    <!-- Title — stretched link via ::after covers entire card -->
    <h2 class="text-base font-bold text-primary-900 dark:text-primary-50 group-hover:text-highlight-700 dark:group-hover:text-highlight-400 transition-colors leading-snug mb-1">
      <a href={href} class="stretched-link">
        {title}
      </a>
    </h2>
    {subtitle && (
      <p class="text-sm italic text-primary-500 dark:text-primary-400 mb-2">{subtitle}</p>
    )}

    <!-- Authors -->
    {displayAuthors && (
      <p class="text-xs text-primary-600 dark:text-primary-300 mb-3">{displayAuthors}</p>
    )}

    <!-- Venue / journal -->
    {venueStr && (
      <p class="text-xs text-primary-500 dark:text-primary-400 italic mb-3">{venueStr}</p>
    )}

    <!-- Abstract preview -->
    {abstract && (
      <p class="text-sm text-primary-700 dark:text-primary-300 line-clamp-3 leading-relaxed mb-4">
        {abstract}
      </p>
    )}

    <!-- Status + ref count -->
    <div class="flex items-center gap-2 mb-3 flex-wrap">
      {hasStatusStyling(status) && (
        <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${getStatusClasses(status)}`}>
          {getStatusDisplayText(status)}
        </span>
      )}
      {refCount > 0 && (
        <span class="text-xs text-primary-400 dark:text-primary-500">
          {refCount} reference{refCount !== 1 ? 's' : ''}
        </span>
      )}
    </div>

    <!-- Tags -->
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-1 mb-4">
        {tags.slice(0, 5).map(tag => (
          <span class="text-xs px-2 py-0.5 rounded-full bg-primary-100 dark:bg-primary-800 text-primary-600 dark:text-primary-300">
            #{tag}
          </span>
        ))}
      </div>
    )}

    <!-- External links — z-index above stretched link so they remain clickable -->
    <div class="relative z-10 flex items-center gap-3 mt-auto pt-1">
      {doiHref && (
        <a
          href={doiHref}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-xs text-highlight-600 dark:text-highlight-400 hover:underline"
        >
          <Icon name="external-link" class="w-3 h-3" />
          DOI
        </a>
      )}
      {url && !doi && (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-xs text-highlight-600 dark:text-highlight-400 hover:underline"
        >
          <Icon name="external-link" class="w-3 h-3" />
          Read
        </a>
      )}
      {pdfHref && (
        <a
          href={pdfHref}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-xs text-primary-500 dark:text-primary-400 hover:underline"
        >
          <Icon name="file-text" class="w-3 h-3" />
          PDF
        </a>
      )}
    </div>
  </div>
</div>

<style>
  /* Stretched link: ::after covers entire card, z-index below explicit z-10 elements */
  :global(.stretched-link::after) {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 1;
    content: "";
  }
</style>
