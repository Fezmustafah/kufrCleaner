---
export interface Props { currentSlug?: string; }
const { currentSlug } = Astro.props;
---

<div class="local-graph-widget">
  <!-- Canvas + overlaid buttons (all inside the graph window) -->
  <div class="graph-canvas-outer" id="local-graph-body">
    <div id="local-graph-canvas" class="graph-canvas"></div>
    <div class="graph-overlay-btns" id="graph-overlay-btns">
      <!-- Global graph -->
      <button id="local-graph-global-btn" class="g-btn" title="Open global graph" aria-label="Open global graph">
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/>
          <line x1="12" y1="7" x2="5" y2="17"/><line x1="12" y1="7" x2="19" y2="17"/>
        </svg>
      </button>
      <!-- Fullscreen -->
      <button id="local-graph-fullscreen-btn" class="g-btn" title="Expand" aria-label="Expand graph">
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/>
          <line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>
        </svg>
      </button>
      <!-- Collapse -->
      <button id="local-graph-toggle-btn" class="g-btn" title="Collapse" aria-expanded="true" aria-label="Collapse graph">
        <svg class="graph-chevron" xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="18 15 12 9 6 15"/>
        </svg>
      </button>
    </div>
  </div>
  <!-- Shown only when collapsed — lets the user re-expand -->
  <button class="graph-expand-handle" id="local-graph-expand-btn" aria-label="Show graph" title="Show graph">
    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
    <span>Graph</span>
  </button>
</div>

<!-- Script extracted to /src/scripts/local-graph-client.ts and imported globally
     from BaseLayout so it loads on every page (works around Astro+Swup
     reloadScripts:false: per-component scripts that aren't on the initial page
     never run after Swup nav). The init function no-ops when #local-graph-canvas
     is not in the DOM. -->

<style>
  .local-graph-widget { width: 100%; }

  /* ── Canvas + overlaid buttons ───────────────────────────────────────── */
  .graph-canvas-outer { position: relative; width: 100%; }
  .graph-canvas { width: 100%; border-radius: 0.25rem; overflow: hidden; }
  .graph-canvas svg { display: block; }

  /* Buttons overlaid on top-right of the canvas */
  .graph-overlay-btns {
    position: absolute;
    top: 4px;
    right: 4px;
    display: flex;
    gap: 2px;
    opacity: 0;
    transition: opacity 0.15s ease;
    pointer-events: none;
  }
  .graph-canvas-outer:hover .graph-overlay-btns {
    opacity: 1;
    pointer-events: auto;
  }

  .g-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background: rgb(var(--color-primary-50) / 0.9);
    border: none;
    border-radius: 0.2rem;
    cursor: pointer;
    color: rgb(var(--color-primary-500));
    backdrop-filter: blur(2px);
    transition: color 0.12s, background-color 0.12s;
    line-height: 0;
  }
  .g-btn:hover {
    color: rgb(var(--color-highlight-600));
    background: rgb(var(--color-primary-100));
  }
  :global(.dark) .g-btn {
    background: rgb(var(--color-primary-900) / 0.9);
    color: rgb(var(--color-primary-400));
  }
  :global(.dark) .g-btn:hover {
    color: rgb(var(--color-highlight-400));
    background: rgb(var(--color-primary-800));
  }

  .graph-chevron { transition: transform 0.2s ease; }
  .local-graph-widget.is-collapsed .graph-canvas-outer { display: none; }
  .local-graph-widget.is-collapsed .graph-chevron { transform: rotate(180deg); }

  /* ── Expand handle (visible only when collapsed) ─────────────────────── */
  .graph-expand-handle {
    display: none;
    align-items: center;
    gap: 0.3rem;
    background: none;
    border: none;
    cursor: pointer;
    color: rgb(var(--color-primary-400));
    font-size: 0.72rem;
    padding: 0.2rem 0.1rem;
    transition: color 0.15s;
  }
  .graph-expand-handle:hover { color: rgb(var(--color-highlight-600)); }
  :global(.dark) .graph-expand-handle:hover { color: rgb(var(--color-highlight-400)); }
  .local-graph-widget.is-collapsed .graph-expand-handle { display: flex; }

  .graph-error {
    font-size: 0.72rem; color: rgb(var(--color-primary-400));
    text-align: center; padding: 0.5rem; margin: 0;
  }

  /* ── Fullscreen overlay ──────────────────────────────────────────────── */
  :global(.lg-fs-overlay) {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(0,0,0,0.55); backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
  }
  :global(.lg-fs-box) {
    background: rgb(var(--color-primary-50));
    border-radius: 0.75rem; padding: 0.5rem;
    box-shadow: 0 12px 48px rgba(0,0,0,0.3);
  }
  :global(.dark .lg-fs-box) { background: rgb(var(--color-primary-900)); }

  :global(.lg-fs-toolbar) {
    display: flex; justify-content: flex-end; gap: 0.25rem;
    margin-bottom: 0.375rem;
  }
  :global(.lg-fs-gbtn), :global(.lg-fs-close) {
    display: flex; align-items: center; justify-content: center;
    width: 26px; height: 26px;
    background: none; border: none; cursor: pointer; border-radius: 0.25rem;
    color: rgb(var(--color-primary-500));
    transition: color 0.12s, background-color 0.12s;
  }
  :global(.lg-fs-gbtn:hover), :global(.lg-fs-close:hover) {
    color: rgb(var(--color-highlight-600));
    background: rgb(var(--color-primary-100) / 0.8);
  }
  :global(.lg-fs-canvas) { border-radius: 0.5rem; overflow: hidden; }
</style>
