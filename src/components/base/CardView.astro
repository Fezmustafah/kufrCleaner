---
import type { Note } from '@/utils/bases/types';
import type { BaseView } from '@/utils/bases/types';
import { getPropertyValue, formatPropertyValue } from '@/utils/bases/filter';
import { getOptimizedFormat } from '@/utils/images';
import { getTagTitleMap, tagTitle } from '@/utils/tag-titles';
import ImageWrapper from '@/components/ImageWrapper.astro';
import Icon from '@/components/Icon.astro';

interface Props {
  notes: Note[];
  view: BaseView;
  imageUrlMap?: Record<string, string>;
}

const { notes, view, imageUrlMap = {} } = Astro.props;
const tagTitles = await getTagTitleMap();
const cardSize = view.cardSize || 260;
const imageAspectRatio = view.imageAspectRatio || 0.75;
const imageFit = view.imageFit || 'cover';
const propertyOrder = view.order || ['file.name'];

function getPropertyLabel(propertyName: string): string {
  if (propertyName.startsWith('file.')) {
    const name = propertyName.substring(5);
    return name.charAt(0).toUpperCase() + name.slice(1);
  }
  return propertyName.charAt(0).toUpperCase() + propertyName.slice(1);
}

function resolveImage(note: Note): { src: string; basePath: string } | null {
  // Prefer imageUrlMap (pre-resolved by the page)
  if (imageUrlMap[note.id]) {
    const url = imageUrlMap[note.id];
    return url.startsWith('http') ? { src: url, basePath: '' } : { src: url, basePath: '' };
  }

  if (!view.image || !note.data[view.image]) return null;

  let raw = String(note.data[view.image]);

  // Strip Obsidian wikilink brackets
  if (raw.startsWith('[[') && raw.endsWith(']]')) {
    raw = raw.slice(2, -2);
  }

  // External URL — use as-is
  if (raw.startsWith('http')) {
    return { src: raw, basePath: '' };
  }

  // Local: attachments/ prefix → shared attachments folder
  if (raw.startsWith('attachments/')) {
    const filename = raw.replace('attachments/', '');
    return { src: getOptimizedFormat(filename), basePath: '/posts/attachments/' };
  }

  // Local: folder-based post image
  return { src: getOptimizedFormat(raw), basePath: `/posts/${note.id}/` };
}
---

{notes.length === 0 ? (
  <div class="empty-state">
    <p>No posts match the current filters.</p>
  </div>
) : (
  <div class="cards-grid" style={`column-width: ${cardSize}px;`}>
    {notes.map(note => {
      const imgResolved = resolveImage(note);
      return (
        <div class="card">
          {imgResolved && (
            <div class="card-image" style={`aspect-ratio: 1 / ${imageAspectRatio};`}>
              <ImageWrapper
                src={imgResolved.src}
                basePath={imgResolved.basePath}
                alt=""
                class="card-img"
                width={600}
                height={Math.round(600 * imageAspectRatio)}
                format="webp"
                quality={85}
                loading="lazy"
              />
            </div>
          )}
          <div class="card-body">
            {propertyOrder.map(propertyName => {
              const value = getPropertyValue(note, propertyName);
              const formatted = formatPropertyValue(value);

              if (propertyName === 'file.name') {
                return (
                  <a href={`${import.meta.env.BASE_URL}posts/${note.id}`} class="card-title">
                    {note.data.title || formatted || note.id}
                  </a>
                );
              }

              if (propertyName === 'file.tags' || propertyName === 'tags') {
                return Array.isArray(value) && value.length > 0 ? (
                  <div class="card-tags">
                    {value.map((tag: string) => (
                      <span class="tag-chip">
                        <Icon name="tag" class="w-2.5 h-2.5 opacity-70" />
                        {tagTitle(tagTitles, tag)}
                      </span>
                    ))}
                  </div>
                ) : null;
              }

              if (value !== null && value !== undefined && value !== '') {
                return (
                  <div class="card-prop">
                    <span class="card-prop-label">{getPropertyLabel(propertyName)}:</span>{' '}
                    <span class="card-prop-value">{formatted}</span>
                  </div>
                );
              }

              return null;
            })}
          </div>
        </div>
      );
    })}
  </div>
)}

<style>
  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: rgb(var(--color-primary-400));
    font-style: italic;
  }

  .cards-grid {
    column-gap: 1rem;
    width: 100%;
    padding: 1rem 0;
  }

  /* Card surface matches .post-card (global.css): shadow-sm → md plus the
     Andalusian gold border-left hover accent — one card language platform-wide */
  .card {
    break-inside: avoid;
    margin-bottom: 1rem;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid rgb(var(--color-primary-200));
    border-left: 2px solid transparent;
    background: rgb(var(--color-primary-50));
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .card:hover {
    border-left-color: rgb(var(--color-highlight-400) / 0.55);
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
  }

  .card-image {
    width: 100%;
    overflow: hidden;
    background: rgb(var(--color-primary-100));
  }

  /* ImageWrapper renders in a child component so scoped styles don't reach it — use :global */
  .card-image :global(.card-img) {
    width: 100%;
    height: 100%;
  }

  .card-image :global(.card-img img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    color: rgb(var(--color-highlight-600));
    text-decoration: none;
    display: block;
    line-height: 1.3;
  }

  .card-title:hover {
    color: rgb(var(--color-highlight-700));
    text-decoration: underline;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  /* Tag pills use the shared .tag-chip class (global.css) */

  .card-prop {
    font-size: 0.875rem;
    color: rgb(var(--color-primary-500));
  }

  .card-prop-label { font-weight: 500; }
  .card-prop-value { color: rgb(var(--color-primary-600)); }
</style>
