---
import SiteGraph from '@/components/SiteGraph.astro';
import '@/styles/global.css';
import { siteConfig } from '@/config';
---
<!DOCTYPE html>
<html
  lang="en"
  data-theme-config={siteConfig.theme}
  data-custom-theme-file={siteConfig.customThemeFile ?? ''}
  data-available-themes={JSON.stringify(siteConfig.availableThemes)}
>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Graph</title>
  <script is:inline>
    // Apply theme before first paint to avoid flash
    const _p = new URLSearchParams(location.search);
    if (_p.get('theme') === 'dark') document.documentElement.classList.add('dark');
  </script>
</head>
<body style="margin:0;padding:0;overflow:hidden;">
  <div style="position:fixed;inset:0;">
    <SiteGraph mode="modal" currentSlug="" />
  </div>
  <script>
    // Sync theme changes from parent window
    window.addEventListener('message', (e) => {
      if (e.data?.type === 'set-theme') {
        document.documentElement.classList.toggle('dark', !!e.data.dark);
      }
    });
  </script>
</body>
</html>
