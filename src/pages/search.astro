---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Icon from '@/components/Icon.astro';
import { siteConfig } from '@/config';
import { shouldShowPost } from '@/utils/markdown';
import { getTagTitleMap, tagTitle } from '@/utils/tag-titles';

const query = Astro.url.searchParams.get('q') || '';
const pageTitle = query ? `Search: "${query}"` : 'Search';

const seoData = {
  title: `${pageTitle} | ${siteConfig.title}`,
  description: 'Search all posts and content',
  canonical: Astro.url.href,
  ogType: 'website' as const,
};

// Empty-state affordances: live article count + most-used tags as entry points.
const isDev = import.meta.env.DEV;
const posts = (await getCollection('posts')).filter(post => shouldShowPost(post, isDev));
const tagTitles = await getTagTitleMap();
const tagCounts = new Map<string, number>();
for (const p of posts) for (const t of p.data.tags ?? []) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
const popularTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8).map(([t]) => t);
---

<BaseLayout seoData={seoData}>
  <div data-pagefind-ignore class="max-w-5xl mx-auto px-4 lg:px-0">

    <!--
      Centering shell: flex column that fills the viewport vertically when no results are
      showing, so the search bar appears centered. JS collapses it when results appear.
    -->
    <div id="search-shell" class="flex flex-col" style="min-height: calc(100vh - 5rem)">

      <!--
        Search header: no sticky by default (centred layout).
        JS applies position:sticky / top:3.5rem / z-index:20 when results appear,
        and removes them when the input is cleared.
      -->
      <div id="search-header" class="bg-white dark:bg-primary-950 pt-8 pb-3 w-full">

        <!-- Intro (fades out when results appear) — same identity system as the homepage hero -->
        <div id="search-intro" class="text-center mb-7">
          <p class="search-kicker">A Scholarly Reference</p>
          <h1 class="search-title">Search the archive</h1>
          <p class="search-sub">{posts.length.toLocaleString()} articles — sourced, cited, and indexed in full</p>
        </div>

        <!-- Search form — single surface; the input itself is chromeless (see global.css §Search) -->
        <form id="search-form" action={`${import.meta.env.BASE_URL}search/`} method="get">
          <div class="search-field">
            <Icon name="search" class="w-4 h-4 shrink-0 text-highlight-500/70 dark:text-highlight-400/70" />
            <input
              type="text"
              name="q"
              id="search-query"
              value={query}
              placeholder="Search the archive… (#tag to filter)"
              autocomplete="off"
              autofocus
            />
            <button
              id="search-clear"
              type="button"
              aria-label="Clear search"
              class="hidden p-1 rounded text-primary-400 hover:text-primary-600 dark:hover:text-primary-200 transition-colors"
            >
              <Icon name="x" class="w-4 h-4" />
            </button>
          </div>
        </form>

        <!-- Status + filter toggle -->
        <div class="flex items-center justify-between mt-2 min-h-[1.5rem]">
          <p id="search-status" class="text-sm text-primary-500 dark:text-primary-400 hidden"></p>
          <div class="flex items-center gap-1.5">
            <!-- Clear button — shown when filters active, sits next to Filters toggle -->
            <button id="filter-clear-outer" style="display:none"
                    class="inline-flex items-center gap-1 text-xs font-medium px-2 py-1 rounded-lg border border-primary-200 dark:border-primary-700 text-primary-500 dark:text-primary-400 hover:border-highlight-500 hover:text-highlight-600 dark:hover:text-highlight-400 transition-colors">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              Clear<span id="filter-clear-count" class="tabular-nums"></span>
            </button>
            <button id="filter-toggle"
                    style="display:none"
                    class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1.5 rounded-lg border border-primary-200 dark:border-primary-700 text-primary-600 dark:text-primary-300 hover:border-primary-400 dark:hover:border-primary-500 hover:text-primary-900 dark:hover:text-primary-50 transition-colors"
                    aria-expanded="false"
                    aria-controls="filter-bar">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" x2="4" y1="21" y2="14"/><line x1="4" x2="4" y1="10" y2="3"/><line x1="12" x2="12" y1="21" y2="12"/><line x1="12" x2="12" y1="8" y2="3"/><line x1="20" x2="20" y1="21" y2="16"/><line x1="20" x2="20" y1="12" y2="3"/><line x1="1" x2="7" y1="14" y2="14"/><line x1="9" x2="15" y1="8" y2="8"/><line x1="17" x2="23" y1="16" y2="16"/></svg>
              Filters
              <span id="filter-badge" style="display:none" class="ml-0.5 min-w-[1.25rem] text-center px-1 py-0.5 text-xs font-semibold bg-highlight-500 text-white rounded-full leading-none tabular-nums"></span>
            </button>
          </div>
        </div>

        <!-- Filter bar -->
        <div id="filter-bar" class="hidden mt-3"></div>

      </div><!-- /search-header -->

      <!-- Empty / pre-search state (inside shell so it contributes to vertical centering) -->
      <div id="search-empty" class="flex-1 pt-10 pb-16">
        <div class="max-w-2xl mx-auto text-center px-2">
          <p class="search-hint-label">Start from a popular topic</p>
          <div class="flex flex-wrap justify-center gap-1.5 mb-8">
            {popularTags.map(t => (
              <a href={`${import.meta.env.BASE_URL}posts/tag/${encodeURIComponent(t)}/`} class="tag-chip">
                <Icon name="tag" class="w-2.5 h-2.5 opacity-70" />
                {tagTitle(tagTitles, t)}
              </a>
            ))}
          </div>
          <p class="search-kbd-hints">
            <span><kbd>#tag</kbd> filters by tag</span>
            <span class="hidden sm:inline"><kbd>↑↓</kbd> move · <kbd>↵</kbd> open</span>
            <span class="hidden md:inline">hover a result to preview</span>
          </p>
          <a href={`${import.meta.env.BASE_URL}posts/`} class="search-browse-all">or browse all {posts.length.toLocaleString()} articles <span aria-hidden="true">→</span></a>
        </div>
      </div>

    </div><!-- /search-shell -->

    <!-- Split pane (outside the centering shell) -->
    <div id="search-pane" class="hidden rounded-lg border border-primary-200 dark:border-primary-700 overflow-hidden shadow-sm" style="height: 68vh; min-height: 400px;">
      <div class="flex h-full">
        <div id="search-results" class="w-full md:w-72 md:min-w-[18rem] overflow-y-auto border-r border-primary-200 dark:border-primary-700 bg-white dark:bg-primary-900 flex-shrink-0"></div>
        <div class="hidden md:flex flex-1 flex-col overflow-hidden bg-white dark:bg-primary-900">
          <div id="preview-content" class="flex-1 overflow-y-auto p-6">
            <p class="text-primary-400 dark:text-primary-500 text-center mt-20 text-sm">Select a result to preview</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Curated tag titles for search-client.ts (renders results via innerHTML) -->
    <script is:inline type="application/json" id="tag-title-data" set:html={JSON.stringify(Object.fromEntries(tagTitles))}></script>

  </div>

  <!--
    Mobile bottom sheet — inside BaseLayout so Swup replaces it on navigation.
    z-[55]/z-[60] sit above the fixed nav (z-50) so the backdrop actually blocks nav clicks.
  -->
  <div id="mobile-sheet-backdrop"
       class="fixed inset-0 z-[55] bg-black/50 backdrop-blur-sm hidden"
       aria-hidden="true"></div>
  <div id="mobile-sheet"
       class="fixed inset-x-0 bottom-0 z-[60] rounded-t-2xl bg-white dark:bg-primary-900 shadow-2xl border-t border-primary-200 dark:border-primary-700 transition-transform duration-300 ease-out translate-y-full md:hidden"
       style="max-height: 80vh;"
       role="dialog"
       aria-modal="true"
       aria-label="Post preview">
    <div class="relative flex items-center justify-between px-5 pt-5 pb-3 border-b border-primary-200 dark:border-primary-700">
      <div class="absolute left-1/2 -translate-x-1/2 top-2 w-10 h-1 rounded-full bg-primary-300 dark:bg-primary-600"></div>
      <span class="text-sm font-medium text-primary-900 dark:text-primary-50">Preview</span>
      <button id="mobile-sheet-close"
              class="p-1 rounded text-primary-400 hover:text-primary-600 dark:hover:text-primary-200 transition-colors"
              aria-label="Close preview">
        <Icon name="x" class="w-4 h-4" />
      </button>
    </div>
    <div id="mobile-sheet-content" class="overflow-y-auto p-5" style="max-height: calc(80vh - 57px);"></div>
  </div>
</BaseLayout>

<!-- Behaviour lives in /src/scripts/search-client.ts, loaded globally from
     BaseLayout: a page-inline script would never run when this page is reached
     via Swup nav (e.g. from the search palette's "Advanced search" link).
     Page chrome CSS lives in global.css §Search page — results/preview markup is
     injected via innerHTML, which Astro-scoped styles can never reach. -->
