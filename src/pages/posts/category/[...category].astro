---
import type { GetStaticPaths } from 'astro';
import { getCollection, getEntry, render } from 'astro:content';
import { siteConfig } from '@/config';
import { shouldShowPost, sortPostsByDate, extractCategories } from '@/utils/markdown';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Pagination from '@/components/Pagination.astro';
import Icon from '@/components/Icon.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const isDev = import.meta.env.DEV;

  try {
    const allPosts = await getCollection('posts');
    const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));
    const sortedPosts = sortPostsByDate(visiblePosts);
    const allCategories = extractCategories(sortedPosts);

    return allCategories.map(category => ({
      params: { category },
      props: { category, allPosts: sortedPosts }
    }));
  } catch (error) {
    return [];
  }
};

const { category, allPosts } = Astro.props as {
  category: string;
  allPosts: any[];
};
const isDev = import.meta.env.DEV;

if (!category || typeof category !== 'string') {
  if (!isDev) return Astro.redirect('/404');
}

// Load optional category entry (banner image, description)
let categoryEntry: any = null;
let CategoryContent: any = null;
try {
  categoryEntry = await getEntry('categories', category);
  if (categoryEntry) {
    const rendered = await render(categoryEntry);
    CategoryContent = rendered.Content;
  }
} catch (_) {}

const filteredPosts = allPosts.filter((post: any) => {
  const cat = post.data.category;
  return cat && typeof cat === 'string' && cat.trim() === category.trim();
});

const postsPerPage = siteConfig.postOptions.postsPerPage;
const totalPosts = filteredPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const currentPage = 1;
const paginatedPosts = filteredPosts.slice(0, postsPerPage);

const categoryDisplayTitle = categoryEntry?.data.title || category;
const categoryDescription = categoryEntry?.data.description || null;
const coverImage = categoryEntry?.data.image || null;
const coverImageAlt = categoryEntry?.data.imageAlt || categoryDisplayTitle;

const seoData = {
  title: `${categoryDisplayTitle} | ${siteConfig.title}`,
  description: categoryDescription || `All posts in the "${category}" category`,
  canonical: Astro.url.href,
  ogType: 'website' as const
};

const baseUrl = `${import.meta.env.BASE_URL}posts/category/${encodeURIComponent(category)}`;
const pagination = {
  currentPage,
  totalPages,
  hasNext: currentPage < totalPages,
  hasPrev: false,
  nextUrl: totalPages > 1 ? `${baseUrl}/2` : undefined,
  prevUrl: undefined
};
---

<BaseLayout seoData={seoData}>
  <div class="py-8">
    <div class="cat-moc-grid" style={`--contentWidth: ${siteConfig.layout.contentWidth}`}>

      <article class="moc-article bg-primary-50 dark:bg-primary-900 rounded-lg border border-primary-200 dark:border-primary-700 shadow-sm overflow-hidden">

        <!-- Banner: cover image or gradient fallback -->
        {coverImage && coverImage !== '' ? (
          <div class="moc-banner">
            <img
              src={coverImage}
              alt={coverImageAlt}
              class="w-full h-full object-cover object-center"
              loading="eager"
              fetchpriority="high"
            />
            <div class="moc-banner-overlay" />
          </div>
        ) : (
          <div class="moc-banner moc-banner--gradient" />
        )}

        <!-- Header -->
        <div class="px-6 pt-6 pb-4 border-b border-primary-200 dark:border-primary-700">
          <div class="flex items-center gap-2 mb-3">
            <a
              href={`${import.meta.env.BASE_URL}posts/category`}
              class="inline-flex items-center text-sm text-primary-500 dark:text-primary-400 hover:text-highlight-600 dark:hover:text-highlight-400 transition-colors"
            >
              <Icon name="book-open" class="w-3 h-3 mr-1 opacity-70" />
              All categories
            </a>
          </div>

          <h1 class="text-3xl font-bold text-primary-900 dark:text-primary-50 mb-3 leading-tight">
            {categoryDisplayTitle}
          </h1>

          {categoryDescription && (
            <p class="text-base text-primary-600 dark:text-primary-300 max-w-prose leading-relaxed mb-3">
              {categoryDescription}
            </p>
          )}

          <span class="text-sm font-medium text-primary-500 dark:text-primary-400">
            {totalPosts === 1 ? '1 post' : `${totalPosts} posts`}
          </span>
        </div>

        <!-- Prose body from category file -->
        {CategoryContent && (
          <div class="px-6 py-6 border-b border-primary-200 dark:border-primary-700">
            <div class="prose dark:prose-dark max-w-none">
              <CategoryContent />
            </div>
          </div>
        )}

        <!-- Post card grid -->
        <div class="p-6">
          {paginatedPosts.length > 0 ? (
            <>
              <div class="posts-cards-grid">
                {paginatedPosts.map((post: any, index: number) => (
                  <PostCard post={post} context="posts" eager={index < 4} />
                ))}
              </div>
              <div class="mt-8">
                <Pagination pagination={pagination} baseUrl={baseUrl} />
              </div>
            </>
          ) : (
            <div class="text-center py-12">
              <Icon name="book-open" class="w-10 h-10 text-primary-300 dark:text-primary-600 mx-auto mb-3" />
              <p class="text-base text-primary-500 dark:text-primary-400">No posts in this category.</p>
            </div>
          )}
        </div>

      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .cat-moc-grid {
    display: grid;
    grid-template-columns: minmax(0, var(--contentWidth));
    justify-content: center;
    padding: 0 1rem;
  }

  .moc-article { min-width: 0; }

  .moc-banner {
    width: 100%;
    height: clamp(180px, 28vw, 380px);
    overflow: hidden;
    position: relative;
  }

  .moc-banner--gradient {
    background: linear-gradient(135deg, #e5e7eb 0%, #f3f4f6 100%);
  }

  :global(.dark) .moc-banner--gradient {
    background: linear-gradient(135deg, #1e2939 0%, #273549 100%);
  }

  .moc-banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.08) 100%);
    pointer-events: none;
  }

  @media (min-width: 1280px) {
    .cat-moc-grid { padding: 0 1.5rem; }
  }
</style>
