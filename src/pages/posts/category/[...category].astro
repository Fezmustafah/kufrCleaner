---
import type { GetStaticPaths } from 'astro';
import { getCollection, getEntry, render } from 'astro:content';
import { siteConfig } from '@/config';
import { shouldShowPost, sortPostsByDate, extractCategories } from '@/utils/markdown';
import { topicSlug, categoryDisplayName } from '@/utils/topics';
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopicBanner from '@/components/TopicBanner.astro';
import PostCard from '@/components/PostCard.astro';
import Pagination from '@/components/Pagination.astro';
import Icon from '@/components/Icon.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const isDev = import.meta.env.DEV;

  try {
    const allPosts = await getCollection('posts');
    const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));
    const sortedPosts = sortPostsByDate(visiblePosts);
    const allCategories = extractCategories(sortedPosts);

    return allCategories.map(category => ({
      params: { category },
      props: { category, allPosts: sortedPosts }
    }));
  } catch (error) {
    return [];
  }
};

const { category, allPosts } = Astro.props as {
  category: string;
  allPosts: any[];
};
const isDev = import.meta.env.DEV;
const baseUrl = import.meta.env.BASE_URL;

if (!category || typeof category !== 'string') {
  if (!isDev) return Astro.redirect('/404');
}

// Load the optional category entry (description, cover image, MOC body).
// Entry ids are slugified by Astro's glob loader, so slugify the raw value to match.
let categoryEntry: any = null;
let CategoryContent: any = null;
try {
  categoryEntry = await getEntry('categories', topicSlug(category));
  if (categoryEntry) {
    const rendered = await render(categoryEntry);
    CategoryContent = rendered.Content;
  }
} catch (_) {}

const filteredPosts = allPosts.filter((post: any) => {
  const cat = post.data.category;
  return cat && typeof cat === 'string' && cat.trim() === category.trim();
});

const postsPerPage = siteConfig.postOptions.postsPerPage;
const totalPosts = filteredPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const currentPage = 1;
const paginatedPosts = filteredPosts.slice(0, postsPerPage);

const categoryDisplayTitle = categoryEntry?.data.title || categoryDisplayName(category);
const categoryDescription = categoryEntry?.data.description || null;
const coverImage = categoryEntry?.data.image || null;
const coverImageAlt = categoryEntry?.data.imageAlt || categoryDisplayTitle;

const seoData = {
  title: `${categoryDisplayTitle} | ${siteConfig.title}`,
  description: categoryDescription || `All posts in the "${category}" category`,
  canonical: Astro.url.href,
  ogType: 'website' as const
};

const listBaseUrl = `${baseUrl}posts/category/${encodeURIComponent(category)}`;
const pagination = {
  currentPage,
  totalPages,
  hasNext: currentPage < totalPages,
  hasPrev: false,
  nextUrl: totalPages > 1 ? `${listBaseUrl}/2/` : undefined,
  prevUrl: undefined
};
---

<BaseLayout seoData={seoData}>
  <div class="cat-single" style={`--contentWidth: ${siteConfig.layout.contentWidth}`}>

    <nav class="cat-back">
      <a href={`${baseUrl}posts/category/`}>
        <Icon name="chevron-left" class="w-3.5 h-3.5" />
        All topics
      </a>
    </nav>

    <!-- Banner hero: entry image or al-andalus arabesque, title overlaid -->
    <header class="cat-hero">
      <TopicBanner name={categoryDisplayTitle} image={coverImage} imageAlt={coverImageAlt} eager={true} />
      <div class="cat-hero-content">
        <p class="cat-hero-kicker">Topic</p>
        <h1 class="cat-hero-title">{categoryDisplayTitle}</h1>
        {categoryDescription && <p class="cat-hero-desc">{categoryDescription}</p>}
        <span class="cat-hero-count">{totalPosts === 1 ? '1 article' : `${totalPosts.toLocaleString()} articles`}</span>
      </div>
    </header>

    <!-- Optional MOC prose from the category entry -->
    {CategoryContent && (
      <div class="cat-moc prose dark:prose-invert max-w-none">
        <CategoryContent />
      </div>
    )}

    <!-- Posts -->
    {paginatedPosts.length > 0 ? (
      <>
        <div class="posts-cards-grid">
          {paginatedPosts.map((post: any, index: number) => (
            <PostCard post={post} context="posts" eager={index < 4} />
          ))}
        </div>
        <div class="cat-pagination">
          <Pagination pagination={pagination} baseUrl={listBaseUrl} />
        </div>
      </>
    ) : (
      <div class="cat-empty">
        <Icon name="book-open" class="w-9 h-9" />
        <p>No posts in this topic yet.</p>
      </div>
    )}

  </div>
</BaseLayout>

<style>
  .cat-single {
    max-width: var(--contentWidth, 65rem);
    margin: 0 auto;
    padding: 1.5rem 1rem 3.5rem;
  }
  @media (min-width: 1280px) { .cat-single { padding-left: 1.5rem; padding-right: 1.5rem; } }

  /* ── Back link ── */
  .cat-back { margin-bottom: 0.9rem; }
  .cat-back a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-prose, serif);
    font-size: 0.85rem;
    color: rgb(var(--color-primary-500));
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .cat-back a:hover { color: rgb(var(--color-highlight-600)); }
  :global(.dark) .cat-back a { color: rgb(var(--color-primary-400)); }
  :global(.dark) .cat-back a:hover { color: rgb(var(--color-highlight-400)); }

  /* ── Banner hero ── */
  .cat-hero {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
    min-height: clamp(220px, 34vw, 400px);
    border: 1px solid rgb(var(--color-highlight-500) / 0.2);
    display: flex;
  }
  .cat-hero-content {
    position: relative;
    z-index: 1;
    align-self: flex-end;
    padding: clamp(1.25rem, 3.5vw, 2.5rem);
    max-width: 52rem;
  }
  .cat-hero-kicker {
    font-family: var(--font-prose, serif);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgb(var(--color-highlight-300));
    margin: 0 0 0.55rem;
  }
  .cat-hero-title {
    font-family: var(--font-heading, serif);
    font-size: clamp(2rem, 5.5vw, 3.4rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.04;
    color: rgb(var(--color-primary-50));
    margin: 0;
    text-wrap: balance;
  }
  .cat-hero-desc {
    font-family: var(--font-prose, serif);
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    line-height: 1.6;
    color: rgb(var(--color-primary-200));
    margin: 0.85rem 0 0;
    max-width: 46rem;
    text-wrap: pretty;
  }
  .cat-hero-count {
    display: inline-block;
    font-family: var(--font-prose, serif);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--color-primary-100));
    margin-top: 1.1rem;
    padding: 0.32rem 0.7rem;
    border: 1px solid rgb(var(--color-highlight-400) / 0.4);
    border-radius: 999px;
    background: rgb(0 0 0 / 0.25);
    backdrop-filter: blur(4px);
  }

  /* ── MOC prose ── */
  .cat-moc {
    margin: 2rem 0 0.5rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid rgb(var(--color-primary-200));
  }
  :global(.dark) .cat-moc { border-bottom-color: rgb(var(--color-primary-800)); }

  /* ── Posts ── */
  .posts-cards-grid { margin-top: 2rem; }
  .cat-pagination { margin-top: 2.5rem; }

  .cat-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
    padding: 4rem 0;
    color: rgb(var(--color-primary-500));
    font-family: var(--font-prose, serif);
  }
  :global(.dark) .cat-empty { color: rgb(var(--color-primary-400)); }
</style>
