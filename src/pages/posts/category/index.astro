---
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { shouldShowPost, sortPostsByDate } from '@/utils/markdown';
import { topicSlug, categoryDisplayName } from '@/utils/topics';
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopicTile from '@/components/TopicTile.astro';

const isDev = import.meta.env.DEV;
const baseUrl = import.meta.env.BASE_URL;

const allPosts = await getCollection('posts');
const visiblePosts = sortPostsByDate(allPosts.filter(post => shouldShowPost(post, isDev)));

// Post counts per category (skip empties + the "Test" placeholder)
const counts = new Map<string, number>();
for (const post of visiblePosts) {
  const cat = (post.data as any).category;
  if (typeof cat === 'string' && cat.trim() && cat.trim().toLowerCase() !== 'test') {
    const key = cat.trim();
    counts.set(key, (counts.get(key) || 0) + 1);
  }
}

// Merge in each category's description/image entry (keyed by slug id)
const catEntries = await getCollection('categories');
const entryBySlug = new Map(catEntries.map(e => [e.id, e.data]));

const categories = Array.from(counts.entries())
  .map(([raw, count]) => {
    const entry = entryBySlug.get(topicSlug(raw));
    return {
      raw,
      count,
      title: entry?.title || categoryDisplayName(raw),
      description: entry?.description || '',
      image: entry?.image || null,
      imageAlt: entry?.imageAlt || entry?.title || raw,
      url: `${baseUrl}posts/category/${encodeURIComponent(raw)}/`,
    };
  })
  .sort((a, b) => b.count - a.count);

const featured = categories.slice(0, 2);
const rest = categories.slice(2);
const totalPosts = categories.reduce((n, c) => n + c.count, 0);

const seoData = {
  title: `Topics | ${siteConfig.title}`,
  description: `Browse ${categories.length} topics across ${totalPosts.toLocaleString()} articles.`,
  canonical: Astro.url.href,
  ogType: 'website' as const,
};
---

<BaseLayout seoData={seoData}>
  <div class="cat-index">

    <header class="cat-head">
      <p class="cat-kicker">Browse the library</p>
      <h1 class="cat-title">Topics</h1>
      <p class="cat-sub">{categories.length} areas of study · {totalPosts.toLocaleString()} articles</p>
    </header>

    {categories.length > 0 ? (
      <>
        {featured.length > 0 && (
          <div class="cat-featured">
            {featured.map((c) => (
              <TopicTile
                href={c.url}
                name={c.title}
                label={c.title}
                count={c.count}
                description={c.description}
                image={c.image}
                imageAlt={c.imageAlt}
                large={true}
                eager={true}
              />
            ))}
          </div>
        )}

        {rest.length > 0 && (
          <div class="cat-rest">
            {rest.map((c) => (
              <TopicTile
                href={c.url}
                name={c.title}
                label={c.title}
                count={c.count}
                description={c.description}
                image={c.image}
                imageAlt={c.imageAlt}
              />
            ))}
          </div>
        )}
      </>
    ) : (
      <p class="cat-empty">No topics found.</p>
    )}

  </div>
</BaseLayout>

<style>
  /* Full-bleed: break out of <main>'s contentWidth cap to span the viewport.
     Safe because body has overflow-x: clip (global.css). */
  .cat-index {
    position: relative;
    left: 50%;
    right: 50%;
    width: 100vw;
    margin-left: -50vw;
    margin-right: -50vw;
    padding: 2.5rem clamp(1rem, 4vw, 3.5rem) 3.5rem;
  }

  /* ── Header ── */
  .cat-head { margin-bottom: 1.75rem; }
  .cat-kicker {
    font-family: var(--font-prose, serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(var(--color-highlight-600));
    margin: 0 0 0.5rem;
  }
  :global(.dark) .cat-kicker { color: rgb(var(--color-highlight-400)); }
  .cat-title {
    font-family: var(--font-heading, serif);
    font-size: clamp(2rem, 5vw, 2.9rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.05;
    color: rgb(var(--color-primary-900));
    margin: 0 0 0.4rem;
  }
  :global(.dark) .cat-title { color: rgb(var(--color-primary-50)); }
  .cat-sub {
    font-family: var(--font-prose, serif);
    font-size: 0.95rem;
    color: rgb(var(--color-primary-500));
    margin: 0;
  }
  :global(.dark) .cat-sub { color: rgb(var(--color-primary-400)); }

  /* ── Grids (tiles size themselves via TopicTile) ── */
  .cat-featured {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  @media (min-width: 720px) { .cat-featured { grid-template-columns: 1.9fr 1fr; } }

  .cat-rest {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 520px) { .cat-rest { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .cat-rest { grid-template-columns: repeat(3, 1fr); } }
  /* keep tiles a sane size once the grid bleeds full-width */
  @media (min-width: 1400px) { .cat-rest { grid-template-columns: repeat(4, 1fr); } }
  @media (min-width: 1900px) { .cat-rest { grid-template-columns: repeat(5, 1fr); } }

  .cat-empty {
    font-family: var(--font-prose, serif);
    text-align: center;
    color: rgb(var(--color-primary-500));
    padding: 4rem 0;
  }
</style>
