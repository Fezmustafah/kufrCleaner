---
import type { GetStaticPaths } from 'astro';
import { getCollection, getEntry } from 'astro:content';
import { siteConfig } from '@/config';
import { shouldShowPost, sortPostsByDate, extractCategories } from '@/utils/markdown';
import { topicSlug } from '@/utils/topics';
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopicBanner from '@/components/TopicBanner.astro';
import PostCard from '@/components/PostCard.astro';
import Pagination from '@/components/Pagination.astro';
import Icon from '@/components/Icon.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const isDev = import.meta.env.DEV;

  try {
    const allPosts = await getCollection('posts');
    const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));
    const sortedPosts = sortPostsByDate(visiblePosts);
    const allCategories = extractCategories(sortedPosts);
    const postsPerPage = siteConfig.postOptions.postsPerPage;
    const paths: any[] = [];

    for (const category of allCategories) {
      const categoryPosts = sortedPosts.filter((post: any) => {
        const cat = post.data.category;
        return cat && typeof cat === 'string' && cat.trim() === category.trim();
      });
      const totalPages = Math.ceil(categoryPosts.length / postsPerPage);

      for (let page = 2; page <= totalPages; page++) {
        paths.push({
          params: { category, page: page.toString() },
          props: { category, allPosts: sortedPosts, currentPage: page }
        });
      }
    }

    return paths;
  } catch (error) {
    return [];
  }
};

const { category, allPosts, currentPage } = Astro.props as {
  category: string;
  allPosts: any[];
  currentPage: number;
};
const isDev = import.meta.env.DEV;
const baseUrl = import.meta.env.BASE_URL;

if (!category || typeof category !== 'string') {
  if (!isDev) return Astro.redirect('/404');
}

// Load optional category entry (slugified id — see @/utils/topics)
let categoryEntry: any = null;
try {
  categoryEntry = await getEntry('categories', topicSlug(category));
} catch (_) {}

const filteredPosts = allPosts.filter((post: any) => {
  const cat = post.data.category;
  return cat && typeof cat === 'string' && cat.trim() === category.trim();
});

const postsPerPage = siteConfig.postOptions.postsPerPage;
const totalPosts = filteredPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const startIndex = (currentPage - 1) * postsPerPage;
const paginatedPosts = filteredPosts.slice(startIndex, startIndex + postsPerPage);

const categoryDisplayTitle = categoryEntry?.data.title || category;
const coverImage = categoryEntry?.data.image || null;
const coverImageAlt = categoryEntry?.data.imageAlt || categoryDisplayTitle;

const seoData = {
  title: `${categoryDisplayTitle} — Page ${currentPage} | ${siteConfig.title}`,
  description: categoryEntry?.data.description || `Page ${currentPage} of posts in the "${category}" category`,
  canonical: Astro.url.href,
  ogType: 'website' as const
};

const listBaseUrl = `${baseUrl}posts/category/${encodeURIComponent(category)}`;
const pagination = {
  currentPage,
  totalPages,
  hasNext: currentPage < totalPages,
  hasPrev: currentPage > 1,
  nextUrl: currentPage < totalPages ? `${listBaseUrl}/${currentPage + 1}` : undefined,
  prevUrl: currentPage > 1 ? (currentPage === 2 ? listBaseUrl : `${listBaseUrl}/${currentPage - 1}`) : undefined
};
---

<BaseLayout seoData={seoData}>
  <div class="cat-single" style={`--contentWidth: ${siteConfig.layout.contentWidth}`}>

    <nav class="cat-back">
      <a href={listBaseUrl}>
        <Icon name="chevron-left" class="w-3.5 h-3.5" />
        {categoryDisplayTitle}
      </a>
    </nav>

    <!-- Compact banner hero for pages 2+ -->
    <header class="cat-hero cat-hero--compact">
      <TopicBanner name={categoryDisplayTitle} image={coverImage} imageAlt={coverImageAlt} eager={true} />
      <div class="cat-hero-content">
        <p class="cat-hero-kicker">Topic · Page {currentPage} of {totalPages}</p>
        <h1 class="cat-hero-title">{categoryDisplayTitle}</h1>
      </div>
    </header>

    <div class="posts-cards-grid">
      {paginatedPosts.map((post: any, index: number) => (
        <PostCard post={post} context="posts" eager={index < 4} />
      ))}
    </div>
    <div class="cat-pagination">
      <Pagination pagination={pagination} baseUrl={listBaseUrl} />
    </div>

  </div>
</BaseLayout>

<style>
  .cat-single {
    max-width: var(--contentWidth, 65rem);
    margin: 0 auto;
    padding: 1.5rem 1rem 3.5rem;
  }
  @media (min-width: 1280px) { .cat-single { padding-left: 1.5rem; padding-right: 1.5rem; } }

  .cat-back { margin-bottom: 0.9rem; }
  .cat-back a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-prose, serif);
    font-size: 0.85rem;
    color: rgb(var(--color-primary-500));
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .cat-back a:hover { color: rgb(var(--color-highlight-600)); }
  :global(.dark) .cat-back a { color: rgb(var(--color-primary-400)); }
  :global(.dark) .cat-back a:hover { color: rgb(var(--color-highlight-400)); }

  .cat-hero {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid rgb(var(--color-highlight-500) / 0.2);
    display: flex;
  }
  .cat-hero--compact { min-height: clamp(140px, 20vw, 230px); }
  .cat-hero-content {
    position: relative;
    z-index: 1;
    align-self: flex-end;
    padding: clamp(1.1rem, 3vw, 1.9rem);
    max-width: 52rem;
  }
  .cat-hero-kicker {
    font-family: var(--font-prose, serif);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(var(--color-highlight-300));
    margin: 0 0 0.45rem;
  }
  .cat-hero-title {
    font-family: var(--font-heading, serif);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.05;
    color: rgb(var(--color-primary-50));
    margin: 0;
    text-wrap: balance;
  }

  .posts-cards-grid { margin-top: 2rem; }
  .cat-pagination { margin-top: 2.5rem; }
</style>
