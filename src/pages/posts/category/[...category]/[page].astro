---
import type { GetStaticPaths } from 'astro';
import { getCollection, getEntry } from 'astro:content';
import { siteConfig } from '@/config';
import { shouldShowPost, sortPostsByDate, extractCategories } from '@/utils/markdown';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Pagination from '@/components/Pagination.astro';
import Icon from '@/components/Icon.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const isDev = import.meta.env.DEV;

  try {
    const allPosts = await getCollection('posts');
    const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));
    const sortedPosts = sortPostsByDate(visiblePosts);
    const allCategories = extractCategories(sortedPosts);
    const postsPerPage = siteConfig.postOptions.postsPerPage;
    const paths: any[] = [];

    for (const category of allCategories) {
      const categoryPosts = sortedPosts.filter((post: any) => {
        const cat = post.data.category;
        return cat && typeof cat === 'string' && cat.trim() === category.trim();
      });
      const totalPages = Math.ceil(categoryPosts.length / postsPerPage);

      for (let page = 2; page <= totalPages; page++) {
        paths.push({
          params: { category, page: page.toString() },
          props: { category, allPosts: sortedPosts, currentPage: page }
        });
      }
    }

    return paths;
  } catch (error) {
    return [];
  }
};

const { category, allPosts, currentPage } = Astro.props as {
  category: string;
  allPosts: any[];
  currentPage: number;
};
const isDev = import.meta.env.DEV;

if (!category || typeof category !== 'string') {
  if (!isDev) return Astro.redirect('/404');
}

// Load optional category entry for title/image
let categoryEntry: any = null;
try {
  categoryEntry = await getEntry('categories', category);
} catch (_) {}

const filteredPosts = allPosts.filter((post: any) => {
  const cat = post.data.category;
  return cat && typeof cat === 'string' && cat.trim() === category.trim();
});

const postsPerPage = siteConfig.postOptions.postsPerPage;
const totalPosts = filteredPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const startIndex = (currentPage - 1) * postsPerPage;
const paginatedPosts = filteredPosts.slice(startIndex, startIndex + postsPerPage);

const categoryDisplayTitle = categoryEntry?.data.title || category;
const coverImage = categoryEntry?.data.image || null;
const coverImageAlt = categoryEntry?.data.imageAlt || categoryDisplayTitle;

const seoData = {
  title: `${categoryDisplayTitle} — Page ${currentPage} | ${siteConfig.title}`,
  description: categoryEntry?.data.description || `Page ${currentPage} of posts in the "${category}" category`,
  canonical: Astro.url.href,
  ogType: 'website' as const
};

const baseUrl = `${import.meta.env.BASE_URL}posts/category/${encodeURIComponent(category)}`;
const pagination = {
  currentPage,
  totalPages,
  hasNext: currentPage < totalPages,
  hasPrev: currentPage > 1,
  nextUrl: currentPage < totalPages ? `${baseUrl}/${currentPage + 1}` : undefined,
  prevUrl: currentPage > 1 ? (currentPage === 2 ? baseUrl : `${baseUrl}/${currentPage - 1}`) : undefined
};
---

<BaseLayout seoData={seoData}>
  <div class="py-8">
    <div class="cat-moc-grid" style={`--contentWidth: ${siteConfig.layout.contentWidth}`}>

      <article class="moc-article bg-primary-50 dark:bg-primary-900 rounded-lg border border-primary-200 dark:border-primary-700 shadow-sm overflow-hidden">

        <!-- Compact banner for pages 2+ -->
        {coverImage && coverImage !== '' ? (
          <div class="moc-banner-compact">
            <img
              src={coverImage}
              alt={coverImageAlt}
              class="w-full h-full object-cover object-center"
              loading="eager"
            />
            <div class="moc-banner-overlay" />
          </div>
        ) : (
          <div class="moc-banner-compact moc-banner--gradient" />
        )}

        <!-- Header -->
        <div class="px-6 pt-5 pb-4 border-b border-primary-200 dark:border-primary-700">
          <div class="flex items-center gap-3 mb-2">
            <a
              href={baseUrl}
              class="inline-flex items-center text-sm text-primary-500 dark:text-primary-400 hover:text-highlight-600 dark:hover:text-highlight-400 transition-colors"
            >
              <Icon name="arrow-left" class="w-3 h-3 mr-1" />
              {categoryDisplayTitle}
            </a>
            <span class="text-primary-300 dark:text-primary-600 text-xs">·</span>
            <span class="text-sm text-primary-500 dark:text-primary-400">
              Page {currentPage} of {totalPages}
            </span>
          </div>
          <h1 class="text-2xl font-bold text-primary-900 dark:text-primary-50 leading-tight">
            {categoryDisplayTitle}
          </h1>
        </div>

        <!-- Card grid -->
        <div class="p-6">
          <div class="posts-cards-grid">
            {paginatedPosts.map((post: any, index: number) => (
              <PostCard post={post} context="posts" eager={index < 4} />
            ))}
          </div>
          <div class="mt-8">
            <Pagination pagination={pagination} baseUrl={baseUrl} />
          </div>
        </div>

      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .cat-moc-grid {
    display: grid;
    grid-template-columns: minmax(0, var(--contentWidth));
    justify-content: center;
    padding: 0 1rem;
  }

  .moc-article { min-width: 0; }

  .moc-banner-compact {
    width: 100%;
    height: clamp(80px, 12vw, 160px);
    overflow: hidden;
    position: relative;
  }

  .moc-banner--gradient {
    background: linear-gradient(135deg, #e5e7eb 0%, #f3f4f6 100%);
  }

  :global(.dark) .moc-banner--gradient {
    background: linear-gradient(135deg, #1e2939 0%, #273549 100%);
  }

  .moc-banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.08) 100%);
    pointer-events: none;
  }

  @media (min-width: 1280px) {
    .cat-moc-grid { padding: 0 1.5rem; }
  }
</style>
