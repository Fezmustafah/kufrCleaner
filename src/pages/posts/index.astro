---
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { generatePageSEO } from '@/utils/seo';
import { shouldShowPost, sortPostsByDate } from '@/utils/markdown';
import { optimizePostImagePath } from '@/utils/images';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Icon from '@/components/Icon.astro';

// Get special content for posts page
let postsPageContent;
try {
  postsPageContent = await getCollection('special', ({ slug }) => slug === 'posts');
} catch (error) {
  // Fallback if special collection doesn't exist or posts.md doesn't exist
  postsPageContent = [];
}

const postsPageData = postsPageContent.length > 0 ? postsPageContent[0] : null;

// Get query parameters
const url = new URL(Astro.request.url);
const selectedTag = url.searchParams.get('tag');

// Get all posts
const allPosts = await getCollection('posts');

// Filter posts based on environment
const isDev = import.meta.env.DEV;
const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));

// Sort posts by date (newest first)
const sortedPosts = sortPostsByDate(visiblePosts);

// Filter by tag if specified
const filteredPosts = selectedTag
  ? sortedPosts.filter(post => post.data.tags?.includes(selectedTag))
  : sortedPosts;

// Sorting + client-side "load more": render ALL posts, reveal in batches via JS
// (posts-sort-client.ts). Default order = newest first (already sorted above).
const postsPerPage = siteConfig.postOptions.postsPerPage;
const totalPosts = filteredPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const nextPageUrl = `${import.meta.env.BASE_URL}posts/2`;


// Generate SEO data
const pageTitle = selectedTag
  ? `Posts tagged "${selectedTag}"`
  : (postsPageData?.data.title || 'All Posts');
const pageDescription = selectedTag
  ? `All posts tagged with "${selectedTag}"`
  : (postsPageData?.data.description || `Browse all ${totalPosts} posts on ${siteConfig.title}`);

const seoData = {
  title: `${pageTitle} | ${siteConfig.title}`,
  description: pageDescription,
  canonical: Astro.url.href,
  ogType: 'website' as const
};

---

<BaseLayout seoData={seoData}>
  <Fragment slot="head">
    {filteredPosts.length > 0 && (() => {
      const firstPost = filteredPosts[0];
      if (!firstPost.data.image || typeof firstPost.data.image === 'string' && firstPost.data.image.startsWith('http')) return null;
      const showCoverImages = siteConfig.postOptions.showPostCardCoverImages;
      const shouldShowCoverImage = ['all', 'posts', 'featured-and-posts'].includes(showCoverImages);
      return shouldShowCoverImage ? (
        <link rel="preload" as="image" href={optimizePostImagePath(firstPost.data.image, undefined, firstPost.id)} fetchpriority="high" />
      ) : null;
    })()}
  </Fragment>

  <div class="py-8">
    <div class="mx-auto px-4 sm:px-6" style={`max-width: ${siteConfig.layout.contentWidth}`}>

      <header class="mb-6">
        <h1 class="text-3xl font-bold text-primary-900 dark:text-primary-50 mb-1">
          {pageTitle}
        </h1>
        <p class="text-base text-primary-500 dark:text-primary-400">
          {selectedTag ? (
            <>Showing <strong>{filteredPosts.length}</strong> posts tagged <span class="inline-flex items-center px-2 py-0.5 bg-highlight-100 dark:bg-highlight-900/30 text-highlight-800 dark:text-highlight-200 rounded text-sm font-medium ml-1">#{selectedTag}</span></>
          ) : (
            <>Explore all <strong>{totalPosts}</strong> posts</>
          )}
        </p>
        {selectedTag && (
          <a href={`${import.meta.env.BASE_URL}posts`} class="inline-flex items-center mt-3 text-sm text-primary-500 dark:text-primary-400 hover:text-primary-800 dark:hover:text-primary-200 transition-colors">
            <Icon name="arrow-left" class="w-4 h-4 mr-1" />Show all posts
          </a>
        )}
      </header>

      {filteredPosts.length > 0 ? (
        <div data-posts-sort-root data-batch={postsPerPage}>
          {/* Sort control */}
          <div class="flex items-center justify-end gap-2 mb-4">
            <label for="posts-sort" class="text-sm text-primary-500 dark:text-primary-400">Sort</label>
            <select
              id="posts-sort"
              data-sort-select
              class="text-sm rounded-md border border-primary-200 dark:border-primary-700 bg-white dark:bg-primary-900 text-primary-800 dark:text-primary-100 px-2 py-1.5 focus:outline-none focus:ring-2 focus:ring-highlight-500 cursor-pointer"
            >
              <option value="newest">Newest</option>
              <option value="updated">Newly updated</option>
              <option value="longest">Longest → shortest</option>
              <option value="shortest">Shortest → longest</option>
              <option value="az">Title A–Z</option>
              <option value="za">Title Z–A</option>
            </select>
          </div>

          <div class="posts-cards-grid mb-8">
            {filteredPosts.map((post, index) => {
              const _d = post.data.date instanceof Date ? post.data.date : new Date(post.data.date);
              const _m = post.data.modified ? new Date(post.data.modified) : _d;
              return (
                <div
                  class={`post-item${index >= postsPerPage ? ' is-hidden' : ''}`}
                  data-date={_d.getTime()}
                  data-modified={_m.getTime()}
                  data-length={(post.body || '').length}
                  data-title={(post.data.title || '').toLowerCase()}
                >
                  <PostCard post={post} eager={index < 2} context="posts" />
                </div>
              );
            })}
          </div>

          {totalPosts > postsPerPage && (
            <div class="flex justify-center mb-8">
              <button type="button" data-load-more class="btn-primary px-5 py-2 rounded-md text-sm font-medium">
                Load more
              </button>
            </div>
          )}

          <noscript>
            <div class="flex justify-center mb-8">
              <a href={nextPageUrl} class="text-highlight-600 dark:text-highlight-400 hover:underline">More posts →</a>
            </div>
          </noscript>
        </div>
      ) : selectedTag ? (
        <div class="text-center py-16">
          <Icon name="tag" class="w-12 h-12 text-primary-300 dark:text-primary-600 mx-auto mb-4" />
          <p class="text-primary-500 dark:text-primary-400">No posts tagged "{selectedTag}". <a href={`${import.meta.env.BASE_URL}posts`} class="hover:underline">View all posts</a>.</p>
        </div>
      ) : (
        <div class="text-center py-16">
          <Icon name="file-text" class="w-12 h-12 text-primary-300 dark:text-primary-600 mx-auto mb-4" />
          <p class="text-primary-500 dark:text-primary-400">No posts yet.</p>
        </div>
      )}

    </div>
  </div>

  <style>
    /* Wrappers carry sort-key data attributes but stay out of layout so the
       PostCard <article> remains the real grid item. */
    .post-item { display: contents; }
    .post-item.is-hidden { display: none; }
  </style>
</BaseLayout>
