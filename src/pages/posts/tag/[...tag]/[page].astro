---
import type { GetStaticPaths } from 'astro';
import { getCollection, getEntry } from 'astro:content';
import { siteConfig } from '@/config';
import { shouldShowPost, sortPostsByDate, extractTags } from '@/utils/markdown';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Pagination from '@/components/Pagination.astro';
import Icon from '@/components/Icon.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const isDev = import.meta.env.DEV;
  const allPosts = await getCollection('posts');
  const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));
  const sortedPosts = sortPostsByDate(visiblePosts);
  const allTags = extractTags(sortedPosts);
  const postsPerPage = siteConfig.postOptions.postsPerPage;
  const paths: any[] = [];

  for (const tag of allTags) {
    const tagPosts = sortedPosts.filter((post: any) => {
      if (!post.data.tags) return false;
      const postTags = Array.isArray(post.data.tags) ? post.data.tags : [post.data.tags];
      return postTags.some((t: any) => t && typeof t === 'string' && t.trim() === tag.trim());
    });
    const totalPages = Math.ceil(tagPosts.length / postsPerPage);
    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: { tag, page: page.toString() },
        props: { tag, allPosts: sortedPosts, currentPage: page }
      });
    }
  }

  return paths;
};

const { tag, allPosts, currentPage } = Astro.props as {
  tag: string;
  allPosts: any[];
  currentPage: number;
};

const isDev = import.meta.env.DEV;
if (!tag && !isDev) return Astro.redirect('/404');

// Optional tag entry for title/image
let tagEntry: any = null;
try {
  tagEntry = await getEntry('tags', tag);
} catch (_) {}

const filteredPosts = allPosts.filter((post: any) => {
  if (!post.data.tags) return false;
  const postTags = Array.isArray(post.data.tags) ? post.data.tags : [post.data.tags];
  return postTags.some((t: any) => t && typeof t === 'string' && t.trim() === tag.trim());
});

const postsPerPage = siteConfig.postOptions.postsPerPage;
const totalPosts = filteredPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const startIndex = (currentPage - 1) * postsPerPage;
const paginatedPosts = filteredPosts.slice(startIndex, startIndex + postsPerPage);

const tagDisplayTitle = tagEntry?.data.title || tag;
const coverImage = tagEntry?.data.image || null;
const coverImageAlt = tagEntry?.data.imageAlt || tagDisplayTitle;

const seoData = {
  title: `${tagDisplayTitle} — Page ${currentPage} | ${siteConfig.title}`,
  description: tagEntry?.data.description || `Posts tagged with "${tag}" — page ${currentPage}`,
  canonical: Astro.url.href,
  ogType: 'website' as const
};

const baseUrl = `/posts/tag/${encodeURIComponent(tag)}`;
const pagination = {
  currentPage,
  totalPages,
  hasNext: currentPage < totalPages,
  hasPrev: currentPage > 1,
  nextUrl: currentPage < totalPages ? `${baseUrl}/${currentPage + 1}` : undefined,
  prevUrl: currentPage > 1 ? (currentPage === 2 ? baseUrl : `${baseUrl}/${currentPage - 1}`) : undefined
};
---

<BaseLayout seoData={seoData}>
  <div class="py-8">
    <div class="tag-moc-grid" style={`--contentWidth: ${siteConfig.layout.contentWidth}`}>

      <Breadcrumbs
        postId={`tag/${tag}`}
        title={tagDisplayTitle}
        class="moc-breadcrumb mb-4"
      />

      <article class="moc-article bg-primary-50 dark:bg-primary-900 rounded-lg border border-primary-200 dark:border-primary-700 shadow-sm overflow-hidden">

        <!-- Compact banner for pages 2+ -->
        {coverImage && coverImage !== '' ? (
          <div class="moc-banner-compact">
            <img
              src={coverImage}
              alt={coverImageAlt}
              class="w-full h-full object-cover object-center"
              loading="eager"
            />
            <div class="moc-banner-overlay" />
          </div>
        ) : (
          <div class="moc-banner-compact moc-banner--gradient" />
        )}

        <!-- Header -->
        <div class="px-6 pt-5 pb-4 border-b border-primary-200 dark:border-primary-700">
          <div class="flex items-center gap-3 mb-2">
            <a
              href={baseUrl}
              class="inline-flex items-center text-xs text-primary-500 dark:text-primary-400 hover:text-highlight-600 dark:hover:text-highlight-400 transition-colors"
            >
              <Icon name="arrow-left" class="w-3 h-3 mr-1" />
              #{tagDisplayTitle}
            </a>
            <span class="text-primary-300 dark:text-primary-600 text-xs">·</span>
            <span class="text-xs text-primary-500 dark:text-primary-400">
              Page {currentPage} of {totalPages}
            </span>
          </div>
          <h1 class="text-xl font-bold text-primary-900 dark:text-primary-50 leading-tight">
            #{tagDisplayTitle}
          </h1>
        </div>

        <!-- Card grid -->
        <div class="p-6">
          <div class="moc-card-grid">
            {paginatedPosts.map((post: any, index: number) => (
              <PostCard post={post} context="tags" eager={index < 4} />
            ))}
          </div>
          <div class="mt-8">
            <Pagination pagination={pagination} baseUrl={baseUrl} />
          </div>
        </div>

      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .tag-moc-grid {
    display: grid;
    grid-template-columns: minmax(0, var(--contentWidth));
    justify-content: center;
    padding: 0 1rem;
  }

  .moc-breadcrumb { grid-column: 1 / -1; }
  .moc-article { min-width: 0; }

  /* Compact banner for pagination pages */
  .moc-banner-compact {
    width: 100%;
    height: clamp(80px, 12vw, 160px);
    overflow: hidden;
    position: relative;
  }

  .moc-banner--gradient {
    background: linear-gradient(135deg, #e5e7eb 0%, #f3f4f6 100%);
  }

  :global(.dark) .moc-banner--gradient {
    background: linear-gradient(135deg, #1e2939 0%, #273549 100%);
  }

  .moc-banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.08) 100%);
    pointer-events: none;
  }

  .moc-card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .moc-card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1280px) {
    .tag-moc-grid { padding: 0 1.5rem; }
  }
</style>
