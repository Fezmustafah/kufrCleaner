---
import type { GetStaticPaths } from 'astro';
import { getCollection, getEntry } from 'astro:content';
import { siteConfig } from '@/config';
import { shouldShowPost, sortPostsByDate, extractTags } from '@/utils/markdown';
import { topicSlug } from '@/utils/topics';
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopicBanner from '@/components/TopicBanner.astro';
import PostCard from '@/components/PostCard.astro';
import Pagination from '@/components/Pagination.astro';
import Icon from '@/components/Icon.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const isDev = import.meta.env.DEV;
  const allPosts = await getCollection('posts');
  const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));
  const sortedPosts = sortPostsByDate(visiblePosts);
  const allTags = extractTags(sortedPosts);
  const postsPerPage = siteConfig.postOptions.postsPerPage;
  const paths: any[] = [];

  for (const tag of allTags) {
    const tagPosts = sortedPosts.filter((post: any) => {
      if (!post.data.tags) return false;
      const postTags = Array.isArray(post.data.tags) ? post.data.tags : [post.data.tags];
      return postTags.some((t: any) => t && typeof t === 'string' && t.trim() === tag.trim());
    });
    const totalPages = Math.ceil(tagPosts.length / postsPerPage);
    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: { tag, page: page.toString() },
        props: { tag, allPosts: sortedPosts, currentPage: page }
      });
    }
  }

  return paths;
};

const { tag, allPosts, currentPage } = Astro.props as {
  tag: string;
  allPosts: any[];
  currentPage: number;
};
const isDev = import.meta.env.DEV;
const baseUrl = import.meta.env.BASE_URL;

if (!tag && !isDev) return Astro.redirect('/404');

// Optional tag entry (slugified id — see @/utils/topics)
let tagEntry: any = null;
try {
  tagEntry = await getEntry('tags', topicSlug(tag));
} catch (_) {}

const filteredPosts = allPosts.filter((post: any) => {
  if (!post.data.tags) return false;
  const postTags = Array.isArray(post.data.tags) ? post.data.tags : [post.data.tags];
  return postTags.some((t: any) => t && typeof t === 'string' && t.trim() === tag.trim());
});

const postsPerPage = siteConfig.postOptions.postsPerPage;
const totalPosts = filteredPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const startIndex = (currentPage - 1) * postsPerPage;
const paginatedPosts = filteredPosts.slice(startIndex, startIndex + postsPerPage);

const tagDisplayTitle = tagEntry?.data.title || tag;
const coverImage = tagEntry?.data.image || null;
const coverImageAlt = tagEntry?.data.imageAlt || tagDisplayTitle;

const seoData = {
  title: `#${tagDisplayTitle} — Page ${currentPage} | ${siteConfig.title}`,
  description: tagEntry?.data.description || `Posts tagged with "${tag}" — page ${currentPage}`,
  canonical: Astro.url.href,
  ogType: 'website' as const
};

const listBaseUrl = `${baseUrl}posts/tag/${encodeURIComponent(tag)}`;
const pagination = {
  currentPage,
  totalPages,
  hasNext: currentPage < totalPages,
  hasPrev: currentPage > 1,
  nextUrl: currentPage < totalPages ? `${listBaseUrl}/${currentPage + 1}` : undefined,
  prevUrl: currentPage > 1 ? (currentPage === 2 ? listBaseUrl : `${listBaseUrl}/${currentPage - 1}`) : undefined
};
---

<BaseLayout seoData={seoData}>
  <div class="tag-single" style={`--contentWidth: ${siteConfig.layout.contentWidth}`}>

    <nav class="tag-back">
      <a href={listBaseUrl}>
        <Icon name="chevron-left" class="w-3.5 h-3.5" />
        #{tagDisplayTitle}
      </a>
    </nav>

    <header class="tag-hero tag-hero--compact">
      <TopicBanner name={tagDisplayTitle} image={coverImage} imageAlt={coverImageAlt} eager={true} />
      <div class="tag-hero-content">
        <p class="tag-hero-kicker">Tag · Page {currentPage} of {totalPages}</p>
        <h1 class="tag-hero-title">#{tagDisplayTitle}</h1>
      </div>
    </header>

    <div class="posts-cards-grid">
      {paginatedPosts.map((post: any, index: number) => (
        <PostCard post={post} context="tags" eager={index < 4} />
      ))}
    </div>
    <div class="tag-pagination">
      <Pagination pagination={pagination} baseUrl={listBaseUrl} />
    </div>

  </div>
</BaseLayout>

<style>
  .tag-single {
    max-width: var(--contentWidth, 65rem);
    margin: 0 auto;
    padding: 1.5rem 1rem 3.5rem;
  }
  @media (min-width: 1280px) { .tag-single { padding-left: 1.5rem; padding-right: 1.5rem; } }

  .tag-back { margin-bottom: 0.9rem; }
  .tag-back a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-prose, serif);
    font-size: 0.85rem;
    color: rgb(var(--color-primary-500));
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .tag-back a:hover { color: rgb(var(--color-highlight-600)); }
  :global(.dark) .tag-back a { color: rgb(var(--color-primary-400)); }
  :global(.dark) .tag-back a:hover { color: rgb(var(--color-highlight-400)); }

  .tag-hero {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid rgb(var(--color-highlight-500) / 0.2);
    display: flex;
  }
  .tag-hero--compact { min-height: clamp(140px, 20vw, 230px); }
  .tag-hero-content {
    position: relative;
    z-index: 1;
    align-self: flex-end;
    padding: clamp(1.1rem, 3vw, 1.9rem);
    max-width: 52rem;
  }
  .tag-hero-kicker {
    font-family: var(--font-prose, serif);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(var(--color-highlight-300));
    margin: 0 0 0.45rem;
  }
  .tag-hero-title {
    font-family: var(--font-heading, serif);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.05;
    color: rgb(var(--color-primary-50));
    margin: 0;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  .posts-cards-grid { margin-top: 2rem; }
  .tag-pagination { margin-top: 2.5rem; }
</style>
