---
import type { GetStaticPaths } from 'astro';
import { getCollection, getEntry, render } from 'astro:content';
import { siteConfig } from '@/config';
import { shouldShowPost, sortPostsByDate, extractTags } from '@/utils/markdown';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Pagination from '@/components/Pagination.astro';
import Icon from '@/components/Icon.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const isDev = import.meta.env.DEV;
  const allPosts = await getCollection('posts');
  const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));
  const sortedPosts = sortPostsByDate(visiblePosts);
  const allTags = extractTags(sortedPosts);

  return allTags.map(tag => ({
    params: { tag },
    props: { tag, allPosts: sortedPosts, allTags }
  }));
};

const { tag, allPosts } = Astro.props as {
  tag: string;
  allPosts: any[];
  allTags: string[];
};

const isDev = import.meta.env.DEV;
if (!tag && !isDev) return Astro.redirect('/404');

// Load optional tag entry
let tagEntry: any = null;
let TagContent: any = null;
try {
  tagEntry = await getEntry('tags', tag);
  if (tagEntry) {
    const rendered = await render(tagEntry);
    TagContent = rendered.Content;
  }
} catch (_) {}

// Filter posts by tag
const filteredPosts = allPosts.filter((post: any) => {
  if (!post.data.tags) return false;
  const postTags = Array.isArray(post.data.tags) ? post.data.tags : [post.data.tags];
  return postTags.some((t: any) => t && typeof t === 'string' && t.trim() === tag.trim());
});

const postsPerPage = siteConfig.postOptions.postsPerPage;
const totalPosts = filteredPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const paginatedPosts = filteredPosts.slice(0, postsPerPage);

const tagDisplayTitle = tagEntry?.data.title || tag;
const tagDescription = tagEntry?.data.description || `All posts tagged with "${tag}"`;
const coverImage = tagEntry?.data.image || null;
const coverImageAlt = tagEntry?.data.imageAlt || tagDisplayTitle;

const seoData = {
  title: `${tagDisplayTitle} | ${siteConfig.title}`,
  description: tagDescription,
  canonical: Astro.url.href,
  ogType: 'website' as const
};

const baseUrl = `/posts/tag/${encodeURIComponent(tag)}`;
const pagination = {
  currentPage: 1,
  totalPages,
  hasNext: totalPages > 1,
  hasPrev: false,
  nextUrl: totalPages > 1 ? `${baseUrl}/2` : undefined,
  prevUrl: undefined
};
---

<BaseLayout seoData={seoData}>
  <div class="py-8">
    <div class="tag-moc-grid" style={`--contentWidth: ${siteConfig.layout.contentWidth}`}>

      <Breadcrumbs
        postId={`tag/${tag}`}
        title={tagDisplayTitle}
        class="moc-breadcrumb mb-4"
      />

      <article class="moc-article bg-primary-50 dark:bg-primary-900 rounded-lg border border-primary-200 dark:border-primary-700 shadow-sm overflow-hidden">

        <!-- Banner: clamp height handles any image resolution gracefully -->
        {coverImage && coverImage !== '' ? (
          <div class="moc-banner">
            <img
              src={coverImage}
              alt={coverImageAlt}
              class="w-full h-full object-cover object-center"
              loading="eager"
              fetchpriority="high"
            />
            <div class="moc-banner-overlay" />
          </div>
        ) : (
          <div class="moc-banner moc-banner--gradient" />
        )}

        <!-- Header: sits below banner -->
        <div class="px-6 pt-6 pb-4 border-b border-primary-200 dark:border-primary-700">
          <div class="flex items-center gap-2 mb-3">
            <a
              href="/posts/tag"
              class="inline-flex items-center text-xs text-primary-500 dark:text-primary-400 hover:text-highlight-600 dark:hover:text-highlight-400 transition-colors"
            >
              <Icon name="tag" class="w-3 h-3 mr-1 opacity-70" />
              All tags
            </a>
          </div>

          <h1 class="text-2xl font-bold text-primary-900 dark:text-primary-50 mb-3 leading-tight">
            #{tagDisplayTitle}
          </h1>

          {tagEntry?.data.description && (
            <p class="text-sm text-primary-600 dark:text-primary-300 max-w-prose leading-relaxed mb-3">
              {tagEntry.data.description}
            </p>
          )}

          <span class="text-xs font-medium text-primary-500 dark:text-primary-400">
            {totalPosts === 1 ? '1 post' : `${totalPosts} posts`}
          </span>
        </div>

        <!-- Prose body from tag file (description essay, context, etc.) -->
        {TagContent && (
          <div class="px-6 py-6 border-b border-primary-200 dark:border-primary-700">
            <div class="prose dark:prose-dark max-w-none">
              <TagContent />
            </div>
          </div>
        )}

        <!-- Post card grid — 2 cols on md+, mimics Bases card view -->
        <div class="p-6">
          {paginatedPosts.length > 0 ? (
            <>
              <div class="moc-card-grid">
                {paginatedPosts.map((post: any, index: number) => (
                  <PostCard post={post} context="tags" eager={index < 4} />
                ))}
              </div>
              <div class="mt-8">
                <Pagination pagination={pagination} baseUrl={baseUrl} />
              </div>
            </>
          ) : (
            <div class="text-center py-12">
              <Icon name="tag" class="w-10 h-10 text-primary-300 dark:text-primary-600 mx-auto mb-3" />
              <p class="text-sm text-primary-500 dark:text-primary-400">No posts yet.</p>
            </div>
          )}
        </div>

      </article>
    </div>
  </div>
</BaseLayout>

<style>
  /* Centered single-column — clean MOC layout, no sidebar */
  .tag-moc-grid {
    display: grid;
    grid-template-columns: minmax(0, var(--contentWidth));
    justify-content: center;
    padding: 0 1rem;
  }

  .moc-breadcrumb {
    grid-column: 1 / -1;
  }

  .moc-article {
    min-width: 0;
  }

  /* Banner: clamp handles portrait/landscape/square without distortion */
  .moc-banner {
    width: 100%;
    height: clamp(180px, 28vw, 380px);
    overflow: hidden;
    position: relative;
    background: var(--color-primary-200, #e5e7eb);
  }

  :global(.dark) .moc-banner {
    background: var(--color-primary-800, #1f2937);
  }

  .moc-banner--gradient {
    background: linear-gradient(
      135deg,
      oklch(var(--p-300, 0.85 0.05 250)) 0%,
      oklch(var(--p-200, 0.92 0.02 250)) 100%
    );
  }

  :global(.dark) .moc-banner--gradient {
    background: linear-gradient(
      135deg,
      oklch(var(--p-800, 0.25 0.04 250)) 0%,
      oklch(var(--p-700, 0.32 0.04 250)) 100%
    );
  }

  /* Subtle scrim so header text stays readable if we later overlay text on banner */
  .moc-banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.08) 100%);
    pointer-events: none;
  }

  /* Card grid: 1 col mobile, 2 col md+ — matches Bases card aesthetics */
  .moc-card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .moc-card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1280px) {
    .tag-moc-grid {
      padding: 0 1.5rem;
    }
  }

  /* Tailwind's bg utilities won't work in oklch without vars — fallback to primary scale */
  .moc-banner--gradient {
    background: linear-gradient(135deg, #e5e7eb 0%, #f3f4f6 100%);
  }

  :global(.dark) .moc-banner--gradient {
    background: linear-gradient(135deg, #1e2939 0%, #273549 100%);
  }
</style>
