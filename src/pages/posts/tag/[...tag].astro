---
import type { GetStaticPaths } from 'astro';
import { getCollection, getEntry, render } from 'astro:content';
import { siteConfig } from '@/config';
import { shouldShowPost, sortPostsByDate, extractTags } from '@/utils/markdown';
import { topicSlug } from '@/utils/topics';
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopicBanner from '@/components/TopicBanner.astro';
import PostCard from '@/components/PostCard.astro';
import Pagination from '@/components/Pagination.astro';
import Icon from '@/components/Icon.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const isDev = import.meta.env.DEV;
  const allPosts = await getCollection('posts');
  const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));
  const sortedPosts = sortPostsByDate(visiblePosts);
  const allTags = extractTags(sortedPosts);

  return allTags.map(tag => ({
    params: { tag },
    props: { tag, allPosts: sortedPosts }
  }));
};

const { tag, allPosts } = Astro.props as {
  tag: string;
  allPosts: any[];
};
const isDev = import.meta.env.DEV;
const baseUrl = import.meta.env.BASE_URL;

if (!tag && !isDev) return Astro.redirect('/404');

// Load the optional tag entry (description, cover image, MOC body).
// Entry ids are slugified by Astro's glob loader, so slugify the raw value to match.
let tagEntry: any = null;
let TagContent: any = null;
try {
  tagEntry = await getEntry('tags', topicSlug(tag));
  if (tagEntry) {
    const rendered = await render(tagEntry);
    TagContent = rendered.Content;
  }
} catch (_) {}

const filteredPosts = allPosts.filter((post: any) => {
  if (!post.data.tags) return false;
  const postTags = Array.isArray(post.data.tags) ? post.data.tags : [post.data.tags];
  return postTags.some((t: any) => t && typeof t === 'string' && t.trim() === tag.trim());
});

const postsPerPage = siteConfig.postOptions.postsPerPage;
const totalPosts = filteredPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const currentPage = 1;
const paginatedPosts = filteredPosts.slice(0, postsPerPage);

const tagDisplayTitle = tagEntry?.data.title || tag;
const tagDescription = tagEntry?.data.description || null;
const coverImage = tagEntry?.data.image || null;
const coverImageAlt = tagEntry?.data.imageAlt || tagDisplayTitle;

const seoData = {
  title: `#${tagDisplayTitle} | ${siteConfig.title}`,
  description: tagDescription || `All posts tagged with "${tag}"`,
  canonical: Astro.url.href,
  ogType: 'website' as const
};

const listBaseUrl = `${baseUrl}posts/tag/${encodeURIComponent(tag)}`;
const pagination = {
  currentPage,
  totalPages,
  hasNext: currentPage < totalPages,
  hasPrev: false,
  nextUrl: totalPages > 1 ? `${listBaseUrl}/2/` : undefined,
  prevUrl: undefined
};
---

<BaseLayout seoData={seoData}>
  <div class="tag-single" style={`--contentWidth: ${siteConfig.layout.contentWidth}`}>

    <nav class="tag-back">
      <a href={`${baseUrl}posts/tag/`}>
        <Icon name="chevron-left" class="w-3.5 h-3.5" />
        All tags
      </a>
    </nav>

    <!-- Banner hero: entry image or al-andalus arabesque, title overlaid -->
    <header class="tag-hero">
      <TopicBanner name={tagDisplayTitle} image={coverImage} imageAlt={coverImageAlt} eager={true} />
      <div class="tag-hero-content">
        <p class="tag-hero-kicker">Tag</p>
        <h1 class="tag-hero-title">#{tagDisplayTitle}</h1>
        {tagDescription && <p class="tag-hero-desc">{tagDescription}</p>}
        <span class="tag-hero-count">{totalPosts === 1 ? '1 article' : `${totalPosts.toLocaleString()} articles`}</span>
      </div>
    </header>

    <!-- Optional MOC prose from the tag entry -->
    {TagContent && (
      <div class="tag-moc prose dark:prose-invert max-w-none">
        <TagContent />
      </div>
    )}

    <!-- Posts -->
    {paginatedPosts.length > 0 ? (
      <>
        <div class="posts-cards-grid">
          {paginatedPosts.map((post: any, index: number) => (
            <PostCard post={post} context="tags" eager={index < 4} />
          ))}
        </div>
        <div class="tag-pagination">
          <Pagination pagination={pagination} baseUrl={listBaseUrl} />
        </div>
      </>
    ) : (
      <div class="tag-empty">
        <Icon name="tag" class="w-9 h-9" />
        <p>No posts with this tag yet.</p>
      </div>
    )}

  </div>
</BaseLayout>

<style>
  .tag-single {
    max-width: var(--contentWidth, 65rem);
    margin: 0 auto;
    padding: 1.5rem 1rem 3.5rem;
  }
  @media (min-width: 1280px) { .tag-single { padding-left: 1.5rem; padding-right: 1.5rem; } }

  /* ── Back link ── */
  .tag-back { margin-bottom: 0.9rem; }
  .tag-back a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-prose, serif);
    font-size: 0.85rem;
    color: rgb(var(--color-primary-500));
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .tag-back a:hover { color: rgb(var(--color-highlight-600)); }
  :global(.dark) .tag-back a { color: rgb(var(--color-primary-400)); }
  :global(.dark) .tag-back a:hover { color: rgb(var(--color-highlight-400)); }

  /* ── Banner hero ── */
  .tag-hero {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
    min-height: clamp(200px, 30vw, 340px);
    border: 1px solid rgb(var(--color-highlight-500) / 0.2);
    display: flex;
  }
  .tag-hero-content {
    position: relative;
    z-index: 1;
    align-self: flex-end;
    padding: clamp(1.25rem, 3.5vw, 2.5rem);
    max-width: 52rem;
  }
  .tag-hero-kicker {
    font-family: var(--font-prose, serif);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgb(var(--color-highlight-300));
    margin: 0 0 0.55rem;
  }
  .tag-hero-title {
    font-family: var(--font-heading, serif);
    font-size: clamp(1.9rem, 5vw, 3.1rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.04;
    color: rgb(var(--color-primary-50));
    margin: 0;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }
  .tag-hero-desc {
    font-family: var(--font-prose, serif);
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    line-height: 1.6;
    color: rgb(var(--color-primary-200));
    margin: 0.85rem 0 0;
    max-width: 46rem;
    text-wrap: pretty;
  }
  .tag-hero-count {
    display: inline-block;
    font-family: var(--font-prose, serif);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--color-primary-100));
    margin-top: 1.1rem;
    padding: 0.32rem 0.7rem;
    border: 1px solid rgb(var(--color-highlight-400) / 0.4);
    border-radius: 999px;
    background: rgb(0 0 0 / 0.25);
    backdrop-filter: blur(4px);
  }

  /* ── MOC prose ── */
  .tag-moc {
    margin: 2rem 0 0.5rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid rgb(var(--color-primary-200));
  }
  :global(.dark) .tag-moc { border-bottom-color: rgb(var(--color-primary-800)); }

  /* ── Posts ── */
  .posts-cards-grid { margin-top: 2rem; }
  .tag-pagination { margin-top: 2.5rem; }

  .tag-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
    padding: 4rem 0;
    color: rgb(var(--color-primary-500));
    font-family: var(--font-prose, serif);
  }
  :global(.dark) .tag-empty { color: rgb(var(--color-primary-400)); }
</style>
