---
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { shouldShowPost } from '@/utils/markdown';
import { getTagCloudItems } from '@/utils/tag-cloud-data';
import BaseLayout from '@/layouts/BaseLayout.astro';
import TagCloud from '@/components/TagCloud.astro';

const isDev = import.meta.env.DEV;
const baseUrl = import.meta.env.BASE_URL;

// Tag items (noise-filtered, cleaned titles) — shared with the homepage cloud
const tags = await getTagCloudItems(isDev, baseUrl);
const totalPosts = (await getCollection('posts')).filter(post => shouldShowPost(post, isDev)).length;

// ── Alphabetical index (discovery layer) ──
const letterOf = (s: string) => {
  const c = (s.trim()[0] || '#').toUpperCase();
  return /[A-Z]/.test(c) ? c : '#';
};
const byTitle = [...tags].sort((a, b) => a.title.localeCompare(b.title, 'en', { sensitivity: 'base' }));
const groups = new Map<string, typeof tags>();
for (const t of byTitle) {
  const L = letterOf(t.title);
  if (!groups.has(L)) groups.set(L, []);
  groups.get(L)!.push(t);
}
const ALPHA = '#ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
const sections = ALPHA.filter(L => groups.has(L)).map(L => ({ letter: L, tags: groups.get(L)! }));
const idFor = (L: string) => (L === '#' ? 'ltr-sym' : `ltr-${L}`);

const seoData = {
  title: `Tags | ${siteConfig.title}`,
  description: `Browse ${tags.length} tags across ${totalPosts.toLocaleString()} articles.`,
  canonical: Astro.url.href,
  ogType: 'website' as const,
};
---

<BaseLayout seoData={seoData}>
  <div class="tag-index" style={`--contentWidth: ${siteConfig.layout.contentWidth}`}>

    <header class="tag-head">
      <p class="tag-kicker">Browse the library</p>
      <h1 class="tag-title">Tags</h1>
      <p class="tag-sub">{tags.length} tags across {totalPosts.toLocaleString()} articles</p>
    </header>

    {tags.length > 0 ? (
      <>
        <!-- Word cloud — size scales with post count (shared component) -->
        <div class="cloud-wrap">
          <TagCloud items={tags} minFont={18} maxFont={62} />
        </div>

        <!-- Alphabetical index -->
        <p class="az-subhead">Browse A–Z</p>
        <nav class="az-rail" aria-label="Jump to letter">
          {ALPHA.map((L) =>
            groups.has(L) ? (
              <a class="az-letter" href={`#${idFor(L)}`}>{L}</a>
            ) : (
              <span class="az-letter az-letter--off" aria-hidden="true">{L}</span>
            )
          )}
        </nav>

        {sections.map((sec) => (
          <section class="tag-section" id={idFor(sec.letter)}>
            <h2 class="tag-section-h">{sec.letter}</h2>
            <div class="tag-row">
              {sec.tags.map((t) => (
                <a class="tag-chip" href={t.url}>
                  <span class="tag-chip-dot" aria-hidden="true"></span>
                  <span class="tag-chip-name">{t.title}</span>
                  <span class="tag-chip-count">{t.count}</span>
                </a>
              ))}
            </div>
          </section>
        ))}
      </>
    ) : (
      <p class="tag-empty">No tags found.</p>
    )}

  </div>
</BaseLayout>

<style>
  .tag-index {
    max-width: var(--contentWidth, 65rem);
    margin: 0 auto;
    padding: 2.5rem 1rem 3.5rem;
  }
  @media (min-width: 1280px) { .tag-index { padding-left: 1.5rem; padding-right: 1.5rem; } }

  /* ── Header ── */
  .tag-head { margin-bottom: 1.75rem; }
  .tag-kicker {
    font-family: var(--font-prose, serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(var(--color-highlight-600));
    margin: 0 0 0.5rem;
  }
  :global(.dark) .tag-kicker { color: rgb(var(--color-highlight-400)); }
  .tag-title {
    font-family: var(--font-heading, serif);
    font-size: clamp(2rem, 5vw, 2.9rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.05;
    color: rgb(var(--color-primary-900));
    margin: 0 0 0.4rem;
  }
  :global(.dark) .tag-title { color: rgb(var(--color-primary-50)); }
  .tag-sub {
    font-family: var(--font-prose, serif);
    font-size: 0.95rem;
    color: rgb(var(--color-primary-500));
    margin: 0;
  }
  :global(.dark) .tag-sub { color: rgb(var(--color-primary-400)); }

  /* Word cloud styles live in TagCloud.astro (shared component) */
  .cloud-wrap { margin-bottom: 2.75rem; }

  /* ── Alphabetical index ── */
  .az-subhead {
    font-family: var(--font-prose, serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(var(--color-primary-500));
    margin: 0 0 0.35rem;
  }
  :global(.dark) .az-subhead { color: rgb(var(--color-primary-400)); }

  .az-rail {
    position: sticky;
    top: 3.5rem;
    z-index: 20;
    display: flex;
    flex-wrap: wrap;
    gap: 0.15rem;
    padding: 0.55rem 0;
    margin-bottom: 1.5rem;
    background: rgb(var(--color-primary-50) / 0.85);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgb(var(--color-primary-200));
  }
  :global(.dark) .az-rail {
    background: rgb(var(--color-primary-950) / 0.85);
    border-bottom-color: rgb(var(--color-primary-800));
  }
  .az-letter {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.55rem;
    height: 1.55rem;
    border-radius: 0.35rem;
    font-family: var(--font-mono, monospace);
    font-size: 0.72rem;
    color: rgb(var(--color-primary-500));
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .az-letter:hover {
    background: rgb(var(--color-highlight-500) / 0.15);
    color: rgb(var(--color-highlight-700));
  }
  :global(.dark) .az-letter { color: rgb(var(--color-primary-400)); }
  :global(.dark) .az-letter:hover { color: rgb(var(--color-highlight-300)); }
  .az-letter--off { opacity: 0.25; pointer-events: none; }

  .tag-section {
    scroll-margin-top: 6.5rem;
    margin-bottom: 1.75rem;
  }
  .tag-section-h {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-heading, serif);
    font-size: 1.35rem;
    font-weight: 600;
    color: rgb(var(--color-highlight-700));
    margin: 0 0 0.75rem;
  }
  :global(.dark) .tag-section-h { color: rgb(var(--color-highlight-400)); }
  .tag-section-h::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgb(var(--color-primary-200));
  }
  :global(.dark) .tag-section-h::after { background: rgb(var(--color-primary-800)); }

  .tag-row { display: flex; flex-wrap: wrap; gap: 0.55rem; }
  .tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.38rem 0.55rem 0.38rem 0.7rem;
    border-radius: 0.5rem;
    border: 1px solid rgb(var(--color-primary-200));
    background: rgb(var(--color-primary-50));
    text-decoration: none;
    transition: transform 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  :global(.dark) .tag-chip {
    border-color: rgb(var(--color-primary-800));
    background: rgb(var(--color-primary-900) / 0.4);
  }
  .tag-chip:hover {
    transform: translateY(-2px);
    border-color: rgb(var(--color-highlight-400) / 0.6);
    background: rgb(var(--color-highlight-500) / 0.08);
  }
  .tag-chip-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    border: 1.5px solid rgb(var(--color-highlight-500) / 0.6);
    flex: none;
  }
  .tag-chip-name {
    font-family: var(--font-heading, serif);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1;
    color: rgb(var(--color-primary-800));
  }
  :global(.dark) .tag-chip-name { color: rgb(var(--color-primary-100)); }
  .tag-chip:hover .tag-chip-name { color: rgb(var(--color-highlight-700)); }
  :global(.dark) .tag-chip:hover .tag-chip-name { color: rgb(var(--color-highlight-300)); }
  .tag-chip-count {
    font-family: var(--font-mono, monospace);
    font-size: 0.68rem;
    color: rgb(var(--color-primary-500));
    background: rgb(var(--color-primary-100));
    border-radius: 999px;
    padding: 0.08rem 0.4rem;
    min-width: 1.2rem;
    text-align: center;
  }
  :global(.dark) .tag-chip-count {
    color: rgb(var(--color-primary-300));
    background: rgb(var(--color-primary-800));
  }

  .tag-empty {
    font-family: var(--font-prose, serif);
    text-align: center;
    color: rgb(var(--color-primary-500));
    padding: 4rem 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .tag-chip { transition: border-color 0.15s ease, background 0.15s ease; }
    .tag-chip:hover { transform: none; }
    .az-rail { backdrop-filter: none; }
    .tag-cloud a { animation: none; }
    .cloud-word { transition: fill 0.15s ease, fill-opacity 0.15s ease; }
    .tag-cloud a:hover .cloud-word { transform: none; }
  }
</style>
