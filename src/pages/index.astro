---
import { getCollection, getEntry, render } from 'astro:content';
import { siteConfig } from '@/config';
import { generateHomeSEO } from '@/utils/seo';
import { shouldShowPost, sortPostsByDate, processPost, extractCategories, formatDateShort } from '@/utils/markdown';
import { categoryDisplayName } from '@/utils/topics';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Icon from '@/components/Icon.astro';
import { optimizePostImagePath } from '@/utils/images';
import HomepageHero from '@/components/HomepageHero.astro';
import TopicTile from '@/components/TopicTile.astro';

const baseUrl = import.meta.env.BASE_URL;

// Get all posts and filter by visibility
const allPosts = await getCollection('posts');
const isDev = import.meta.env.DEV;
const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));
const sortedPosts = sortPostsByDate(visiblePosts);

// Process posts for reading time and word count
const processedPosts = await Promise.all(
  sortedPosts.map(async (post) => await processPost(post))
) as any[];

// Featured post — kept only for the <head> image preload
let featuredPost = null;
if (siteConfig.homeOptions.featuredPost.enabled) {
  if (siteConfig.homeOptions.featuredPost.type === "latest") {
    featuredPost = processedPosts[0];
  } else if (siteConfig.homeOptions.featuredPost.type === "featured" && siteConfig.homeOptions.featuredPost.slug) {
    featuredPost = processedPosts.find(post => post.id === siteConfig.homeOptions.featuredPost.slug) || null;
  }
}

// Get home blurb content from special collection
let homeBlurbContent = null;
let HomeBlurbContent = null;
if (siteConfig.homeOptions.blurb.placement !== 'none') {
  try {
    homeBlurbContent = await getEntry('special', 'home');
    if (homeBlurbContent) {
      const { Content } = await render(homeBlurbContent);
      HomeBlurbContent = Content;
    }
  } catch (error) {
    // no blurb entry — fine
  }
}

// Categories + post counts
const allCategories = extractCategories(sortedPosts);
const categoryPostCounts = allCategories.reduce((acc: Record<string, number>, cat: string) => {
  acc[cat] = sortedPosts.filter((p: any) => p.data.category === cat).length;
  return acc;
}, {} as Record<string, number>);

// One-line topic descriptions (auto-config, code-maintained — no per-article curation).
// Keyed by normalized category name; missing categories simply render name + count.
const TOPIC_DESCRIPTIONS: Record<string, string> = {
  'refutations': 'Point-by-point responses to the most frequently circulated polemics and criticisms of Islam.',
  'christianity': 'Answering biblical criticism and missionary arguments.',
  'atheism': 'Responding to secular and New-Atheist objections.',
  'science and islam': 'The Quran, hadith, and modern science.',
  'qadyanis': 'Responses to Ahmadiyya claims.',
  'history': 'Setting the historical record straight.',
  'hadiths science': 'Authenticity, isnād, and hadith criticism.',
  'refuting shias': 'Responses to Shia theological claims.',
  'islam': 'Foundational clarifications and first principles.',
  'ﷺ': 'The life, character, and honour of the Prophet Muhammad ﷺ.',
};

// Bento topics — drop noise buckets, sort by count desc. First tile renders large.
// (display name comes from the shared categoryDisplayName; URL keeps the raw value.)
const TOPIC_NOISE = new Set(['', 'test', 'quranic refutations', 'islamic refutations']);
const topics = allCategories
  .filter((c: string) => c && !TOPIC_NOISE.has(c.toLowerCase().trim()))
  .map((c: string) => ({
    name: c,
    display: categoryDisplayName(c),
    count: categoryPostCounts[c],
    desc: TOPIC_DESCRIPTIONS[c.toLowerCase().trim()] || '',
  }))
  .sort((a, b) => b.count - a.count);
// Same bento shape as the /posts/category/ index: top 2 render large, rest fill a 3-col grid.
const featuredTopics = topics.slice(0, 2);
const restTopics = topics.slice(2);

// Common objections — question-titled posts that carry a rebuttal summary, most recent 5.
const objections = sortedPosts
  .filter((p: any) => (p.data.title || '').trim().endsWith('?') && p.data.description)
  .slice(0, 5);

// Latest — newly added (by date) and recently updated (by `modified`).
const getModifiedDate = (post: any): Date | null => {
  const m = post.data.modified;
  if (!m) return null;
  return m instanceof Date ? m : new Date(m);
};
const recentlyUpdated = [...visiblePosts]
  .filter(p => getModifiedDate(p) !== null)
  .sort((a, b) => getModifiedDate(b)!.getTime() - getModifiedDate(a)!.getTime())
  .slice(0, 6);
const newlyAdded = sortedPosts.slice(0, 6);

// Hero stats
const postCount = visiblePosts.length;
const categoryCount = topics.length;
const totalWords = processedPosts.reduce((sum: number, p: any) => sum + (p.wordCount || 0), 0);

// Only-blurb fallback (no posts at all)
const onlyBlurbContent = processedPosts.length === 0 && siteConfig.homeOptions.blurb.placement !== 'none' && HomeBlurbContent;

// SEO
const seoData = generateHomeSEO(Astro.url.href);
if (siteConfig.homepageTitle) seoData.title = siteConfig.homepageTitle;

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteConfig.site}/#website`,
      name: siteConfig.title,
      url: siteConfig.site,
      description: siteConfig.description,
      inLanguage: siteConfig.language,
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${siteConfig.site}/search/?q={search_term_string}`
        },
        'query-input': 'required name=search_term_string'
      }
    },
    {
      '@type': 'Organization',
      '@id': `${siteConfig.site}/#organization`,
      name: siteConfig.title,
      url: siteConfig.site,
      sameAs: [
        'https://x.com/kufrcleaner1',
        'https://www.instagram.com/kufrcleaner/',
        'https://discord.gg/29gmvhXRh8'
      ]
    },
    {
      '@type': 'ItemList',
      '@id': `${siteConfig.site}/#topics`,
      name: 'Topics',
      description: 'Islamic apologetics topics covered on OpenIslam',
      itemListElement: topics.map((t, i: number) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: t.display,
        url: `${siteConfig.site}/posts/category/${encodeURIComponent(t.name)}/`
      }))
    },
    {
      '@type': 'Blog',
      '@id': `${siteConfig.site}/#blog`,
      name: siteConfig.title,
      description: siteConfig.description,
      url: siteConfig.site,
      inLanguage: siteConfig.language,
      author: { '@type': 'Person', name: siteConfig.author },
      publisher: { '@id': `${siteConfig.site}/#organization` }
    }
  ]
};
---

<BaseLayout seoData={seoData}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    {featuredPost && featuredPost.data.image && siteConfig.postOptions.showPostCardCoverImages === 'all' && !featuredPost.data.hideCoverImage && typeof featuredPost.data.image === 'string' && !featuredPost.data.image.startsWith('http') && (
      <link
        rel="preload"
        as="image"
        href={optimizePostImagePath(featuredPost.data.image, undefined, featuredPost.id)}
        fetchpriority="high"
      />
    )}
  </Fragment>

  <HomepageHero postCount={postCount} categoryCount={categoryCount} totalWords={totalWords} />

  <div class="py-8 relative">
    <div class="hp mx-auto px-4 sm:px-6 lg:px-8" style={`max-width: ${siteConfig.layout.contentWidth}`}>

      {onlyBlurbContent ? (
        <article class="bg-primary-50 dark:bg-primary-900 rounded-lg border border-primary-200 dark:border-primary-700 shadow-sm mt-10">
          <div class="p-6 rounded-lg">
            {homeBlurbContent?.data.title && (
              <header class="mb-4">
                <h2 class="text-xl font-bold text-primary-900 dark:text-primary-50 mb-6 leading-tight">
                  {homeBlurbContent.data.title}
                </h2>
              </header>
            )}
            <div class="prose dark:prose-dark max-w-none" id="page-content">
              {HomeBlurbContent && <HomeBlurbContent />}
            </div>
          </div>
        </article>
      ) : processedPosts.length > 0 ? (
        <>
          {siteConfig.homeOptions.blurb.placement === 'above' && HomeBlurbContent && (
            <section class="prose prose-sm dark:prose-dark max-w-none mb-12 mt-10">
              <HomeBlurbContent />
            </section>
          )}

          <!-- ═══════════════════ 1 · LATEST (segmented) ═══════════════════ -->
          {(newlyAdded.length > 0 || recentlyUpdated.length > 0) && (
            <section class="hp-sec hp-sec--first">
              <div class="hp-sechead">
                <div>
                  <span class="hp-eyebrow"><span aria-hidden="true">◆</span> Fresh from the desk</span>
                  <h2 class="hp-h2">Latest</h2>
                </div>
                <div class="hp-seg" role="group" aria-label="Filter latest articles">
                  <button type="button" aria-pressed="true" data-tab="new" aria-controls="hp-latest-new">Newly added</button>
                  {recentlyUpdated.length > 0 && (
                    <button type="button" aria-pressed="false" data-tab="upd" aria-controls="hp-latest-upd">Recently updated</button>
                  )}
                </div>
              </div>

              <div class="hp-latest" id="hp-latest-new">
                {newlyAdded.map((p: any) => (
                  <a href={`${baseUrl}posts/${p.id}/`}>
                    {p.data.category && <span class="hp-lt-cat">{p.data.category}</span>}
                    <h3 class="hp-lt-title">{p.data.title}</h3>
                    <span class="hp-lt-meta">{formatDateShort(p.data.date)}<br />+ new</span>
                  </a>
                ))}
              </div>

              {recentlyUpdated.length > 0 && (
                <div class="hp-latest" id="hp-latest-upd" hidden>
                  {recentlyUpdated.map((p: any) => (
                    <a href={`${baseUrl}posts/${p.id}/`}>
                      {p.data.category && <span class="hp-lt-cat">{p.data.category}</span>}
                      <h3 class="hp-lt-title">{p.data.title}</h3>
                      <span class="hp-lt-meta"><span class="hp-upd"><span aria-hidden="true">↻</span> {formatDateShort(getModifiedDate(p))}</span></span>
                    </a>
                  ))}
                </div>
              )}
            </section>
          )}

          <!-- ═══════════════════ 2 · EXPLORE BY TOPIC (bento) ═══════════════════ -->
          {siteConfig.postOptions.categories && topics.length > 0 && (
            <section class="hp-sec">
              <div class="hp-sechead">
                <div>
                  <span class="hp-eyebrow"><span aria-hidden="true">◆</span> By subject area</span>
                  <h2 class="hp-h2">Explore by topic</h2>
                </div>
                <a class="hp-more" href={`${baseUrl}posts/category/`}>All topics →</a>
              </div>
              {featuredTopics.length > 0 && (
                <div class="hp-topic-feat">
                  {featuredTopics.map((t) => (
                    <TopicTile
                      href={`${baseUrl}posts/category/${encodeURIComponent(t.name)}/`}
                      name={t.display}
                      label={t.display}
                      count={t.count}
                      description={t.desc || null}
                      large={true}
                    />
                  ))}
                </div>
              )}
              {restTopics.length > 0 && (
                <div class="hp-topic-rest">
                  {restTopics.map((t) => (
                    <TopicTile
                      href={`${baseUrl}posts/category/${encodeURIComponent(t.name)}/`}
                      name={t.display}
                      label={t.display}
                      count={t.count}
                      description={t.desc || null}
                    />
                  ))}
                </div>
              )}
            </section>
          )}

          <!-- ═══════════════════ 2 · COMMON OBJECTIONS (accordion) ═══════════════════ -->
          {objections.length > 0 && (
            <section class="hp-sec">
              <div class="hp-sechead">
                <div>
                  <span class="hp-eyebrow"><span aria-hidden="true">◆</span> Frequently raised objections</span>
                  <h2 class="hp-h2">Common objections, answered</h2>
                </div>
                <a class="hp-more" href={`${baseUrl}posts/`}>All answers →</a>
              </div>
              <div class="hp-alleg">
                {objections.map((p: any, i: number) => (
                  <details open={i === 0}>
                    <summary>
                      <span class="hp-q-quote" aria-hidden="true">“</span>
                      <h3 class="hp-q">{p.data.title}</h3>
                      <span class="hp-chev" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
                      </span>
                    </summary>
                    <div class="hp-ans">
                      <p>{p.data.description}</p>
                      <a href={`${baseUrl}posts/${p.id}/`}>Read the full response →</a>
                    </div>
                  </details>
                ))}
              </div>
            </section>
          )}

          <!-- ═══════════ 3 · FINDING YOUR WAY AROUND (guide, full-bleed band) ═══════════ -->
          <section class="hp-band hp-guide">
            <div class="hp-band-inner" style={`max-width: ${siteConfig.layout.contentWidth}`}>
              <div class="hp-sechead">
                <div>
                  <span class="hp-eyebrow"><span aria-hidden="true">◆</span> New here?</span>
                  <h2 class="hp-h2">Finding your way around</h2>
                </div>
              </div>
              <div class="hp-guide-grid">
                <a class="hp-guide-card" href={`${baseUrl}search/`}>
                  <span class="hp-guide-ic"><Icon name="search" size={20} /></span>
                  <h3>Search the library</h3>
                  <p>Hit a specific claim? Search the exact allegation and jump straight to the response.</p>
                  <span class="hp-guide-go" aria-hidden="true">→</span>
                </a>
                <a class="hp-guide-card" href={`${baseUrl}posts/category/`}>
                  <span class="hp-guide-ic"><Icon name="grid-3x3" size={20} /></span>
                  <h3>Browse by topic</h3>
                  <p>Work through a subject area — Refutations, Christianity, Atheism, and more.</p>
                  <span class="hp-guide-go" aria-hidden="true">→</span>
                </a>
                <a class="hp-guide-card" href={`${baseUrl}posts/tag/`}>
                  <span class="hp-guide-ic"><Icon name="tag" size={20} /></span>
                  <h3>Browse by tag</h3>
                  <p>Zero in on a specific person, scripture, or concept across every article.</p>
                  <span class="hp-guide-go" aria-hidden="true">→</span>
                </a>
                <a class="hp-guide-card" href={`${baseUrl}graph-view/`}>
                  <span class="hp-guide-ic"><Icon name="share-2" size={20} /></span>
                  <h3>See the graph</h3>
                  <p>Explore how every topic and article connects across the wiki.</p>
                  <span class="hp-guide-go" aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          </section>

          <!-- ═══════════ CLOSING PULL-QUOTE ═══════════ -->
          <section class="hp-closer">
            <p class="hp-closer-line">Every allegation, answered.</p>
            <div class="hp-closer-rule" aria-hidden="true">◇ ✦ ◇</div>
            <p class="hp-closer-sub">No slogans, no hand-waving — just sourced, scholarly responses to the claims raised against Islam.</p>
          </section>
        </>
      ) : (
        <section class="text-center py-16">
          <div class="max-w-md mx-auto">
            <Icon name="file-text" class="w-16 h-16 text-primary-400 dark:text-primary-500 mx-auto mb-6" />
            <h2 class="text-2xl font-semibold text-primary-900 dark:text-primary-50 mb-4">No Posts Yet</h2>
            <p class="text-primary-600 dark:text-primary-300 mb-8">
              This blog is just getting started. Check back soon for new content!
            </p>
          </div>
        </section>
      )}

      <!-- ═══════════════════ SUPPORT (full-bleed band) ═══════════════════ -->
      <section class="hp-band hp-support-band">
        <div class="hp-support">
          <h2>Support this work</h2>
          <p>
            OpenIslam is a free, independent resource — no paywalls, no ads.
            Your support keeps the research going and the answers accessible.
          </p>
          <div class="hp-support-actions">
            <a class="hp-btn primary" href="https://www.paypal.com/invoice/p/#GRZNFXRSGNM52F5B" target="_blank" rel="noopener noreferrer" aria-label="Donate via PayPal">
              <Icon name="paypal" size={17} /><span>Donate via PayPal</span>
            </a>
            <div class="hp-support-socials">
              <a class="hp-btn" href="https://x.com/kufrcleaner1" target="_blank" rel="noopener noreferrer">
                <Icon name="x-twitter" size={16} /><span>X / Twitter</span>
              </a>
              <a class="hp-btn" href="https://www.instagram.com/kufrcleaner/?hl=en" target="_blank" rel="noopener noreferrer">
                <Icon name="instagram" size={16} /><span>Instagram</span>
              </a>
              <a class="hp-btn" href="https://discord.gg/29gmvhXRh8" target="_blank" rel="noopener noreferrer">
                <Icon name="discord" size={16} /><span>Discord</span>
              </a>
            </div>
          </div>
          <p class="hp-support-contact">
            Spotted an error, or want a topic covered? <a href={`${baseUrl}contact/`}>Get in touch →</a>
          </p>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>


<style>
  /* ══════════════ Redesigned homepage — al-andalus tokens ══════════════ */
  /* Semantic roles sourced from the runtime theme vars. Light-mode accent/meta/teal
     are stepped for WCAG AA on small text (accent h-700, meta p-600, teal s-600). */
  .hp {
    --hp-bg-inset: rgb(var(--color-primary-100));
    --hp-bg-raise: rgb(var(--color-primary-50));
    --hp-text: rgb(var(--color-primary-900));
    --hp-muted: rgb(var(--color-primary-600));
    --hp-meta: rgb(var(--color-primary-600));
    --hp-border: rgb(var(--color-primary-200));
    --hp-border-strong: rgb(var(--color-primary-300));
    --hp-accent: rgb(var(--color-highlight-700));
    --hp-accent-soft: rgb(var(--color-highlight-400));
    --hp-teal: rgb(var(--color-secondary-600));
  }
  :global(html.dark) .hp {
    --hp-bg-inset: rgb(var(--color-primary-800));
    --hp-bg-raise: rgb(var(--color-primary-900));
    --hp-text: rgb(var(--color-primary-100));
    --hp-muted: rgb(var(--color-primary-300));
    --hp-meta: rgb(var(--color-primary-300));
    --hp-border: rgb(var(--color-primary-700));
    --hp-border-strong: rgb(var(--color-primary-600));
    --hp-accent: rgb(var(--color-highlight-400));
    --hp-accent-soft: rgb(var(--color-highlight-500));
    --hp-teal: rgb(var(--color-secondary-400));
  }

  /* ── shared section head ── */
  .hp-sec { margin-bottom: 3.5rem; }
  .hp-sec--first { margin-top: 2.5rem; }
  .hp-sechead {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .hp-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-prose, serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--hp-accent);
  }
  .hp-eyebrow span { color: var(--hp-accent-soft); font-size: 0.6em; opacity: 0.8; }
  .hp-h2 {
    font-family: var(--font-heading, serif);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--hp-text);
    margin: 0.35rem 0 0;
    line-height: 1.15;
  }
  .hp-more {
    font-family: var(--font-prose, serif);
    font-size: 0.9rem;
    white-space: nowrap;
    color: var(--hp-accent);
    text-decoration: none;
    border-bottom: 1px dotted currentColor;
    padding-bottom: 1px;
    transition: color 0.15s;
  }
  .hp-more:hover { color: var(--hp-text); }

  /* ── 1 · topic bento (shared TopicTile — matches /posts/category/ index) ── */
  .hp-topic-feat { display: grid; grid-template-columns: 1fr; gap: 1rem; margin-bottom: 1rem; }
  @media (min-width: 720px) { .hp-topic-feat { grid-template-columns: 1.9fr 1fr; } }
  .hp-topic-rest { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 520px) { .hp-topic-rest { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .hp-topic-rest { grid-template-columns: repeat(3, 1fr); } }

  /* ── 2 · accordion ── */
  .hp-alleg { border-top: 1px solid var(--hp-border); }
  .hp-alleg details { border-bottom: 1px solid var(--hp-border); }
  .hp-alleg summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem 0;
  }
  .hp-alleg summary::-webkit-details-marker { display: none; }
  .hp-q-quote {
    font-family: var(--font-heading, serif);
    font-size: 2rem;
    line-height: 0;
    color: var(--hp-accent-soft);
    position: relative;
    top: 0.75rem;
    flex: none;
  }
  .hp-q {
    flex: 1;
    font-family: var(--font-heading, serif);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--hp-text);
    margin: 0;
    transition: color 0.2s;
  }
  .hp-alleg summary:hover .hp-q { color: var(--hp-accent); }
  .hp-chev { flex: none; color: var(--hp-accent); transition: transform 0.25s; margin-top: 0.35rem; }
  .hp-alleg details[open] summary .hp-chev { transform: rotate(45deg); }
  .hp-ans { padding: 0 0 1.5rem 2.4rem; max-width: 70ch; }
  .hp-ans p { font-family: var(--font-prose, serif); margin: 0 0 0.75rem; color: var(--hp-muted); line-height: 1.7; }
  .hp-ans a {
    font-family: var(--font-prose, serif);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--hp-accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .hp-ans a:hover { border-bottom-color: currentColor; }

  /* ── full-bleed bands — break out of the constrained <main> (body has overflow-x: clip) ── */
  .hp-band {
    position: relative;
    left: 50%;
    right: 50%;
    width: 100vw;
    margin-left: -50vw;
    margin-right: -50vw;
  }
  .hp-band-inner { margin-inline: auto; padding-inline: 1rem; }
  @media (min-width: 640px) { .hp-band-inner { padding-inline: 1.5rem; } }

  /* ── 3 · navigation guide (full-bleed shelf) ── */
  .hp-guide {
    padding-block: 3.25rem;
    background: var(--hp-bg-inset);
    border-block: 1px solid var(--hp-border);
  }
  .hp-guide-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }
  @media (max-width: 900px) { .hp-guide-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .hp-guide-grid { grid-template-columns: 1fr; } }
  .hp-guide-card {
    position: relative;
    display: block;
    padding: 1.4rem;
    background: var(--hp-bg-raise);
    border: 1px solid var(--hp-border);
    border-radius: 0.6rem;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }
  .hp-guide-card:hover { border-color: var(--hp-accent-soft); transform: translateY(-2px); }
  .hp-guide-ic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
