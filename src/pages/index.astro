---
import { getCollection, getEntry, render, type CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config';
import { generateHomeSEO } from '@/utils/seo';
import { shouldShowPost, sortPostsByDate, processPost, extractCategories } from '@/utils/markdown';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Icon from '@/components/Icon.astro';
import { optimizePostImagePath } from '@/utils/images';
import HomepageHero from '@/components/HomepageHero.astro';
import AiAssistant from '@/components/AiAssistant.astro';

// Get all posts and filter by visibility
const allPosts = await getCollection('posts');
const isDev = import.meta.env.DEV;
const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));
const sortedPosts = sortPostsByDate(visiblePosts);

// Process posts for reading time and word count
const processedPosts = await Promise.all(
  sortedPosts.map(async (post) => await processPost(post))
) as any[];

// Get featured post based on configuration
let featuredPost = null;
if (siteConfig.homeOptions.featuredPost.enabled) {
  if (siteConfig.homeOptions.featuredPost.type === "latest") {
    featuredPost = processedPosts[0];
  } else if (siteConfig.homeOptions.featuredPost.type === "featured" && siteConfig.homeOptions.featuredPost.slug) {
    // Find the specific post by id (slug config value maps to post.id in v6)
    featuredPost = processedPosts.find(post => post.id === siteConfig.homeOptions.featuredPost.slug) || null;
  }
}

// Get preview posts based on whether featured post is shown
const previewPosts = featuredPost
  ? processedPosts.slice(1, siteConfig.homeOptions.recentPosts.count + 1)
  : processedPosts.slice(0, siteConfig.homeOptions.recentPosts.count);

// Get home blurb content from special collection
let homeBlurbContent = null;
let HomeBlurbContent = null;

if (siteConfig.homeOptions.blurb.placement !== 'none') {
  try {
    homeBlurbContent = await getEntry('special', 'home');
    if (homeBlurbContent) {
      const { Content } = await render(homeBlurbContent);
      HomeBlurbContent = Content;
    }
  } catch (error) {
  }
}

// Extract categories and post counts for hero section
const allCategories = extractCategories(sortedPosts);
const categoryPostCounts = allCategories.reduce((acc: Record<string, number>, cat: string) => {
  acc[cat] = sortedPosts.filter((p: any) => p.data.category === cat).length;
  return acc;
}, {} as Record<string, number>);

// Hot Topics: posts with 20+ R2 images, sorted by word count
const hotTopics = [...sortedPosts]
  .filter(p => p.body && p.body.length > 500)
  .map(p => {
    const words = (p.body || '').split(/\s+/).filter(Boolean).length;
    const r2Images = ((p.body || '').match(/r2\.dev/g) || []).length;
    return { post: p, words, r2Images };
  })
  .filter(({ r2Images }) => r2Images >= 20)
  .sort((a, b) => b.words - a.words)
  .slice(0, 6);

// Recently Updated: posts with `modified` field, sorted by modified date desc, top 10
const getModifiedDate = (post: any): Date | null => {
  const m = post.data.modified;
  if (!m) return null;
  return m instanceof Date ? m : new Date(m);
};
const recentlyUpdated = [...visiblePosts]
  .filter(p => getModifiedDate(p) !== null)
  .sort((a, b) => getModifiedDate(b)!.getTime() - getModifiedDate(a)!.getTime())
  .slice(0, 10);

// Newly Added: top 6 most recently published posts
const newlyAdded = sortedPosts.slice(0, 6);

// Stats for hero
const postCount = visiblePosts.length;
const categoryCount = allCategories.length;

// Determine which content types are being displayed
const hasFeaturedPost = siteConfig.homeOptions.featuredPost.enabled && featuredPost;
const hasRecentPosts = siteConfig.homeOptions.recentPosts.enabled && previewPosts.length > 0;

// Count how many content types are being displayed
const contentTypesCount = [hasFeaturedPost, hasRecentPosts].filter(Boolean).length;

// Determine if only blurb content should be shown (no posts)
const onlyBlurbContent = contentTypesCount === 0 && siteConfig.homeOptions.blurb.placement !== 'none' && HomeBlurbContent;

// Generate SEO data for homepage
const seoData = generateHomeSEO(Astro.url.href);
if (siteConfig.homepageTitle) seoData.title = siteConfig.homepageTitle;

// Structured data for the website
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteConfig.site}/#website`,
      name: siteConfig.title,
      url: siteConfig.site,
      description: siteConfig.description,
      inLanguage: siteConfig.language,
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${siteConfig.site}/search/?q={search_term_string}`
        },
        'query-input': 'required name=search_term_string'
      }
    },
    {
      '@type': 'Organization',
      '@id': `${siteConfig.site}/#organization`,
      name: siteConfig.title,
      url: siteConfig.site,
      sameAs: [
        'https://x.com/kufrcleaner1',
        'https://www.instagram.com/kufrcleaner/',
        'https://discord.gg/29gmvhXRh8'
      ]
    },
    {
      '@type': 'ItemList',
      '@id': `${siteConfig.site}/#topics`,
      name: 'Topics',
      description: 'Islamic apologetics topics covered on OpenIslam',
      itemListElement: allCategories.map((cat: string, i: number) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: cat,
        url: `${siteConfig.site}/posts/category/${encodeURIComponent(cat)}`
      }))
    },
    {
      '@type': 'Blog',
      '@id': `${siteConfig.site}/#blog`,
      name: siteConfig.title,
      description: siteConfig.description,
      url: siteConfig.site,
      inLanguage: siteConfig.language,
      author: {
        '@type': 'Person',
        name: siteConfig.author
      },
      publisher: {
        '@id': `${siteConfig.site}/#organization`
      }
    }
  ]
};
---

<BaseLayout seoData={seoData}>
  <Fragment slot="head">
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Preload critical images - use same URL as actual img tags for caching -->
    {featuredPost && featuredPost.data.image && siteConfig.postOptions.showPostCardCoverImages === 'all' && !featuredPost.data.hideCoverImage && typeof featuredPost.data.image === 'string' && !featuredPost.data.image.startsWith('http') && (
      <link
        rel="preload"
        as="image"
        href={optimizePostImagePath(featuredPost.data.image, undefined, featuredPost.id)}
        fetchpriority="high"
      />
    )}
  </Fragment>

  <HomepageHero postCount={postCount} categoryCount={categoryCount} />

  <div class="py-8 relative">
    <div class="mx-auto px-4 sm:px-6 lg:px-8" style={`max-width: ${siteConfig.layout.contentWidth}`}>

      <!-- ═══════════════════ BROWSE BY CATEGORY ═══════════════════ -->
      {siteConfig.postOptions.categories && allCategories.length > 0 && (
        <section class="mb-12 mt-10">
          <div class="flex items-center justify-between mb-5">
            <h2 class="section-heading">
              <span aria-hidden="true" class="section-heading-ornament">◆</span>
              Browse by Topic
            </h2>
            <a href={`${import.meta.env.BASE_URL}posts`} class="text-base text-highlight-600 dark:text-highlight-400 border-b border-dotted border-highlight-400/50 hover:border-solid pb-0.5 transition-all">
              All articles →
            </a>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
            {allCategories.map((cat: string) => (
              <a
                href={`${import.meta.env.BASE_URL}posts/category/${encodeURIComponent(cat)}`}
                class="group flex items-center gap-2 px-3 py-2 rounded-lg border border-primary-200 dark:border-primary-700 bg-primary-50 dark:bg-primary-900/60 hover:bg-primary-100 dark:hover:bg-primary-800/60 hover:border-highlight-400/60 dark:hover:border-highlight-600/40 transition-all duration-150"
              >
                <Icon name="book-open" class="w-3.5 h-3.5 text-secondary-500 dark:text-secondary-400 shrink-0" />
                <span class="font-medium text-sm text-primary-800 dark:text-primary-100 group-hover:text-highlight-600 dark:group-hover:text-highlight-400 transition-colors truncate flex-1">
                  {cat}
                </span>
                <span class="text-xs text-primary-400 dark:text-primary-500 tabular-nums shrink-0">
                  {categoryPostCounts[cat]}
                </span>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- ═══════════════════ HOT TOPICS ═══════════════════ -->
      {hotTopics.length > 0 && (
        <section class="mb-12">
          <div class="flex items-center justify-between mb-5">
            <h2 class="section-heading">
              <span aria-hidden="true" class="section-heading-ornament">◆</span>
              In-Depth Articles
            </h2>
            <a href={`${import.meta.env.BASE_URL}posts`} class="text-base text-highlight-600 dark:text-highlight-400 border-b border-dotted border-highlight-400/50 hover:border-solid pb-0.5 transition-all">
              All articles →
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {hotTopics.map(({ post, words }) => {
              const category: string = (post.data as any).category ?? '';
              const wordLabel = words >= 1000 ? `${Math.round(words / 100) / 10}k words` : `${words} words`;
              return (
                <a
                  href={`${import.meta.env.BASE_URL}posts/${post.id}`}
                  class="group flex flex-col gap-2 p-4 rounded-lg border border-primary-200 dark:border-primary-700 bg-primary-50/50 dark:bg-primary-900/40 hover:border-highlight-300 dark:hover:border-highlight-600 hover:bg-primary-50 dark:hover:bg-primary-900/70 transition-all duration-200 hover:shadow-md"
                >
                  <div class="flex items-center justify-between gap-2">
                    {category && (
                      <span class="text-xs font-semibold tracking-widest uppercase text-highlight-600 dark:text-highlight-400 truncate">
                        {category}
                      </span>
                    )}
                    <span class="text-xs text-primary-400 dark:text-primary-500 tabular-nums shrink-0 ml-auto">
                      {wordLabel}
                    </span>
                  </div>
                  <span class="text-sm font-semibold leading-snug text-primary-900 dark:text-primary-50 group-hover:text-highlight-600 dark:group-hover:text-highlight-400 transition-colors line-clamp-3">
                    {post.data.title}
                  </span>
                  {post.data.description && (
                    <span class="text-xs text-primary-500 dark:text-primary-400 line-clamp-2 leading-relaxed mt-auto">
                      {post.data.description}
                    </span>
                  )}
                </a>
              );
            })}
          </div>
        </section>
      )}

      <!-- ═══════════════════ MAIN CONTENT ═══════════════════ -->
      {onlyBlurbContent ? (
        <article class="bg-primary-50 dark:bg-primary-900 rounded-lg border border-primary-200 dark:border-primary-700 shadow-sm">
          <div class="p-6 rounded-lg">
            {homeBlurbContent?.data.title && (
              <header class="mb-4">
                <h2 class="text-xl font-bold text-primary-900 dark:text-primary-50 mb-6 leading-tight">
                  {homeBlurbContent.data.title}
                </h2>
              </header>
            )}
            <div class="prose dark:prose-dark max-w-none" id="page-content">
              {HomeBlurbContent && <HomeBlurbContent />}
            </div>
          </div>
        </article>
      ) : processedPosts.length > 0 ? (
        <>
          {siteConfig.homeOptions.blurb.placement === 'above' && HomeBlurbContent && (
            <section class="prose prose-sm dark:prose-dark max-w-none mb-12">
              <HomeBlurbContent />
            </section>
          )}

          <!-- Featured post -->
          {siteConfig.homeOptions.featuredPost.enabled && featuredPost && (
            <section class="mb-12">
              <div class="flex items-center justify-between mb-5">
                <h2 class="section-heading">
                  <span aria-hidden="true" class="section-heading-ornament">◆</span>
                  {siteConfig.homeOptions.featuredPost.type === "latest" ? "Latest" : "Featured"}
                </h2>
              </div>
              <PostCard post={featuredPost} featured={true} eager={true} context="featured" />
            </section>
          )}

          <!-- Recently Updated -->
          {recentlyUpdated.length > 0 && (
            <section class="mb-12">
              <div class="relative rounded-xl p-5 overflow-hidden
                bg-gradient-to-br from-highlight-500/5 via-primary-50/0 to-primary-500/5
                dark:from-highlight-600/8 dark:via-primary-950/0 dark:to-primary-800/10
                border border-primary-200/40 dark:border-primary-700/30">
                {/* Islamic 8-point star tile */}
                <svg class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <pattern id="pat-updated" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
                      <g fill="none" style="stroke: rgb(var(--color-highlight-500)); stroke-width: 0.9;" class="pattern-lines">
                        <polygon transform="translate(40,40)" points="0,-18 2.87,-6.93 12.73,-12.73 6.93,-2.87 18,0 6.93,2.87 12.73,12.73 2.87,6.93 0,18 -6.93,6.93 -12.73,12.73 -6.93,2.87 -18,0 -6.93,-2.87 -12.73,-12.73 -2.87,-6.93"/>
                        <polygon transform="translate(0,0)" points="0,-18 2.87,-6.93 12.73,-12.73 6.93,-2.87 18,0 6.93,2.87 12.73,12.73 2.87,6.93 0,18 -6.93,6.93 -12.73,12.73 -6.93,2.87 -18,0 -6.93,-2.87 -12.73,-12.73 -2.87,-6.93"/>
                        <polygon transform="translate(80,0)" points="0,-18 2.87,-6.93 12.73,-12.73 6.93,-2.87 18,0 6.93,2.87 12.73,12.73 2.87,6.93 0,18 -6.93,6.93 -12.73,12.73 -6.93,2.87 -18,0 -6.93,-2.87 -12.73,-12.73 -2.87,-6.93"/>
                        <polygon transform="translate(0,80)" points="0,-18 2.87,-6.93 12.73,-12.73 6.93,-2.87 18,0 6.93,2.87 12.73,12.73 2.87,6.93 0,18 -6.93,6.93 -12.73,12.73 -6.93,2.87 -18,0 -6.93,-2.87 -12.73,-12.73 -2.87,-6.93"/>
                        <polygon transform="translate(80,80)" points="0,-18 2.87,-6.93 12.73,-12.73 6.93,-2.87 18,0 6.93,2.87 12.73,12.73 2.87,6.93 0,18 -6.93,6.93 -12.73,12.73 -6.93,2.87 -18,0 -6.93,-2.87 -12.73,-12.73 -2.87,-6.93"/>
                      </g>
                    </pattern>
                  </defs>
                  <rect width="100%" height="100%" fill="url(#pat-updated)"/>
                </svg>
                {/* top edge glow */}
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-2/3 h-px bg-gradient-to-r from-transparent via-highlight-500/50 to-transparent pointer-events-none" aria-hidden="true"></div>

                <div class="flex items-center justify-between mb-4">
                  <h2 class="section-heading">
                    <span aria-hidden="true" class="section-heading-ornament">◆</span>
                    Recently Updated
                  </h2>
                  <span class="text-xs text-primary-400 dark:text-primary-500 tabular-nums">{recentlyUpdated.length} articles</span>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                  {recentlyUpdated.map((post: any) => {
                    const modDate = getModifiedDate(post)!;
                    const cat: string = post.data.category ?? '';
                    const modLabel = modDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
                    return (
                      <a
                        href={`${import.meta.env.BASE_URL}posts/${post.id}`}
                        class="group relative flex flex-col gap-1 p-3.5 rounded-lg
                          bg-white/40 dark:bg-primary-950/40
                          backdrop-blur-sm
                          border border-primary-200/60 dark:border-primary-700/40
                          hover:border-highlight-400/60 dark:hover:border-highlight-500/40
                          hover:shadow-[0_0_16px_rgb(var(--color-highlight-500)/0.12)]
                          transition-all duration-200"
                      >
                        <div class="flex items-center justify-between gap-2">
                          {cat && (
                            <span class="text-[0.65rem] font-bold tracking-widest uppercase text-highlight-600 dark:text-highlight-400 truncate">
                              {cat}
                            </span>
                          )}
                          <span class="text-[0.65rem] text-primary-400 dark:text-primary-500 tabular-nums shrink-0 ml-auto flex items-center gap-1">
                            <span aria-hidden="true">↻</span>{modLabel}
                          </span>
                        </div>
                        <span class="text-sm font-medium leading-snug text-primary-900 dark:text-primary-100 group-hover:text-highlight-600 dark:group-hover:text-highlight-400 transition-colors line-clamp-2">
                          {post.data.title}
                        </span>
                      </a>
                    );
                  })}
                </div>
              </div>
            </section>
          )}

          <!-- Newly Added -->
          {newlyAdded.length > 0 && (
            <section class="mb-12">
              <div class="relative rounded-xl p-5 overflow-hidden
                bg-gradient-to-br from-primary-500/4 via-transparent to-highlight-500/5
                dark:from-primary-800/20 dark:via-transparent dark:to-highlight-700/8
                border border-primary-200/40 dark:border-primary-700/30">
                {/* Islamic 8-point star tile */}
                <svg class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <pattern id="pat-added" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
                      <g fill="none" style="stroke: rgb(var(--color-highlight-500)); stroke-width: 0.9;" class="pattern-lines">
                        <polygon transform="translate(40,40)" points="0,-18 2.87,-6.93 12.73,-12.73 6.93,-2.87 18,0 6.93,2.87 12.73,12.73 2.87,6.93 0,18 -6.93,6.93 -12.73,12.73 -6.93,2.87 -18,0 -6.93,-2.87 -12.73,-12.73 -2.87,-6.93"/>
                        <polygon transform="translate(0,0)" points="0,-18 2.87,-6.93 12.73,-12.73 6.93,-2.87 18,0 6.93,2.87 12.73,12.73 2.87,6.93 0,18 -6.93,6.93 -12.73,12.73 -6.93,2.87 -18,0 -6.93,-2.87 -12.73,-12.73 -2.87,-6.93"/>
                        <polygon transform="translate(80,0)" points="0,-18 2.87,-6.93 12.73,-12.73 6.93,-2.87 18,0 6.93,2.87 12.73,12.73 2.87,6.93 0,18 -6.93,6.93 -12.73,12.73 -6.93,2.87 -18,0 -6.93,-2.87 -12.73,-12.73 -2.87,-6.93"/>
                        <polygon transform="translate(0,80)" points="0,-18 2.87,-6.93 12.73,-12.73 6.93,-2.87 18,0 6.93,2.87 12.73,12.73 2.87,6.93 0,18 -6.93,6.93 -12.73,12.73 -6.93,2.87 -18,0 -6.93,-2.87 -12.73,-12.73 -2.87,-6.93"/>
                        <polygon transform="translate(80,80)" points="0,-18 2.87,-6.93 12.73,-12.73 6.93,-2.87 18,0 6.93,2.87 12.73,12.73 2.87,6.93 0,18 -6.93,6.93 -12.73,12.73 -6.93,2.87 -18,0 -6.93,-2.87 -12.73,-12.73 -2.87,-6.93"/>
                      </g>
                    </pattern>
                  </defs>
                  <rect width="100%" height="100%" fill="url(#pat-added)"/>
                </svg>
                {/* top edge glow */}
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-2/3 h-px bg-gradient-to-r from-transparent via-primary-400/40 to-transparent pointer-events-none" aria-hidden="true"></div>

                <div class="flex items-center justify-between mb-4">
                  <h2 class="section-heading">
                    <span aria-hidden="true" class="section-heading-ornament">◆</span>
                    Newly Added
                  </h2>
                  <a href={`${import.meta.env.BASE_URL}posts`} class="text-base text-highlight-600 dark:text-highlight-400 border-b border-dotted border-highlight-400/50 hover:border-solid pb-0.5 transition-all">
                    All articles →
                  </a>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                  {newlyAdded.map((post: any) => {
                    const cat: string = post.data.category ?? '';
                    const pubLabel = post.data.date
                      ? new Date(post.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
                      : '';
                    return (
                      <a
                        href={`${import.meta.env.BASE_URL}posts/${post.id}`}
                        class="group relative flex flex-col gap-1.5 p-4 rounded-lg
                          bg-white/40 dark:bg-primary-950/40
                          backdrop-blur-sm
                          border border-primary-200/60 dark:border-primary-700/40
                          hover:border-highlight-400/60 dark:hover:border-highlight-500/40
                          hover:shadow-[0_0_16px_rgb(var(--color-highlight-500)/0.12)]
                          transition-all duration-200"
                      >
                        <div class="flex items-center justify-between gap-2">
                          {cat && (
                            <span class="text-[0.65rem] font-bold tracking-widest uppercase text-highlight-600 dark:text-highlight-400 truncate">
                              {cat}
                            </span>
                          )}
                          <span class="inline-flex items-center gap-0.5 text-[0.65rem] font-semibold tracking-wider uppercase text-primary-400 dark:text-primary-500 shrink-0 ml-auto">
                            <span aria-hidden="true" class="text-highlight-500/70">✦</span> New
                          </span>
                        </div>
                        <span class="text-sm font-semibold leading-snug text-primary-900 dark:text-primary-100 group-hover:text-highlight-600 dark:group-hover:text-highlight-400 transition-colors line-clamp-3">
                          {post.data.title}
                        </span>
                        {post.data.description && (
                          <span class="text-xs text-primary-500 dark:text-primary-400 line-clamp-2 leading-relaxed mt-auto">
                            {post.data.description}
                          </span>
                        )}
                        {pubLabel && (
                          <span class="text-[0.65rem] text-primary-400 dark:text-primary-500 tabular-nums mt-0.5">
                            {pubLabel}
                          </span>
                        )}
                      </a>
                    );
                  })}
                </div>
              </div>
            </section>
          )}

          <!-- Recent posts -->
          {siteConfig.homeOptions.recentPosts.enabled && previewPosts.length > 0 && (
            <section class="mb-12">
              <div class="flex items-center justify-between mb-5">
                <h2 class="section-heading">
                  <span aria-hidden="true" class="section-heading-ornament">◆</span>
                  Recent Articles
                </h2>
                <a
                  href={`${import.meta.env.BASE_URL}posts`}
                  class="text-base text-highlight-600 dark:text-highlight-400 border-b border-dotted border-highlight-400/50 hover:border-solid pb-0.5 transition-all"
                >
                  View all {postCount} →
                </a>
              </div>
              <div class="space-y-4">
                {previewPosts.map((post: any, index: number) => (
                  <PostCard post={post} eager={featuredPost ? index === 0 : index < 2} context="recent" />
                ))}
              </div>
            </section>
          )}

          {siteConfig.homeOptions.blurb.placement === 'below' && HomeBlurbContent && (
            <section class="prose prose-sm dark:prose-dark max-w-none mt-12">
              <HomeBlurbContent />
            </section>
          )}
        </>
      ) : (
        <section class="text-center py-16">
          <div class="max-w-md mx-auto">
            <Icon name="file-text" class="w-16 h-16 text-primary-400 dark:text-primary-500 mx-auto mb-6" />
            <h2 class="text-2xl font-semibold text-primary-900 dark:text-primary-50 mb-4">No Posts Yet</h2>
            <p class="text-primary-600 dark:text-primary-300 mb-8">
              This blog is just getting started. Check back soon for new content!
            </p>
            {isDev && (
              <div class="p-4 bg-blue-50 dark:bg-blue-950 rounded-lg border border-blue-200 dark:border-blue-800">
                <p class="text-sm text-blue-800 dark:text-blue-200">
