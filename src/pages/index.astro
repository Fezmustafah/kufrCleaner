  .hp-btn.primary { background: var(--hp-accent); border-color: var(--hp-accent); color: rgb(var(--color-primary-50)); }
  :global(html.dark) .hp-btn.primary { color: rgb(var(--color-primary-900)); }
  .hp-btn.primary:hover { background: rgb(var(--color-highlight-800)); border-color: rgb(var(--color-highlight-800)); text-decoration: none; }
  :global(html.dark) .hp-btn.primary:hover { background: rgb(var(--color-highlight-300)); border-color: rgb(var(--color-highlight-300)); }
</style>

<script>
  function initHomeSections() {
    // Segmented "Latest" toggle
    const seg = document.querySelector('.hp-seg');
    if (seg) {
      seg.querySelectorAll('button').forEach((btn) => {
        btn.addEventListener('click', () => {
          seg.querySelectorAll('button').forEach((b) => b.setAttribute('aria-pressed', 'false'));
          btn.setAttribute('aria-pressed', 'true');
          const isNew = (btn as HTMLElement).dataset.tab === 'new';
          const nw = document.getElementById('hp-latest-new');
          const up = document.getElementById('hp-latest-upd');
          if (nw) nw.hidden = !isNew;
          if (up) up.hidden = isNew;
        });
      });
    }
  }

  // Initial load fires DOMContentLoaded only; Swup fires `swup:page:view` (once)
  // per navigation. So: direct call wires the toggle on load, listener re-wires it
  // after each swap (the segmented buttons are replaced with the swapped content).
  initHomeSections();
  document.addEventListener('swup:page:view', initHomeSections);
</script>
