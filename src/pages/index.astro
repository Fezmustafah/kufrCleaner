---
import { getCollection, getEntry, render, type CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config';
import { generateHomeSEO } from '@/utils/seo';
import { shouldShowPost, sortPostsByDate, processPost, extractCategories } from '@/utils/markdown';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Icon from '@/components/Icon.astro';
import { optimizePostImagePath } from '@/utils/images';
import HomepageHero from '@/components/HomepageHero.astro';

// Get all posts and filter by visibility
const allPosts = await getCollection('posts');
const isDev = import.meta.env.DEV;
const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));
const sortedPosts = sortPostsByDate(visiblePosts);

// Process posts for reading time and word count
const processedPosts = await Promise.all(
  sortedPosts.map(async (post) => await processPost(post))
) as any[];

// Get featured post based on configuration
let featuredPost = null;
if (siteConfig.homeOptions.featuredPost.enabled) {
  if (siteConfig.homeOptions.featuredPost.type === "latest") {
    featuredPost = processedPosts[0];
  } else if (siteConfig.homeOptions.featuredPost.type === "featured" && siteConfig.homeOptions.featuredPost.slug) {
    // Find the specific post by id (slug config value maps to post.id in v6)
    featuredPost = processedPosts.find(post => post.id === siteConfig.homeOptions.featuredPost.slug) || null;
  }
}

// Get preview posts based on whether featured post is shown
const previewPosts = featuredPost
  ? processedPosts.slice(1, siteConfig.homeOptions.recentPosts.count + 1)
  : processedPosts.slice(0, siteConfig.homeOptions.recentPosts.count);

// Get home blurb content from special collection
let homeBlurbContent = null;
let HomeBlurbContent = null;

if (siteConfig.homeOptions.blurb.placement !== 'none') {
  try {
    homeBlurbContent = await getEntry('special', 'home');
    if (homeBlurbContent) {
      const { Content } = await render(homeBlurbContent);
      HomeBlurbContent = Content;
    }
  } catch (error) {
  }
}

// Extract categories and post counts for hero section
const allCategories = extractCategories(sortedPosts);
const categoryPostCounts = allCategories.reduce((acc: Record<string, number>, cat: string) => {
  acc[cat] = sortedPosts.filter((p: any) => p.data.category === cat).length;
  return acc;
}, {} as Record<string, number>);

// Stats for hero
const postCount = visiblePosts.length;
const categoryCount = allCategories.length;

// Determine which content types are being displayed
const hasFeaturedPost = siteConfig.homeOptions.featuredPost.enabled && featuredPost;
const hasRecentPosts = siteConfig.homeOptions.recentPosts.enabled && previewPosts.length > 0;

// Count how many content types are being displayed
const contentTypesCount = [hasFeaturedPost, hasRecentPosts].filter(Boolean).length;

// Determine if only blurb content should be shown (no posts)
const onlyBlurbContent = contentTypesCount === 0 && siteConfig.homeOptions.blurb.placement !== 'none' && HomeBlurbContent;

// Generate SEO data for homepage
const seoData = generateHomeSEO(Astro.url.href);
if (siteConfig.homepageTitle) seoData.title = siteConfig.homepageTitle;

// Structured data for the website
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: siteConfig.title,
  description: siteConfig.description,
  url: siteConfig.site,
  author: {
    '@type': 'Person',
    name: siteConfig.author
  },
  publisher: {
    '@type': 'Organization',
    name: siteConfig.title,
    url: siteConfig.site
  }
};
---

<BaseLayout seoData={seoData}>
  <Fragment slot="head">
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Preload critical images - use same URL as actual img tags for caching -->
    {featuredPost && featuredPost.data.image && siteConfig.postOptions.showPostCardCoverImages === 'all' && !featuredPost.data.hideCoverImage && typeof featuredPost.data.image === 'string' && !featuredPost.data.image.startsWith('http') && (
      <link
        rel="preload"
        as="image"
        href={optimizePostImagePath(featuredPost.data.image, undefined, featuredPost.id)}
        fetchpriority="high"
      />
    )}
  </Fragment>

  <HomepageHero postCount={postCount} categoryCount={categoryCount} />

  <div class="py-8 relative">
    <div class="mx-auto px-4 sm:px-6 lg:px-8" style={`max-width: ${siteConfig.layout.contentWidth}`}>

      <!-- ═══════════════════ BROWSE BY CATEGORY ═══════════════════ -->
      {siteConfig.postOptions.categories && allCategories.length > 0 && (
        <section class="mb-12 mt-10">
          <div class="flex items-center justify-between mb-5">
            <h2 class="section-heading">
              <span aria-hidden="true" class="section-heading-ornament">◆</span>
              Browse by Topic
            </h2>
            <a href={`${import.meta.env.BASE_URL}posts`} class="text-base text-highlight-600 dark:text-highlight-400 border-b border-dotted border-highlight-400/50 hover:border-solid pb-0.5 transition-all">
              All articles →
            </a>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
            {allCategories.map((cat: string) => (
              <a
                href={`${import.meta.env.BASE_URL}posts/category/${encodeURIComponent(cat)}`}
                class="group flex items-center gap-2 px-3 py-2 rounded-lg border border-primary-200 dark:border-primary-700 bg-primary-50 dark:bg-primary-900/60 hover:bg-primary-100 dark:hover:bg-primary-800/60 hover:border-highlight-400/60 dark:hover:border-highlight-600/40 transition-all duration-150"
              >
                <Icon name="book-open" class="w-3.5 h-3.5 text-secondary-500 dark:text-secondary-400 shrink-0" />
                <span class="font-medium text-sm text-primary-800 dark:text-primary-100 group-hover:text-highlight-600 dark:group-hover:text-highlight-400 transition-colors truncate flex-1">
                  {cat}
                </span>
                <span class="text-xs text-primary-400 dark:text-primary-500 tabular-nums shrink-0">
                  {categoryPostCounts[cat]}
                </span>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- ═══════════════════ MAIN CONTENT ═══════════════════ -->
      {onlyBlurbContent ? (
        <article class="bg-primary-50 dark:bg-primary-900 rounded-lg border border-primary-200 dark:border-primary-700 shadow-sm">
          <div class="p-6 rounded-lg">
            {homeBlurbContent?.data.title && (
              <header class="mb-4">
                <h2 class="text-xl font-bold text-primary-900 dark:text-primary-50 mb-6 leading-tight">
                  {homeBlurbContent.data.title}
                </h2>
              </header>
            )}
            <div class="prose dark:prose-dark max-w-none" id="page-content">
              {HomeBlurbContent && <HomeBlurbContent />}
            </div>
          </div>
        </article>
      ) : processedPosts.length > 0 ? (
        <>
          {siteConfig.homeOptions.blurb.placement === 'above' && HomeBlurbContent && (
            <section class="prose prose-sm dark:prose-dark max-w-none mb-12">
              <HomeBlurbContent />
            </section>
          )}

          <!-- Featured post -->
          {siteConfig.homeOptions.featuredPost.enabled && featuredPost && (
            <section class="mb-12">
              <div class="flex items-center justify-between mb-5">
                <h2 class="section-heading">
                  <span aria-hidden="true" class="section-heading-ornament">◆</span>
                  {siteConfig.homeOptions.featuredPost.type === "latest" ? "Latest" : "Featured"}
                </h2>
              </div>
              <PostCard post={featuredPost} featured={true} eager={true} context="featured" />
            </section>
          )}

          <!-- Recent posts -->
          {siteConfig.homeOptions.recentPosts.enabled && previewPosts.length > 0 && (
            <section class="mb-12">
              <div class="flex items-center justify-between mb-5">
                <h2 class="section-heading">
                  <span aria-hidden="true" class="section-heading-ornament">◆</span>
                  Recent Articles
                </h2>
                <a
                  href={`${import.meta.env.BASE_URL}posts`}
                  class="text-base text-highlight-600 dark:text-highlight-400 border-b border-dotted border-highlight-400/50 hover:border-solid pb-0.5 transition-all"
                >
                  View all {postCount} →
                </a>
              </div>
              <div class="space-y-4">
                {previewPosts.map((post: any, index: number) => (
                  <PostCard post={post} eager={featuredPost ? index === 0 : index < 2} context="recent" />
                ))}
              </div>
            </section>
          )}

          {siteConfig.homeOptions.blurb.placement === 'below' && HomeBlurbContent && (
            <section class="prose prose-sm dark:prose-dark max-w-none mt-12">
              <HomeBlurbContent />
            </section>
          )}
        </>
      ) : (
        <section class="text-center py-16">
          <div class="max-w-md mx-auto">
            <Icon name="file-text" class="w-16 h-16 text-primary-400 dark:text-primary-500 mx-auto mb-6" />
            <h2 class="text-2xl font-semibold text-primary-900 dark:text-primary-50 mb-4">No Posts Yet</h2>
            <p class="text-primary-600 dark:text-primary-300 mb-8">
              This blog is just getting started. Check back soon for new content!
            </p>
            {isDev && (
              <div class="p-4 bg-blue-50 dark:bg-blue-950 rounded-lg border border-blue-200 dark:border-blue-800">
                <p class="text-sm text-blue-800 dark:text-blue-200">
                  <strong>Dev Mode:</strong> Add some posts to the <code>content/posts/</code> directory to see them here.
                </p>
              </div>
            )}
          </div>
        </section>
      )}

      <!-- ═══════════════════ SUPPORT & SOCIALS ═══════════════════ -->
      <section class="support-section mt-16 mb-8">
        <div class="support-inner">

          <!-- Ornament -->
          <div class="support-ornament" aria-hidden="true">
            <span class="support-ornament-line"></span>
            <span class="support-ornament-glyph">◈</span>
            <span class="support-ornament-line"></span>
          </div>

          <h2 class="support-heading">Support This Work</h2>

          <p class="support-body">
            OpenIslam Wiki is a free, independent resource — no paywalls, no ads, no institutional
            funding. Every article you read, every refutation published, and every manuscript
            authenticated is sustained by readers who believe the truth deserves a permanent home.
            If this knowledge has benefited you, consider helping us keep it alive and growing.
          </p>

          <p class="support-body support-body--secondary">
            Your contribution covers hosting, research access, translation costs, and the time
            needed to verify sources properly — because getting it right matters more than
            getting it fast.
          </p>

          <!-- Donate button -->
          <a
            href="https://www.paypal.com/invoice/p/#GRZNFXRSGNM52F5B"
            target="_blank"
            rel="noopener noreferrer"
            class="support-donate-btn"
            aria-label="Donate via PayPal"
          >
            <Icon name="paypal" size={17} class="support-donate-icon" />
            <span>Donate via PayPal</span>
          </a>

          <!-- Divider -->
          <div class="support-divider" aria-hidden="true">
            <span class="support-divider-ornament">◇ ✦ ◇</span>
          </div>

          <!-- Socials -->
          <p class="support-follow-label">Follow &amp; Join the Conversation</p>
          <div class="support-socials">
            <a
              href="https://x.com/kufrcleaner1"
              target="_blank"
              rel="noopener noreferrer"
              class="support-social-link"
              aria-label="X / Twitter"
            >
              <Icon name="x-twitter" size={18} />
              <span>X / Twitter</span>
            </a>
            <a
              href="https://www.instagram.com/kufrcleaner/?hl=en"
              target="_blank"
              rel="noopener noreferrer"
              class="support-social-link"
              aria-label="Instagram"
            >
              <Icon name="instagram" size={18} />
              <span>Instagram</span>
            </a>
            <a
              href="https://discord.gg/29gmvhXRh8"
              target="_blank"
              rel="noopener noreferrer"
              class="support-social-link"
              aria-label="Discord"
            >
              <Icon name="discord" size={18} />
              <span>Discord</span>
            </a>
          </div>

        </div>
      </section>

    </div>
  </div>
</BaseLayout>


<style>
  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-heading, serif);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-primary-600));
  }
  :global(.dark) .section-heading {
    color: rgb(var(--color-primary-400));
  }
  .section-heading-ornament {
    color: rgb(var(--color-highlight-500));
    font-size: 0.5em;
    opacity: 0.7;
    vertical-align: middle;
  }

  /* ── Support & Socials section ── */
  .support-section {
    border-top: 1px solid rgb(var(--color-highlight-500) / 0.2);
    padding-top: 3.5rem;
  }

  .support-inner {
    text-align: center;
    max-width: 38rem;
    margin: 0 auto;
  }

  .support-ornament {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.75rem;
  }
  .support-ornament-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, rgb(var(--color-highlight-500) / 0.4));
  }
  .support-ornament-line:last-child {
    background: linear-gradient(to left, transparent, rgb(var(--color-highlight-500) / 0.4));
  }
  .support-ornament-glyph {
    color: rgb(var(--color-highlight-500));
    font-size: 0.9rem;
    line-height: 1;
  }

  .support-heading {
    font-family: var(--font-heading, serif);
    font-size: clamp(1.35rem, 4vw, 1.75rem);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-primary-900));
    margin: 0 0 1.25rem;
  }
  :global(.dark) .support-heading {
    color: rgb(var(--color-primary-50));
  }

  .support-body {
    font-family: var(--font-prose, serif);
    font-size: 1rem;
    line-height: 1.8;
    color: rgb(var(--color-primary-700));
    margin: 0 0 1rem;
  }
  :global(.dark) .support-body {
    color: rgb(var(--color-primary-300));
  }
  .support-body--secondary {
    font-size: 0.93rem;
    color: rgb(var(--color-primary-500));
    margin-bottom: 2rem;
  }
  :global(.dark) .support-body--secondary {
    color: rgb(var(--color-primary-400));
  }

  .support-donate-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.65rem 1.6rem;
    background: rgb(var(--color-highlight-500));
    color: #fff;
    font-family: var(--font-prose, serif);
    font-size: 0.97rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    border-radius: 0.2rem;
    text-decoration: none;
    border: 1px solid rgb(var(--color-highlight-500));
    transition: background 0.18s, border-color 0.18s;
    margin-bottom: 2.5rem;
  }
  .support-donate-btn:hover {
    background: rgb(var(--color-highlight-400));
    border-color: rgb(var(--color-highlight-400));
    text-decoration: none;
  }
  .support-donate-icon {
    opacity: 0.9;
  }

  .support-divider {
    position: relative;
    height: 1px;
    background:
      linear-gradient(to right, transparent, rgb(var(--color-highlight-500) / 0.4)) 0 0 / 44% 1px no-repeat,
      linear-gradient(to left, transparent, rgb(var(--color-highlight-500) / 0.4)) 100% 0 / 44% 1px no-repeat;
    margin-bottom: 1.75rem;
    overflow: visible;
  }
  .support-divider-ornament {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    color: rgb(var(--color-highlight-400));
    font-size: 0.6em;
    letter-spacing: 0.35em;
    white-space: nowrap;
    background: rgb(var(--color-primary-50));
    padding: 0 0.4rem;
  }
  :global(.dark) .support-divider-ornament {
    background: rgb(var(--color-primary-950));
  }

  .support-follow-label {
    font-family: var(--font-prose, serif);
    font-style: italic;
    font-size: 0.88rem;
    color: rgb(var(--color-primary-400));
    margin: 0 0 1rem;
    letter-spacing: 0.03em;
  }

  .support-socials {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding-bottom: 1rem;
  }

  .support-social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.9rem;
    border: 1px solid rgb(var(--color-primary-200));
    border-radius: 0.2rem;
    font-family: var(--font-prose, serif);
    font-size: 0.88rem;
    color: rgb(var(--color-primary-600));
    text-decoration: none;
    background: rgb(var(--color-primary-50));
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  :global(.dark) .support-social-link {
    border-color: rgb(var(--color-primary-700));
    color: rgb(var(--color-primary-300));
    background: rgb(var(--color-primary-900) / 0.6);
  }
  .support-social-link:hover {
    border-color: rgb(var(--color-highlight-500) / 0.6);
    color: rgb(var(--color-highlight-600));
    background: rgb(var(--color-primary-100));
    text-decoration: none;
  }
  :global(.dark) .support-social-link:hover {
    border-color: rgb(var(--color-highlight-600) / 0.5);
    color: rgb(var(--color-highlight-400));
    background: rgb(var(--color-primary-800) / 0.5);
  }
</style>
